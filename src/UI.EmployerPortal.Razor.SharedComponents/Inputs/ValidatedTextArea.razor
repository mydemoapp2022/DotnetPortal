@using UI.EmployerPortal.Razor.SharedComponents.Validation
<div class="form-group master-text-field-full @(showError ? "master-text-field--error" : "")">
    <label for="@Id" class="form-label @(showError ? "master-label--error" : "")">
        @Label
    </label>

    <textarea id="@Id"
              class="form-input master-input @(showError ? "master-input--error" : "")"
              style="height: auto; @(Width > 0 ? $"width:{Width}px;" : "")"
              rows="@Rows"
              maxlength="@MaxLength"
              disabled="@Disabled"
              value="@Value"
              @onchange="HandleChange"
              @oninput="HandleInput"
              @onblur="HandleBlur">@Value</textarea>

    @if (showError && !string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <ValidationError ErrorMessage="@ErrorMessage" />
    }
</div>

@code {
    /// <summary>HTML id for the textarea element.</summary>
    [Parameter] public string Id { get; set; } = string.Empty;

    /// <summary>Label text displayed above the textarea.</summary>
    [Parameter] public string Label { get; set; } = string.Empty;

    /// <summary>Current value.</summary>
    [Parameter] public string? Value { get; set; }

    /// <summary>Two-way binding callback.</summary>
    [Parameter] public EventCallback<string> ValueChanged { get; set; }

    /// <summary>HTML maxlength attribute.</summary>
    [Parameter] public int? MaxLength { get; set; }

    /// <summary>Number of visible text rows. Defaults to 4.</summary>
    [Parameter] public int Rows { get; set; } = 4;

    /// <summary>Input width in pixels. Set 0 to omit.</summary>
    [Parameter] public int Width { get; set; }

    /// <summary>Whether the field currently has a validation error.</summary>
    [Parameter] public bool HasError { get; set; }

    /// <summary>Error message to display below the textarea.</summary>
    [Parameter] public string? ErrorMessage { get; set; }

    /// <summary>Callback invoked on blur.</summary>
    [Parameter] public EventCallback OnBlur { get; set; }

    /// <summary>Disables the textarea when true.</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>Visible the input error when true.</summary>
    [Parameter] public bool Visible { get; set; }

    private bool touched;

    private bool showError => (touched || Visible) && HasError;

    private async Task HandleChange(ChangeEventArgs e)
    {
        touched = true;
        await ValueChanged.InvokeAsync(e.Value?.ToString() ?? string.Empty);
    }

    private async Task HandleBlur()
    {
        touched = true;
        await OnBlur.InvokeAsync();
    }

    private async Task HandleInput(ChangeEventArgs e)
    {
        var val = e.Value?.ToString() ?? string.Empty;
        await ValueChanged.InvokeAsync(val);
    }
}
