@using Microsoft.JSInterop
@using UI.EmployerPortal.Razor.SharedComponents.Validation
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="form-group master-text-field @(showError ? "master-text-field--error" : "") @CSS">
    <label for="@Id"
           class="form-label @(showError ? "master-label--error" : "")">
        @Label
    </label>

    <input type="text"
           id="@Id"
           class="form-input master-input @(showError ? "master-input--error" : "")"
           style="@(Width > 0 ? $"width:{Width}px;" : "")"
           value="@FormattedValue"
           disabled="@Disabled"
           required="@IsRequired"
           aria-required="@IsRequired"
           aria-invalid="@showError"
           aria-describedby="@AriaDescribedBy"
           placeholder="@Placeholder"
           @onblur="HandleBlur"
           readonly />

    @if (showError && !string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <ValidationError Id="@ErrorId" ErrorMessage="@ErrorMessage" />
    }
</div>

@code {
    /// <summary>HTML id for the input element.</summary>
    [Parameter] public string Id { get; set; } = string.Empty;

    /// <summary>Label text displayed above the input.</summary>
    [Parameter] public string Label { get; set; } = string.Empty;

    /// <summary>Current date value.</summary>
    [Parameter] public DateTime? Value { get; set; }

    /// <summary>Two-way binding callback.</summary>
    [Parameter] public EventCallback<DateTime?> ValueChanged { get; set; }

    /// <summary>Minimum allowed date.</summary>
    [Parameter] public DateTime? Min { get; set; }

    /// <summary>Maximum allowed date.</summary>
    [Parameter] public DateTime? Max { get; set; }

    /// <summary>
    /// Specific dates to disable in Flatpickr (e.g. Federal Reserve holidays).
    /// Pass as ISO strings: "yyyy-MM-dd".
    /// When null or empty, only weekends + min/max range are enforced.
    /// </summary>
    [Parameter] public IReadOnlyList<string>? DisabledDates { get; set; }

    /// <summary>Input width in pixels. Set 0 to omit.</summary>
    [Parameter] public int Width { get; set; }

    /// <summary>Whether the field currently has a validation error.</summary>
    [Parameter] public bool HasError { get; set; }

    /// <summary>Error message to display below the input.</summary>
    [Parameter] public string? ErrorMessage { get; set; }

    /// <summary>Callback invoked on input blur.</summary>
    [Parameter] public EventCallback OnBlur { get; set; }

    /// <summary>Disables the input when true.</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>Style to display the input label.</summary>
    [Parameter] public string? CSS { get; set; }

    /// <summary>Visible the input error when true.</summary>
    [Parameter] public bool Visible { get; set; }

    /// <summary>Marks the field as required for assistive technologies.</summary>
    [Parameter] public bool IsRequired { get; set; }

    /// <summary>
    /// Optional id of an external hint/instruction element to associate via aria-describedby.
    /// </summary>
    [Parameter] public string? HintId { get; set; }

    /// <summary>Optional placeholder shown inside the input.</summary>
    [Parameter] public string? Placeholder { get; set; }

    private bool touched;
    private bool showError => (touched || Visible) && HasError;
    private string ErrorId => $"{Id}-error";
    private DotNetObjectReference<ValidatedDateInput>? _dotNetRef;

    private string? AriaDescribedBy
    {
        get
        {
            var ids = new List<string>();
            if (!string.IsNullOrWhiteSpace(HintId)) ids.Add(HintId!);
            if (showError && !string.IsNullOrWhiteSpace(ErrorMessage)) ids.Add(ErrorId);
            return ids.Count > 0 ? string.Join(" ", ids) : null;
        }
    }

    private string? FormattedValue => Value?.ToString("yyyy-MM-dd");
    private string? FormattedMin => Min?.ToString("yyyy-MM-dd");
    private string? FormattedMax => Max?.ToString("yyyy-MM-dd");

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && DisabledDates is not null)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync(
                "initAchDatePicker",
                Id,
                FormattedMin,
                FormattedMax,
                DisabledDates,
                _dotNetRef);
        }
    }

    /// <summary>
    /// Called by Flatpickr via JS interop when the user selects a date.
    /// </summary>
    [JSInvokable]
    public async Task OnFlatpickrDateSelected(string dateStr)
    {
        touched = true;
        DateTime? newValue = DateTime.TryParse(dateStr, out var date) ? date : null;
        await ValueChanged.InvokeAsync(newValue);
        await OnBlur.InvokeAsync();
        StateHasChanged();
    }

    private async Task HandleBlur()
    {
        touched = true;
        await OnBlur.InvokeAsync();
    }

    public async ValueTask DisposeAsync()
    {
        if (!string.IsNullOrWhiteSpace(Id))
            await JS.InvokeVoidAsync("destroyAchDatePicker", Id);

        _dotNetRef?.Dispose();
    }
}
