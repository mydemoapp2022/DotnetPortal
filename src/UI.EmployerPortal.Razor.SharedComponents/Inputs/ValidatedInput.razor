@using Microsoft.JSInterop
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<div class="form-group master-text-field @(showError ? "master-text-field--error" : "")">
    <label for="@Id"
           class="form-label @(showError ? "master-label--error" : "")">
        @Label
    </label>


    <input @ref="inputElement"
           type="@InputType"
           id="@Id"
           class="form-input master-input @(showError ? "master-input--error" : "")"
           style="@(Width > 0 ? $"width:{Width}px;" : "")"
           maxlength="@MaxLength"
           step="@Step"
           min="@Min"
           max="@Max"
           value="@Value"
           @onchange="HandleChange"
           @onblur="HandleBlur"
           @onfocus="HandleFocus"
           @oninput="HandleInput"
           @onkeyup="HandleKeyUp" />

    @if (showError && !string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="master-error" aria-live="polite">
            <svg width="12" height="16" viewBox="0 0 12 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <mask id="mask0_5694_133" maskUnits="userSpaceOnUse" x="0" y="2" width="12" height="12">
                    <rect y="2" width="12" height="12" fill="#D9D9D9" />
                </mask>
                <g mask="url(#mask0_5694_133)">
                    <path d="M6 10.5C6.14167 10.5 6.26042 10.4521 6.35625 10.3563C6.45208 10.2604 6.5 10.1417 6.5 10C6.5 9.85833 6.45208 9.73958 6.35625 9.64375C6.26042 9.54792 6.14167 9.5 6 9.5C5.85833 9.5 5.73958 9.54792 5.64375 9.64375C5.54792 9.73958 5.5 9.85833 5.5 10C5.5 10.1417 5.54792 10.2604 5.64375 10.3563C5.73958 10.4521 5.85833 10.5 6 10.5ZM5.5 8.5H6.5V5.5H5.5V8.5ZM6 13C5.30833 13 4.65833 12.8687 4.05 12.6062C3.44167 12.3438 2.9125 11.9875 2.4625 11.5375C2.0125 11.0875 1.65625 10.5583 1.39375 9.95C1.13125 9.34167 1 8.69167 1 8C1 7.30833 1.13125 6.65833 1.39375 6.05C1.65625 5.44167 2.0125 4.9125 2.4625 4.4625C2.9125 4.0125 3.44167 3.65625 4.05 3.39375C4.65833 3.13125 5.30833 3 6 3C6.69167 3 7.34167 3.13125 7.95 3.39375C8.55833 3.65625 9.0875 4.0125 9.5375 4.4625C9.9875 4.9125 10.3438 5.44167 10.6062 6.05C10.8687 6.65833 11 7.30833 11 8C11 8.69167 10.8687 9.34167 10.6062 9.95C10.3438 10.5583 9.9875 11.0875 9.5375 11.5375C9.0875 11.9875 8.55833 12.3438 7.95 12.6062C7.34167 12.8687 6.69167 13 6 13ZM6 12C7.11667 12 8.0625 11.6125 8.8375 10.8375C9.6125 10.0625 10 9.11667 10 8C10 6.88333 9.6125 5.9375 8.8375 5.1625C8.0625 4.3875 7.11667 4 6 4C4.88333 4 3.9375 4.3875 3.1625 5.1625C2.3875 5.9375 2 6.88333 2 8C2 9.11667 2.3875 10.0625 3.1625 10.8375C3.9375 11.6125 4.88333 12 6 12Z"
                          fill="#C82838" />
                </g>
            </svg>
            <span>@ErrorMessage</span>
        </div>
    }
</div>

@code {
    private ElementReference inputElement;
    private IJSObjectReference? module;

    /// <summary>HTML id for the input element.</summary>
    [Parameter] public string Id { get; set; } = string.Empty;

    /// <summary>Label text displayed above the input.</summary>
    [Parameter] public string Label { get; set; } = string.Empty;

    /// <summary>Input type: "text" or "number". Defaults to "text".</summary>
    [Parameter] public string InputType { get; set; } = "text";

    /// <summary>Current value (string). For numeric fields, parent converts.</summary>
    [Parameter] public string? Value { get; set; }

    /// <summary>Two-way binding callback.</summary>
    [Parameter] public EventCallback<string> ValueChanged { get; set; }

    /// <summary>HTML maxlength attribute.</summary>
    [Parameter] public int? MaxLength { get; set; }

    /// <summary>HTML min attribute (for number inputs).</summary>
    [Parameter] public string? Min { get; set; }

    /// <summary>HTML max attribute (for number inputs).</summary>
    [Parameter] public string? Max { get; set; }

    /// <summary>Input width in pixels. Set 0 to omit.</summary>
    [Parameter] public int Width { get; set; }

    /// <summary>Whether the field currently has a validation error.</summary>
    [Parameter] public bool HasError { get; set; }

    /// <summary>Error message to display below the input.</summary>
    [Parameter] public string? ErrorMessage { get; set; }

    /// <summary>Callback invoked on input blur (e.g. to trigger validation).</summary>
    [Parameter] public EventCallback OnBlur { get; set; }

    /// <summary>HTML step attribute (e.g. "0.01" for 2 decimal places).</summary>
    [Parameter] public string? Step { get; set; }

    /// <summary>Disables the input when true.</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>Callback invoked on input key up (e.g. to trigger validation).</summary>
    [Parameter] public EventCallback<KeyboardEventArgs> OnKeyUp { get; set; }

    /// <summary>Visible the input error when true.</summary>
    [Parameter] public bool Visible { get; set; }

    /// <summary>Disables the decimal value when true.</summary>
    [Parameter] public bool NoDecimals { get; set; }

    private bool _touched;
    private bool _focused = false;
    private bool showError => !_focused && (_touched || Visible) && HasError;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && InputType == "number" && MaxLength.HasValue)
        {
            module = await JSRuntime.InvokeAsync<IJSObjectReference>(
                "import", "./js/validated-input.js");
            await module.InvokeVoidAsync("attachNumericOnlyFilter", inputElement, MaxLength.Value);
        }
    }

    private async Task HandleChange(ChangeEventArgs e)
    {
        _touched = true;
        await ValueChanged.InvokeAsync(e.Value?.ToString() ?? string.Empty);
    }

    private async Task HandleBlur()
    {
        _focused = false;
        _touched = true;
        await OnBlur.InvokeAsync();
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        _touched = true;
        await OnKeyUp.InvokeAsync(e);
    }

    private async Task HandleInput(ChangeEventArgs e)
    {
        var val = e.Value?.ToString() ?? string.Empty;
        if (InputType == "number")
        {
            if (NoDecimals && val.Contains('.'))
            {
                val = val[..val.IndexOf(',')];
                await ValueChanged.InvokeAsync(val);
                return;
            }
            if (MaxLength.HasValue && val.Length > MaxLength.Value)
            {
                await ValueChanged.InvokeAsync(val.Substring(0, MaxLength.Value));
                return;
            }
        }
        await ValueChanged.InvokeAsync(val);
    }

    private async Task HandleFocus()
    {
        //_focused = true;
    }

    public async ValueTask DisposeAsync()
    {
        if (module is not null)
        {
            try
            {
                await module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // Ignore - the circuit is already disconnected (e.g., page refresh)
            }
            catch (ObjectDisposedException)
            {
                //Js runtime is alredy been disposed (e.g. during circuit disconnect or page navigation etc.)
            }
        }
    }
}
