@using Microsoft.AspNetCore.Components.Forms
@using System.Linq.Expressions
<!-- Text field container with error state class -->
<div class="master-text-field @(HasError ? "master-text-field--error" : "")"
     aria-label="@Label">

    <!-- Label with error color -->
    <label for="@Id"
           class="@(HasError ? "master-label--error" : "")">
        @Label
    </label>

    <!-- Input field with error styling -->
    <input id="@Id"
           class="master-input @(HasError ? "master-input--error" : "")"
           type="@Type"
           value="@Value"
           @oninput="OnInput"
           @onblur="HandleBlur"
           maxlength="@EffectiveMaxLength"
           disabled="@Disabled"
           aria-label="@Label"
           aria-invalid="@HasError"
           aria-required="@IsRequired"
           aria-describedby="@AriaDescribedBy" />

    <!-- Format/Hint Text -->
    @if (!string.IsNullOrWhiteSpace(FormatText))
    {
        <div id="@HintId" class="master-hint">
            @FormatText
        </div>
    }
    @if (HasError)
    {
        <div id="@ErrorId" class="master-error" aria-live="polite">
            <svg width="12" height="16" viewBox="0 0 12 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <mask id="mask0_5694_133" maskUnits="userSpaceOnUse" x="0" y="2" width="12" height="12">
                    <rect y="2" width="12" height="12" fill="#D9D9D9" />
                </mask>

                <g mask="url(#mask0_5694_133)">
                    <path d="M6 10.5C6.14167 10.5 6.26042 10.4521 6.35625 10.3563C6.45208 10.2604 6.5 10.1417 6.5 10C6.5 9.85833 6.45208 9.73958 6.35625 9.64375C6.26042 9.54792 6.14167 9.5 6 9.5C5.85833 9.5 5.73958 9.54792 5.64375 9.64375C5.54792 9.73958 5.5 9.85833 5.5 10C5.5 10.1417 5.54792 10.2604 5.64375 10.3563C5.73958 10.4521 5.85833 10.5 6 10.5ZM5.5 8.5H6.5V5.5H5.5V8.5ZM6 13C5.30833 13 4.65833 12.8687 4.05 12.6062C3.44167 12.3438 2.9125 11.9875 2.4625 11.5375C2.0125 11.0875 1.65625 10.5583 1.39375 9.95C1.13125 9.34167 1 8.69167 1 8C1 7.30833 1.13125 6.65833 1.39375 6.05C1.65625 5.44167 2.0125 4.9125 2.4625 4.4625C2.9125 4.0125 3.44167 3.65625 4.05 3.39375C4.65833 3.13125 5.30833 3 6 3C6.69167 3 7.34167 3.13125 7.95 3.39375C8.55833 3.65625 9.0875 4.0125 9.5375 4.4625C9.9875 4.9125 10.3438 5.44167 10.6062 6.05C10.8687 6.65833 11 7.30833 11 8C11 8.69167 10.8687 9.34167 10.6062 9.95C10.3438 10.5583 9.9875 11.0875 9.5375 11.5375C9.0875 11.9875 8.55833 12.3438 7.95 12.6062C7.34167 12.8687 6.69167 13 6 13ZM6 12C7.11667 12 8.0625 11.6125 8.8375 10.8375C9.6125 10.0625 10 9.11667 10 8C10 6.88333 9.6125 5.9375 8.8375 5.1625C8.0625 4.3875 7.11667 4 6 4C4.88333 4 3.9375 4.3875 3.1625 5.1625C2.3875 5.9375 2 6.88333 2 8C2 9.11667 2.3875 10.0625 3.1625 10.8375C3.9375 11.6125 4.88333 12 6 12Z"
                          fill="#C82838" />
                </g>
            </svg>

            @foreach (var msg in ErrorMessages)
            {
                <span>@msg</span>
            }
        </div>
    }
</div>
@code {
    [Parameter] public string? Label { get; set; }
    [Parameter] public string Id { get; set; } = Guid.NewGuid().ToString();
    [Parameter] public string Type { get; set; } = "text";
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool Visible { get; set; }
    [Parameter] public string? FormatText { get; set; }
    [Parameter] public int? MaxLength { get; set; } = null;
    [Parameter] public string? InputMode { get; set; }

    /// <summary>
    /// Optional mask pattern. Placeholder characters in the mask are filled with user input;
    /// all other characters are treated as literals and inserted automatically.
    /// <list type="bullet">
    ///   <item><c>0</c> — digit (0–9)</item>
    ///   <item><c>A</c> — letter (a–z, A–Z), case preserved</item>
    ///   <item><c>*</c> — alphanumeric (letter or digit)</item>
    ///   <item>any other character — literal separator, auto-inserted</item>
    /// </list>
    /// Examples:
    /// <list type="bullet">
    ///   <item><c>"00-0000000"</c>  → FEIN format (e.g. 12-3456789)</item>
    ///   <item><c>"000-00-0000"</c> → SSN format  (e.g. 123-45-6789)</item>
    ///   <item><c>"000-000-0000"</c>→ Phone       (e.g. 608-555-1234)</item>
    ///   <item><c>"AA-000"</c>      → Mixed       (e.g. AB-123)</item>
    /// </list>
    /// When set, overrides <see cref="MaxLength"/> with the full mask length.
    /// </summary>
    [Parameter] public string? Mask { get; set; }

    /// <summary>
    /// Gets or sets whether the field is required. Sets aria-required for screen readers.
    /// </summary>
    [Parameter] public bool Required { get; set; }

    /// <summary>
    /// Expression to identify the bound field for validation. Primary Parameter
    /// </summary>
    [Parameter] public Expression<Func<string?>>? For { get; set; }

    /// <summary>
    /// Automatically provided by @bind-value. Falls back to this when For is not set.
    /// </summary>
    [Parameter] public Expression<Func<string?>>? ValueExpression { get; set; }

    /// <summary>
    /// Callback invoked when the input loses focus.
    /// </summary>
    [Parameter] public EventCallback OnBlur { get; set; }

    /// <summary>
    /// Cascaded EditContext from parent EditForm
    /// </summary>
    [CascadingParameter] private EditContext? EditContext { get; set; }

    private Expression<Func<string?>>? ResolvedExpression => For ?? ValueExpression;

    /// <summary>
    /// When a <see cref="Mask"/> is set, returns the full mask length (including literal
    /// separators) as the effective maxlength. Otherwise falls back to <see cref="MaxLength"/>.
    /// </summary>
    private int? EffectiveMaxLength => Mask is not null ? Mask.Length : MaxLength;

    private string? HintId => !string.IsNullOrWhiteSpace(FormatText) ? $"{Id}-hint" : null;

    /// <summary>
    /// Generate Id for the error message element.
    /// </summary>
    private string ErrorId => $"{Id}-error";

    /// <summary>
    /// Combines hint and error ids for aria-describedby.
    /// </summary>
    private string? AriaDescribedBy
    {
        get
        {
            var ids = new List<string>();
            if (HintId is not null) ids.Add(HintId);
            if (HasError) ids.Add(ErrorId);
            return ids.Count > 0 ? string.Join(" ", ids) : null;
        }
    }

    /// <summary>
    /// Returns the validation error messages for this field.
    /// </summary>
    private IEnumerable<string> ErrorMessages =>
        EditContext is not null && ResolvedExpression is not null
        ? EditContext.GetValidationMessages(FieldIdentifier.Create(ResolvedExpression))
        : Enumerable.Empty<string>();

    /// <summary>
    /// Tracks whether the user has blurred this field at least once.
    /// </summary>
    private bool _touched;

    private EditContext? _previousEditContext;

    private bool IsRequired
    {
        get
        {
            if (Required) return true;
            if (ResolvedExpression is null) return false;
            var fi = FieldIdentifier.Create(ResolvedExpression);
            var prop = fi.Model.GetType().GetProperty(fi.FieldName);
            return prop is not null && Attribute.IsDefined(prop, typeof(System.ComponentModel.DataAnnotations.RequiredAttribute));
        }
    }

    /// <summary>
    /// Returns true if the field has validation errors and has been touched or forced visible.
    /// </summary>
    private bool HasError =>
        (_touched || Visible) &&
        EditContext is not null &&
        ResolvedExpression is not null &&
        EditContext.GetValidationMessages(FieldIdentifier.Create(ResolvedExpression)).Any();

    protected override void OnParametersSet()
    {
        if (EditContext != _previousEditContext)
        {
            if (_previousEditContext is not null)
            {
                _previousEditContext.OnValidationRequested -= OnValidationRequested;
            }

            if (EditContext is not null)
            {
                EditContext.OnValidationRequested += OnValidationRequested;
            }

            _previousEditContext = EditContext;
            _touched = false;
        }
    }

    /// <summary>
    /// Called when the form is submitted — auto-touches this field so errors show.
    /// </summary>
    private void OnValidationRequested(object? sender, ValidationRequestedEventArgs e)
    {
        _touched = true;
        StateHasChanged();
    }

    private async Task HandleBlur()
    {
        if (!_touched)
        {
            _touched = true;
            if (EditContext is not null && ResolvedExpression is not null)
            {
                EditContext.NotifyFieldChanged(FieldIdentifier.Create(ResolvedExpression));
            }
        }

        await OnBlur.InvokeAsync();
    }

    /// <summary>
    /// Handles input changes and notifies parent.
    /// Applies mask formatting when <see cref="Mask"/> is set, or strips non-digits
    /// when <see cref="InputMode"/> is <c>"numeric"</c>.
    /// </summary>
    private async Task OnInput(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString() ?? "";

        if (Mask is not null)
        {
            raw = ApplyMask(raw, Mask);
        }
        else if (InputMode == "numeric")
        {
            raw = new string(raw.Where(char.IsDigit).ToArray());
            if (MaxLength.HasValue && raw.Length > MaxLength.Value)
                raw = raw[..MaxLength.Value];
        }

        Value = raw;

        await ValueChanged.InvokeAsync(Value);

        if (EditContext is not null && ResolvedExpression is not null)
        {
            EditContext.NotifyFieldChanged(FieldIdentifier.Create(ResolvedExpression));
        }
    }

    /// <summary>
    /// Formats <paramref name="input"/> according to <paramref name="mask"/>.
    /// Processes input and mask in parallel: valid input characters fill placeholder
    /// positions; literal separator characters are auto-inserted. Invalid input
    /// characters (wrong type for the placeholder) are silently skipped.
    /// Trailing separators are never appended when input is exhausted.
    /// </summary>
    /// <remarks>
    /// Placeholder types: <c>'0'</c> = digit, <c>'A'</c> = letter, <c>'*'</c> = alphanumeric.
    /// </remarks>
    private static string ApplyMask(string input, string mask)
    {
        var result = new System.Text.StringBuilder();
        var maskIndex = 0;
        var inputIndex = 0;

        while (inputIndex < input.Length && maskIndex < mask.Length)
        {
            var maskChar = mask[maskIndex];
            var inputChar = input[inputIndex];

            if (IsPlaceholder(maskChar))
            {
                if (IsValidForPlaceholder(inputChar, maskChar))
                {
                    result.Append(inputChar);
                    inputIndex++;
                    maskIndex++;
                }
                else
                {
                    // Input char does not match this placeholder type — skip it
                    inputIndex++;
                }
            }
            else
            {
                // Literal separator — auto-insert it
                result.Append(maskChar);
                maskIndex++;
                // If the user already typed this literal, consume it so it isn't doubled
                if (inputIndex < input.Length && input[inputIndex] == maskChar)
                    inputIndex++;
            }
        }

        return result.ToString();
    }

    /// <summary>Returns true when <paramref name="maskChar"/> is a placeholder, not a literal.</summary>
    private static bool IsPlaceholder(char maskChar) =>
        maskChar == '0' || maskChar == 'A' || maskChar == '*';

    /// <summary>
    /// Returns true when <paramref name="inputChar"/> satisfies the constraint of
    /// <paramref name="maskChar"/>.
    /// </summary>
    private static bool IsValidForPlaceholder(char inputChar, char maskChar) =>
        maskChar switch
        {
            '0' => char.IsDigit(inputChar),
            'A' => char.IsLetter(inputChar),
            '*' => char.IsLetterOrDigit(inputChar),
            _ => false
        };
}
