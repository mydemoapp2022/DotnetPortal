@using Microsoft.JSInterop
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

@{
    var hasError = HasError || InvalidFields.Contains($"Member{Index}_SSN");
    var showError = (_touched || Visible) && hasError;
    var displayMessage = !string.IsNullOrWhiteSpace(ErrorMessage)
        ? ErrorMessage
        : ValidationErrors.FirstOrDefault(p =>
            !string.IsNullOrWhiteSpace(MemberRole) &&
            p.Contains(MemberRole, StringComparison.OrdinalIgnoreCase) &&
            p.Contains("SSN", StringComparison.OrdinalIgnoreCase));
}

<div class="form-group master-text-field @(showError ? "master-text-field--error" : "")">
    <label for="@Id" class="form-label @(showError ? "master-label--error" : "")">
        @Label
    </label>
    <div class="ssn-input-wrapper">
        <input @ref="inputElement"
               type="text"
               autocomplete="off"
               id="@Id"
               class="@($"form-input ssn-input {CssClass}") master-input @(showError ? "master-input--error" : "")"
               placeholder="X*X-XX-XXXX"
               maxlength="11"
               inputmode="numeric"
               value="@DisplayValue"
               @onfocus="HandleFocus"
               @onblur="HandleBlur"
               @onkeyup="HandleKeyUp"
               style="@(Width > 0 ? "width:" + Width + "px;" : "")" />
    </div>
    @if (showError && !string.IsNullOrWhiteSpace(displayMessage))
    {
        <div class="master-error" aria-live="polite">
            <svg width="12" height="16" viewBox="0 0 12 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <mask id="mask0_5694_133" maskUnits="userSpaceOnUse" x="0" y="2" width="12" height="12">
                    <rect y="2" width="12" height="12" fill="#D9D9D9" />
                </mask>

                <g mask="url(#mask0_5694_133)">
                    <path d="M6 10.5C6.14167 10.5 6.26042 10.4521 6.35625 10.3563C6.45208 10.2604 6.5 10.1417 6.5 10C6.5 9.85833 6.45208 9.73958 6.35625 9.64375C6.26042 9.54792 6.14167 9.5 6 9.5C5.85833 9.5 5.73958 9.54792 5.64375 9.64375C5.54792 9.73958 5.5 9.85833 5.5 10C5.5 10.1417 5.54792 10.2604 5.64375 10.3563C5.73958 10.4521 5.85833 10.5 6 10.5ZM5.5 8.5H6.5V5.5H5.5V8.5ZM6 13C5.30833 13 4.65833 12.8687 4.05 12.6062C3.44167 12.3438 2.9125 11.9875 2.4625 11.5375C2.0125 11.0875 1.65625 10.5583 1.39375 9.95C1.13125 9.34167 1 8.69167 1 8C1 7.30833 1.13125 6.65833 1.39375 6.05C1.65625 5.44167 2.0125 4.9125 2.4625 4.4625C2.9125 4.0125 3.44167 3.65625 4.05 3.39375C4.65833 3.13125 5.30833 3 6 3C6.69167 3 7.34167 3.13125 7.95 3.39375C8.55833 3.65625 9.0875 4.0125 9.5375 4.4625C9.9875 4.9125 10.3438 5.44167 10.6062 6.05C10.8687 6.65833 11 7.30833 11 8C11 8.69167 10.8687 9.34167 10.6062 9.95C10.3438 10.5583 9.9875 11.0875 9.5375 11.5375C9.0875 11.9875 8.55833 12.3438 7.95 12.6062C7.34167 12.8687 6.69167 13 6 13ZM6 12C7.11667 12 8.0625 11.6125 8.8375 10.8375C9.6125 10.0625 10 9.11667 10 8C10 6.88333 9.6125 5.9375 8.8375 5.1625C8.0625 4.3875 7.11667 4 6 4C4.88333 4 3.9375 4.3875 3.1625 5.1625C2.3875 5.9375 2 6.88333 2 8C2 9.11667 2.3875 10.0625 3.1625 10.8375C3.9375 11.6125 4.88333 12 6 12Z"
                          fill="#C82838" />
                </g>
            </svg>

            <span>@displayMessage</span>
        </div>
    }
</div>

@code {
    private ElementReference inputElement;
    private IJSObjectReference? module;
    private DotNetObjectReference<SSNInput>? _dotNetRef;

    /// <summary>Raw digits (no dashes) backing the real SSN value.</summary>
    private string _rawDigits = string.Empty;

    /// <summary>True when JS needs to be told about a parent-driven value change.</summary>
    private bool _needsJsSync;

    [Parameter] public string Id { get; set; } = "ssn";

    [Parameter] public string Label { get; set; } = "SSN";

    [Parameter] public string Value { get; set; } = string.Empty;

    [Parameter] public EventCallback<string> ValueChanged { get; set; }

    [Parameter] public bool IsFocused { get; set; }

    [Parameter] public EventCallback<bool> IsFocusedChanged { get; set; }

    [Parameter] public string CssClass { get; set; } = string.Empty;

    [Parameter] public bool IsRequired { get; set; } = true;

    [Parameter] public int? Width { get; set; } = null;

    [Parameter] public bool HasError { get; set; } = false;

    [Parameter] public string? ErrorMessage { get; set; }

    [Parameter] public HashSet<string> InvalidFields { get; set; } = [];

    [Parameter] public List<string> ValidationErrors { get; set; } = [];

    [Parameter] public int? Index { get; set; } = null;

    [Parameter] public string? MemberRole { get; set; }

    [Parameter] public EventCallback<KeyboardEventArgs> OnKeyUp { get; set; }

    /// <summary>When true, forces error display regardless of touch state (e.g. on form submit).</summary>
    [Parameter] public bool Visible { get; set; }

    /// <summary>Callback invoked on blur — allows parent to trigger validation.</summary>
    [Parameter] public EventCallback OnBlur { get; set; }

    /// <summary>Tracks whether the user has interacted with this field.</summary>
    private bool _touched;

    /// <summary>Always returns a fully-masked star pattern based on current digit count.</summary>
    private string DisplayValue => GenerateDisplayMask(_rawDigits.Length);

    protected override void OnParametersSet()
    {
        var digitsFromValue = new string(Value.Where(char.IsDigit).ToArray());
        if (digitsFromValue != _rawDigits)
        {
            _rawDigits = digitsFromValue;
            _needsJsSync = true;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            module = await JSRuntime.InvokeAsync<IJSObjectReference>(
                "import", "./js/ssn-input.js");
            _dotNetRef = DotNetObjectReference.Create(this);
            await module.InvokeVoidAsync("attachMaskedSSNInput", inputElement, _dotNetRef, _rawDigits);
            _needsJsSync = false;
        }
        else if (_needsJsSync && module is not null)
        {
            await module.InvokeVoidAsync("setSSNDigits", inputElement, _rawDigits);
            _needsJsSync = false;
        }
    }

    /// <summary>Called from JavaScript when the user types or deletes a digit.</summary>
    [JSInvokable]
    public async Task OnSSNDigitsChanged(string digits)
    {
        _rawDigits = digits;
        var formatted = FormatSSN(digits);
        await ValueChanged.InvokeAsync(formatted);
        StateHasChanged();
    }

    private async Task HandleFocus()
    {
        await IsFocusedChanged.InvokeAsync(true);
    }

    private async Task HandleBlur()
    {
        _touched = true;
        await IsFocusedChanged.InvokeAsync(false);
        await OnBlur.InvokeAsync();
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        await OnKeyUp.InvokeAsync(e);
    }

    //Service logic
    /// <summary>
    /// Validates an SSN and returns validation result
    /// </summary>
    public static SSNValidationResult ValidateSSN(string? ssn, string fieldLabel = "")
    {
        var result = new SSNValidationResult { IsValid = true };
        var actualLabel = string.IsNullOrWhiteSpace(fieldLabel) ? string.Empty : $"{fieldLabel.Replace(" SSN", string.Empty)} ";

        if (string.IsNullOrWhiteSpace(ssn))
        {
            result.IsValid = false;
            result.ErrorMessage = $"{actualLabel}SSN is required";
            return result;
        }

        var digitsOnly = new string(ssn.Where(char.IsDigit).ToArray());

        if (digitsOnly.Length != 9)
        {
            result.IsValid = false;
            result.ErrorMessage = $"{actualLabel}SSN format must be 999-99-9999";
            return result;
        }

        if (digitsOnly.Distinct().Count() == 1)
        {
            result.IsValid = false;
            result.ErrorMessage = $"{actualLabel}SSN cannot be all the same character";
            return result;
        }

        if (digitsOnly == "123456789")
        {
            result.IsValid = false;
            result.ErrorMessage = $"{actualLabel}SSN cannot be \"123456789\"";
            return result;
        }

        return result;
    }

    /// <summary>
    /// Formats SSN with dashes
    /// </summary>
    public static string FormatSSN(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        var digitsOnly = new string(value.Where(char.IsDigit).ToArray());

        if (digitsOnly.Length > 9)
        {
            digitsOnly = digitsOnly[..9];
        }

        return digitsOnly.Length > 5
            ? $"{digitsOnly[..3]}-{digitsOnly.Substring(3, 2)}-{digitsOnly[5..]}"
            : digitsOnly.Length > 3
                ? $"{digitsOnly[..3]}-{digitsOnly[3..]}"
                : digitsOnly;
    }

    /// <summary>
    /// Masks SSN for display — always fully masked with stars, no digits revealed.
    /// </summary>
    public static string MaskSSN(string? ssn)
    {
        if (string.IsNullOrWhiteSpace(ssn))
        {
            return string.Empty;
        }

        var digitsOnly = new string(ssn.Where(char.IsDigit).ToArray());

        return GenerateDisplayMask(digitsOnly.Length);
    }

    /// <summary>
    /// Generates a star-masked display string (e.g. "***-**-****") for the given digit count.
    /// </summary>
    public static string GenerateDisplayMask(int digitCount)
    {
        if (digitCount <= 0) return string.Empty;
        if (digitCount <= 3) return new string('*', digitCount);
        if (digitCount <= 5) return $"***-{new string('*', digitCount - 3)}";
        return $"***-**-{new string('*', digitCount - 5)}";
    }

    /// <summary>
    /// Checks for duplicate SSNs in a list
    /// </summary>
    public static List<string> FindDuplicateSSNs(List<string?> ssnList, Func<int, string> getLabelForIndex)
    {
        var errors = new List<string>();
        var ssnDict = new Dictionary<string, List<int>>();

        for (var i = 0; i < ssnList.Count; i++)
        {
            var ssn = ssnList[i];
            if (string.IsNullOrWhiteSpace(ssn))
            {
                continue;
            }

            var digitsOnly = new string(ssn.Where(char.IsDigit).ToArray());

            if (digitsOnly.Length == 9)
            {
                if (!ssnDict.ContainsKey(digitsOnly))
                {
                    ssnDict[digitsOnly] = [];
                }
                ssnDict[digitsOnly].Add(i);
            }
        }

        foreach (var kvp in ssnDict.Where(x =>
        {
            return x.Value.Count > 1;
        }))
        {
            var indices = string.Join(", ", kvp.Value.Select(i =>
            {
                return getLabelForIndex(i);
            }));
            errors.Add($"Duplicate SSN found for: {indices}");
        }
        return errors;
    }

    public async ValueTask DisposeAsync()
    {
        if (module is not null)
        {
            try
            {
                await module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // Ignore - the circuit is already disconnected (e.g., page refresh)
            }
        }
        _dotNetRef?.Dispose();
    }

    /// <summary>
    /// SSN validation result
    /// </summary>
    public class SSNValidationResult
    {
        /// <summary>
        /// IsValid
        /// </summary>
        public bool IsValid { get; set; }

        /// <summary>
        /// Error message
        /// </summary>
        public string ErrorMessage { get; set; } = string.Empty;
    }
}
