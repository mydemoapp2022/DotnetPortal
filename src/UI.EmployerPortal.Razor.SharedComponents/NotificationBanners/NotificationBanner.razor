@if (Visible)
{
    @if (MessageStyle == MessageStyle.MultiLine)
    {
        @if (Messages.Count > 0)
        {
            <div class="row @GetCssClass()">
                <div class="col-md-10 text-start">

                    <ul style="list-style-type:disc;" class="nb-text-multiline">

                        @foreach (var (message, index) in Messages.Select((m, i) => (m, i)))
                        {
                            var fieldId = GetFieldId(index);
                            <li>
                                @if (!string.IsNullOrWhiteSpace(fieldId))
                                {
                                    <a href="#" class="nb-error-link" @onclick="() => FocusFieldAsync(fieldId)" @onclick:preventDefault>
                                        @message
                                    </a>
                                }
                                else
                                {
                                    @message
                                }
                            </li>
                        }
                    </ul>
                </div>
                <div class="col-md-2">
                    <div class="row justify-content-end">
                        <div class="col-auto">
                            @if (DismissButton)
                            {
                                <div @onclick="Hide">@GetDismissIcon()</div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    }

    @if (MessageStyle == MessageStyle.SingleLine)
    {
        @if (IsRightAlignedContent())
        {
            <div class="row @GetCssClass()" aria-label=@($"{Title} {GetFormattedMessage()}")>
                <div class="col-md-8 text-start">@GetNotificationIcon()<span class="nb-text"><strong class="mb-2 me-2">@GetFormattedTitle()</strong>@GetFormattedMessage()</span></div>
                <div class="col-md-4">
                    <div class="row justify-content-end">
                        <div class="col-auto">
                            @if (DueDate.HasValue)
                            {
                                @GetDueDateIcon()
                                @if (DueDateState == DueDateState.Achieved)
                                {
                                    <span class="nb-text text-end">@GetDueDateText()</span>
                                }
                                else
                                {
                                    <span class="nb-text text-end"><strong>@GetDueDateText()</strong></span>
                                }
                            }
                        </div>
                        <div class="col-auto nb-action">
                            @if (HasAction())
                            {
                                <a href="@ActionLink" class="nav-link me-2">Action</a>
                            }
                        </div>
                        <div class="col-auto">
                            @if (DismissButton)
                            {
                                <div @onclick="Hide">@GetDismissIcon()</div>
                            }
                        </div>
                    </div>
                </div>
            </div>
            <br />
        }
        else
        {
            <div class="row @GetCssClass()" aria-label=@($"{Title} {Message}")>
                <div class="col text-start">@GetNotificationIcon()<span class="nb-text"><strong class="mb-2 me-2">@GetFormattedTitle()</strong>@GetFormattedMessage()</span></div>
            </div>
            <br />
        }
    }
}
