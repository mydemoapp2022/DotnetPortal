@page "/billing-payments/bank-account-payment-ach"
@using UI.EmployerPortal.Razor.SharedComponents
@using UI.EmployerPortal.Razor.SharedComponents.NotificationBanners
@using UI.EmployerPortal.Web.Features.BillingPayments.Components
@using UI.EmployerPortal.Web.Features.BillingPayments.Models
@using UI.EmployerPortal.Web.Features.Dashboard
@using UI.EmployerPortal.Web.Features.Shared.Accounts.Models
@using UI.EmployerPortal.Web.Features.Shared.Accounts.Services
@using UI.EmployerPortal.Web.Features.Shared.QuarterlyTax.Services
@inject IJSRuntime JS
@inject NavigationManager Nav

<PageTitle>Bank Account Payment (ACH)</PageTitle>

<main id="main-content" class="section-page" aria-label="Bank Account Payment (ACH)">
    <div class="billing-payments-container">

        <div aria-live="polite" aria-atomic="true" class="visually-hidden" role="status">
            @_stepAnnouncement
        </div>
        @if (_isLoading)
        {
            <div class="ach-loading" aria-live="polite" aria-atomic="true" aria-busy="true">
                <span class="ach-loading-spinner" aria-hidden="true"></span>
                <span class="visually-hidden">Loading payment details, please wait…</span>
            </div>
        }
        else
        {
            @if (_step == AchStep.Entry)
            {
                @* ── STEP: Entry ──────────────────────────────────────────── *@
                <h1 class="billing-section-title fw-bold">Bank Account Payment (ACH)</h1>
                <!-- Validation Error Banner -->
                @if (_showValidationSummary && _validationErrors.Any())
                {
                    <div class="fix-section-width" style="max-width:684px;">
                        <NotificationBanner NotificationType="NotificationType.Alert"
                        MessageStyle="MessageStyle.MultiLine"
                        Messages="_validationErrors"
                        DismissButton="false" />
                    </div>
                }
                <p class="section-description">
                    Make sure that you have provided contact and bank information below and verify that it is correct.
                </p>
                <p class="section-description">All fields are required unless noted</p>

                <section class="billing-section" aria-labelledby="contact-info-heading" aria-label="Contact Information">
                    <AchContactInfoDisplay ContactInfo="_contactInfo" />
                </section>

                <section class="billing-section" aria-labelledby="bank-info-heading" aria-label="Bank Information">
                    <AchBankInfoDisplay BankAccounts="_bankAccounts"
                    BankAccount="_bankAccount"
                    SelectedAccountChanged="account => _bankAccount = account" />
                </section>

                <section class="billing-section" aria-labelledby="payment-info-heading" aria-label="Payment Information">
                    <AchPaymentInformation @ref="_paymentInfoRef"
                                           Draft="_paymentDraft"
                                           InitialAmount="_initialAmount"
                                           AmountChanged="OnAmountChanged"
                                           SettlementDateChanged="OnSettlementDateChanged"
                                           OnAmountInput="OnPaymentAmountInput" />
                </section>
            }
            else if (_step == AchStep.VerifyAuthorize)
            {
                @* ── STEP: Verify & Authorize ────────────────────────────── *@
                <h1 class="billing-section-title-black fw-bold">Verify &amp; Authorize EFT Payment</h1>
                @if (_showValidationSummary && _validationErrors.Any())
                {
                    <div class="fix-section-width" style="max-width:684px;">
                        <NotificationBanner NotificationType="NotificationType.Alert"
                        MessageStyle="MessageStyle.MultiLine"
                        Messages="_validationErrors"
                        DismissButton="false" />
                    </div>
                }
                <p class="section-description">
                    Please verify that the data below is correct and then select the check box that says you
                    authorize us to deduct this payment from your bank account. Then select Continue to complete
                    the payment process. A final payment confirmation page will follow.
                </p>

                <section class="billing-section" aria-label="Contact Information" aria-labelledby="contact-info-heading">
                    <AchContactInfoDisplay ContactInfo="_contactInfo" ReadOnly="true" />
                </section>

                <section class="billing-section" aria-label="Bank Information" aria-labelledby="bank-info-heading">
                    <AchBankInfoDisplay BankAccounts="_bankAccounts"
                    BankAccount="_bankAccount"
                    ReadOnly="true" />
                </section>

                <section class="billing-section" aria-label="Payment Information" aria-labelledby="payment-info-verify-heading">
                    <div class="ach-info-card">
                        <div class="ach-info-card-header">
                            <h2 id="payment-info-verify-heading" class="ach-info-card-title-display fw-bold">Payment Information</h2>
                            <div class="ach-info-card-header-actions">
                                <button type="button"
                                        class="ach-collapse-btn"
                                        aria-expanded="@_verifyAuthorizePaymentExpanded.ToString().ToLower()"
                                        aria-controls="verify-payment-info-body"
                                        aria-label="@(_verifyAuthorizePaymentExpanded ? "Collapse Payment Information" : "Expand Payment Information")"
                                        @onclick="() => _verifyAuthorizePaymentExpanded = !_verifyAuthorizePaymentExpanded">
                                    <span aria-hidden="true">@((MarkupString)(_verifyAuthorizePaymentExpanded ? "&#8963;" : "&#8964;"))</span>
                                </button>
                            </div>
                        </div>
                        <div id="verify-payment-info-body"
                             role="region"
                             aria-labelledby="payment-info-verify-heading"
                             hidden="@(!_verifyAuthorizePaymentExpanded)">
                            <hr class="ach-section-divider" aria-hidden="true" />
                            <div class="ach-bank-grid">
                                <div class="ach-info-field">
                                    <span class="ach-info-label">Description</span>
                                    <strong class="ach-info-value">Payment</strong>
                                </div>
                                <div class="ach-info-field">
                                    <span class="ach-info-label">Payment Amount</span>
                                    <strong class="ach-info-value">@_confirmedAmount.ToString("C2")</strong>
                                </div>
                            </div>
                            <div class="ach-info-field ach-info-field--full">
                                <span class="ach-info-label">Settlement Date</span>
                                <strong class="ach-info-value">@_confirmedSettlementDate.ToString("MM/dd/yyyy")</strong>
                            </div>
                        </div>
                    </div>
                </section>

                @* ── Authorization ── *@
                <div class="ach-authorization-section fix-section-width"
                role="group"
                aria-labelledby="authorization-heading">
                    <p id="authorization-heading" class="ach-authorization-text">
                        I hereby authorize the State of Wisconsin Department of Workforce Development
                        Unemployment Insurance Division to initiate an ACH debit entry to the bank account
                        shown above on this page for the payment amount on the settlement date shown on this page.
                    </p>
                    <div class="ach-authorization-checkbox">
                        <input type="checkbox"
                        id="achAuthorizeCheckbox"
                        @bind="_authorized"
                        aria-required="true"
                        aria-describedby="authorization-heading @(_authorizationError is not null ? "authorization-error" : "")"
                        aria-invalid="@(_authorizationError is not null ? "true" : "false")" />
                        <label for="achAuthorizeCheckbox">I Accept</label>
                    </div>
                    @if (_authorizationError is not null)
                    {
                        <div id="authorization-error"
                        class="ach-field-error"
                        aria-live="assertive"
                        role="alert">
                            @_authorizationError
                        </div>
                    }
                </div>
            }
            else if (_step == AchStep.Confirmation)
            {
                @* ── STEP: Confirmation ───────────────────────────────────── *@
                <h1 class="billing-section-title-black fw-bold">EFT Payment Confirmation</h1>

                <div class="fix-section-width">
                    <NotificationBanner NotificationType="NotificationType.Confirmation"
                    Message="Payment Request Submitted"
                    DismissButton="false" />
                </div>

                <p class="section-description">
                    Thank you for your Wisconsin Unemployment Insurance payment. The details of
                    your payment are shown below which includes a payment confirmation number.
                </p>

                <div class="ach-confirmation-actions">
                    <a href="#" class="ach-print-link" @onclick="HandlePrint"
                    aria-label="Print this page for your records" @onclick:preventDefault>
                        &#128438; Print page for your records
                    </a>
                    @* <button type="button"
                        class="ach-print-link btn-link"
                        aria-label="Print this page for your records"
                        @onclick="HandlePrint">
                    &#128438; Print page for your records
                </button> *@
                    <button type="button"
                    class="btn btn-danger ach-cancel-payment-btn"
                    aria-label="Cancel this payment"
                    @onclick="HandleCancelPayment">
                        CANCEL PAYMENT
                    </button>
                </div>

                <section class="billing-section" aria-label="Payment Information">
                    @RenderPaymentInfoCard("confirm-payment-card", _paymentInfoExpanded, expanded => _paymentInfoExpanded = expanded, showConfirmationDetails: true)
                </section>

                <section class="billing-section" aria-label="Bank Information" aria-labelledby="bank-info-heading">
                    <AchBankInfoDisplay BankAccounts="_bankAccounts"
                    BankAccount="_bankAccount"
                    ReadOnly="true" />
                </section>

                <section class="billing-section" aria-label="Contact Information" aria-labelledby="contact-info-heading">
                    <AchContactInfoDisplay ContactInfo="_contactInfo"
                    ReadOnly="true" />
                </section>
            }
            else if (_step == AchStep.Edit)
            {
                @* ── STEP: Edit Payment ───────────────────────────────────── *@
                <h1 class="billing-section-title fw-bold">Edit Bank Account Payment (ACH)</h1>
                @if (_showValidationSummary && _validationErrors.Any())
                {
                    <div class="fix-section-width" style="max-width:684px;">
                        <NotificationBanner NotificationType="NotificationType.Alert"
                        MessageStyle="MessageStyle.MultiLine"
                        Messages="_validationErrors"
                        DismissButton="false" />
                    </div>
                }
                <p class="section-description">Please make the changes to your payment below.</p>

                <div class="ach-edit-cancel-row fix-section-width">
                    <button type="button"
                    class="btn btn-danger ach-cancel-payment-btn"
                    aria-label="Cancel this payment"
                    @onclick="HandleCancelPayment">
                        CANCEL PAYMENT
                    </button>
                </div>

                <section class="billing-section" aria-label="Contact Information" aria-labelledby="contact-info-heading">
                    <AchContactInfoDisplay ContactInfo="_contactInfo"
                    ReadOnly="true"
                    ShowEditLink="true" />
                </section>

                <section class="billing-section" aria-label="Bank Information" aria-labelledby="bank-info-heading">
                    <AchBankInfoDisplay BankAccounts="_bankAccounts"
                    BankAccount="_bankAccount"
                    ReadOnly="true"
                    ShowEditLink="true" />
                </section>

                <section class="billing-section" aria-label="Payment Information" aria-labelledby="edit-payment-info-heading">
                    <div class="">
                        <div class="ach-info-card-header">
                            <h2 class="ach-info-card-title-payment fw-bold">Payment Information</h2>
                        </div>
                        <hr class="ach-section-divider" aria-hidden="true" />
                        <div class="ach-info-field ach-confirmation-number-field">
                            <span class="ach-info-label">Confirmation Number</span>
                            <strong class="ach-info-value">@_confirmationNumber</strong>
                        </div>
                        <AchPaymentInformation @ref="_paymentInfoRef"
                                               Draft="_paymentDraft"
                                               InitialAmount="@_confirmedAmount"
                                               InitialSettlementDate="@_confirmedSettlementDate"
                                               AmountChanged="OnAmountChanged"
                                               SettlementDateChanged="OnSettlementDateChanged"
                                               OnAmountInput="OnPaymentAmountInput" />
                    </div>
                </section>
            }
            else if (_step == AchStep.VerifyCancel)
            {
                @* ── STEP: Verify & Cancel ────────────────────────────────── *@
                <h1 id="edit-payment-info-heading" class="billing-section-title-black fw-bold">Verify &amp; Cancel EFT Payment</h1>
                <p class="section-description">
                    You have selected to cancel the following payment. If you are sure you want to
                    cancel this payment select cancel payment, otherwise go back to previous page.
                </p>

                <section class="billing-section" aria-label="Payment Information">
                    @RenderPaymentInfoCard("verify-cancel-payment-card", _verifyCancelPaymentExpanded, expanded => _verifyCancelPaymentExpanded = expanded, showConfirmationDetails: true)
                </section>

                <section class="billing-section" aria-label="Contact Information" aria-labelledby="contact-info-heading">
                    <AchContactInfoDisplay ContactInfo="_contactInfo" ReadOnly="true" />
                </section>

                <section class="billing-section" aria-label="Bank Information" aria-labelledby="bank-info-heading">
                    <AchBankInfoDisplay BankAccounts="_bankAccounts"
                    BankAccount="_bankAccount"
                    ReadOnly="true" />
                </section>
            }
            else if (_step == AchStep.CancelConfirmation)
            {
                @* ── STEP: Cancel Confirmation ───────────────────────────── *@
                <h1 class="billing-section-title-black fw-bold">Cancelled EFT Payment Confirmation</h1>
                <p class="section-description">
                    Your Wisconsin Unemployment Insurance payment has been successfully cancelled.
                    Your cancelled payment details are shown below. The confirmation number you
                    were issued when you first made this payment still applies to the cancelled payment.
                </p>

                <section class="billing-section" aria-label="Payment Information">
                    @RenderPaymentInfoCard("cancel-conf-payment-card", _cancelConfPaymentExpanded, expanded => _cancelConfPaymentExpanded = expanded, showConfirmationDetails: true)
                </section>

                <section class="billing-section" aria-label="Contact Information" aria-labelledby="contact-info-heading">
                    <AchContactInfoDisplay ContactInfo="_contactInfo" ReadOnly="true" />
                </section>

                <section class="billing-section" aria-label="Bank Information" aria-labelledby="bank-info-heading">
                    <AchBankInfoDisplay BankAccounts="_bankAccounts"
                    BankAccount="_bankAccount"
                    ReadOnly="true" />
                </section>
            }
            else if (_step == AchStep.PrintPreview)
            {
                @if (_confirmationNumber == string.Empty || _confirmedAmount == 0)
                {
                    <div class="fix-section-width">
                        <NotificationBanner NotificationType="NotificationType.Alert"
                                            Message='@($"Payment information is unavailable. Please visit <a href=\"/billing-payments/payment-history\">Payment History</a> to locate your payment.")'
                                            DismissButton="false" />
                    </div>
                }
                else
                {
                    @* ── STEP: Print Preview ── *@
                    <h1 class="billing-section-title-black fw-bold">EFT Payment Confirmation</h1>
                    <p class="section-description">print out payment confirmation.</p>

                    @* Hidden from @media print via CSS *@
                    <div class="ach-print-actions fix-section-width ach-no-print" aria-hidden="false">
                        <button type="button"
                                class="btn btn-primary ach-print-btn"
                                aria-label="Open browser print dialog to print payment confirmation"
                                @onclick="ExecutePrint">
                            &#128438; PRINT
                        </button>
                    </div>

                    @* ── Accessible print layout ── *@
                    <div class="print-section" id="print-section" role="document" aria-label="EFT Payment Confirmation">

                        <section class="billing-section ach-print-section"
                                 aria-labelledby="print-payment-heading">
                            <div class="ach-info-card ach-info-card--print">
                                <h2 id="print-payment-heading" class="ach-info-card-title-display fw-bold">
                                    Payment Information
                                </h2>
                                <hr class="ach-section-divider" aria-hidden="true" />
                                <dl class="ach-print-dl">
                                    <div class="ach-print-dl-item">
                                        <dt class="ach-info-label">Confirmation Number</dt>
                                        <dd class="ach-info-value">@_confirmationNumber</dd>
                                    </div>
                                    <div class="ach-print-dl-item">
                                        <dt class="ach-info-label">Transaction Date/Time</dt>
                                        <dd class="ach-info-value">@_transactionDateTime.ToString("MM/dd/yyyy hh:mm tt") CST</dd>
                                    </div>
                                    <div class="ach-print-dl-item">
                                        <dt class="ach-info-label">Description</dt>
                                        <dd class="ach-info-value">Payment</dd>
                                    </div>
                                    <div class="ach-print-dl-item">
                                        <dt class="ach-info-label">Payment Amount</dt>
                                        <dd class="ach-info-value">@_confirmedAmount.ToString("C2")</dd>
                                    </div>
                                    <div class="ach-print-dl-item ach-print-dl-item--full">
                                        <dt class="ach-info-label">Settlement Date</dt>
                                        <dd class="ach-info-value">@_confirmedSettlementDate.ToString("MM/dd/yyyy")</dd>
                                    </div>
                                </dl>
                            </div>
                        </section>

                        <section class="billing-section ach-print-section"
                                 aria-labelledby="print-bank-heading">
                            <div class="ach-info-card ach-info-card--print">
                                <h2 id="print-bank-heading" class="ach-info-card-title-display fw-bold">
                                    Bank Information
                                </h2>
                                <hr class="ach-section-divider" aria-hidden="true" />
                                @if (_bankAccount is not null)
                                {
                                    <dl class="ach-print-dl">
                                        <div class="ach-print-dl-item">
                                            <dt class="ach-info-label">Bank Account Nickname</dt>
                                            <dd class="ach-info-value">@_bankAccount.Nickname</dd>
                                        </div>
                                        <div class="ach-print-dl-item">
                                            <dt class="ach-info-label">Bank Name</dt>
                                            <dd class="ach-info-value">@_bankAccount.BankName</dd>
                                        </div>
                                        <div class="ach-print-dl-item">
                                            <dt class="ach-info-label">Bank Routing Number</dt>
                                            <dd class="ach-info-value">@_bankAccount.RoutingNumber</dd>
                                        </div>
                                        <div class="ach-print-dl-item">
                                            <dt class="ach-info-label">Bank Account Number</dt>
                                            <dd class="ach-info-value">@_bankAccount.MaskedAccountNumber</dd>
                                        </div>
                                        <div class="ach-print-dl-item ach-print-dl-item--full">
                                            <dt class="ach-info-label">Account Type</dt>
                                            <dd class="ach-info-value">@_bankAccount.AccountType</dd>
                                        </div>
                                    </dl>
                                }
                            </div>
                        </section>

                        <section class="billing-section ach-print-section"
                                 aria-labelledby="print-contact-heading">
                            <div class="ach-info-card ach-info-card--print">
                                <h2 id="print-contact-heading" class="ach-info-card-title-display fw-bold">
                                    Contact Information
                                </h2>
                                <hr class="ach-section-divider" aria-hidden="true" />
                                @if (_contactInfo is not null)
                                {
                                    <dl class="ach-print-dl">
                                        <div class="ach-print-dl-item">
                                            <dt class="ach-info-label">Contact Name</dt>
                                            <dd class="ach-info-value">@_contactInfo.ContactName</dd>
                                        </div>
                                        <div class="ach-print-dl-item">
                                            <dt class="ach-info-label">Phone Number</dt>
                                            <dd class="ach-info-value">@_contactInfo.PhoneNumber</dd>
                                        </div>
                                        <div class="ach-print-dl-item ach-print-dl-item--full">
                                            <dt class="ach-info-label">Email Address</dt>
                                            <dd class="ach-info-value">@_contactInfo.Email</dd>
                                        </div>
                                    </dl>
                                }
                            </div>
                        </section>

                    </div>
                }
            }
            else
            {
                @* ── STEP: Confirmation ───────────────────────────────────── *@
                <h1 class="billing-section-title fw-bold">Bank Account Payment (ACH)</h1>

                <div class="fix-section-width" style="max-width:684px;">
                    <NotificationBanner NotificationType="NotificationType.Confirmation"
                    Message="Payment Request Submitted"
                    DismissButton="false" />
                </div>

                <p class="section-description">
                    Thank you for your Wisconsin Unemployment Insurance payment. The details of
                    your payment are shown below which includes a payment confirmation number.
                </p>

                <div class="ach-confirmation-actions fix-section-width">
                    <a href="#" class="ach-print-link" @onclick="HandlePrint" @onclick:preventDefault>
                        🖨 Print page for your records
                    </a>
                    <button class="btn btn-danger ach-cancel-payment-btn" @onclick="HandleCancelPayment">
                        CANCEL PAYMENT
                    </button>
                </div>

                @* ── Payment Information collapsible ── *@
                <section class="billing-section ach-collapsible-section" aria-label="Payment Information" aria-labelledby="print-payment-heading">
                    <div class="ach-collapsible-header" @onclick="() => _paymentInfoExpanded = !_paymentInfoExpanded"
                    role="button" aria-expanded="@_paymentInfoExpanded" tabindex="0">
                        <h2 id="print-payment-heading" class="fw-bold">Payment Information</h2>
                        <span class="ach-collapsible-icon" aria-hidden="true">@(_paymentInfoExpanded ? "∧" : "∨")</span>
                    </div>
                    @if (_paymentInfoExpanded)
                    {
                        <hr class="section-divider" aria-hidden="true" />
                        <div class="ach-info-grid">
                            <div class="ach-info-field">
                                <span class="ach-info-label">Confirmation Number</span>
                                <strong class="ach-info-value">@_confirmationNumber</strong>
                            </div>
                            <div class="ach-info-field">
                                <span class="ach-info-label">Transaction Date/Time</span>
                                <strong class="ach-info-value">@_transactionDateTime.ToString("MM/dd/yyyy hh:mm tt") CST</strong>
                            </div>
                            <div class="ach-info-field">
                                <span class="ach-info-label">Description</span>
                                <strong class="ach-info-value">Payment</strong>
                            </div>
                            <div class="ach-info-field">
                                <span class="ach-info-label">Payment Amount</span>
                                <strong class="ach-info-value">@_confirmedAmount.ToString("C2")</strong>
                            </div>
                            <div class="ach-info-field">
                                <span class="ach-info-label">Settlement Date</span>
                                <strong class="ach-info-value">@_confirmedSettlementDate.ToString("MM/dd/yyyy")</strong>
                            </div>
                        </div>
                    }
                </section>

                @* ── Bank Information collapsible ── *@
                <section class="billing-section" aria-label="Bank Information" aria-labelledby="bank-info-heading">
                    <AchBankInfoDisplay BankAccounts="_bankAccounts" BankAccount="_bankAccount" ReadOnly="true" />
                </section>

                @* ── Contact Information collapsible ── *@
                <section class="billing-section" aria-label="Contact Information" aria-labelledby="contact-info-heading">
                    <AchContactInfoDisplay ContactInfo="_contactInfo" ReadOnly="true" />
                </section>
            }

            <!-- Footer Navigation -->
            <nav class="billing-footer" aria-label="Page actions">
                @* @if (_step == AchStep.Confirmation)
            {
                <div class="ach-confirmation-footer">
                    <button class="btn btn-outline-secondary ach-footer-btn"
                            @onclick='() => Nav.NavigateTo("/billing-payments/payment-history")'>
                        PAYMENT HISTORY
                    </button>
                    <button class="btn btn-link ach-edit-payment-btn" @onclick="HandleEditPayment">
                        EDIT PAYMENT
                    </button>
                </div>
            }
            else
            {
                <BillingButtonBar ShowBack="true"
                                  ShowCancel="true"
                                  ShowContinue="true"
                                  OnBack="HandleBack"
                                  OnCancel="HandleCancel"
                                  OnContinue="HandleContinue"
                                  ContinueText="@(_step == AchStep.VerifyAuthorize ? "AUTHORIZE PAYMENT" : "CONTINUE")"
                                  ButtonWidth="@(_step == AchStep.VerifyAuthorize ? "400" : "200")" />

            } *@

                @if (_step == AchStep.Confirmation)
                {
                    <div class="ach-confirmation-footer">
                        <button type="button"
                        class="btn btn-outline-secondary ach-footer-btn"
                        aria-label="Go to payment history"
                        @onclick='() => Nav.NavigateTo("/billing-payments/payment-history")'>
                            PAYMENT HISTORY
                        </button>
                        <button type="button"
                        class="btn btn-link ach-edit-payment-btn"
                        aria-label="Edit this payment"
                        @onclick="HandleEditPayment">
                            EDIT PAYMENT
                        </button>
                    </div>
                }
                else if (_step == AchStep.VerifyCancel)
                {
                    <div class="ach-verify-cancel-footer">
                        <BillingButtonBar ShowBack="true"
                        ShowCancel="false"
                        ShowContinue="true"
                        OnBack="HandleBack"
                        OnContinue="HandleConfirmCancel"
                        ContinueText="CANCEL PAYMENT"
                        ButtonWidth="200" />
                    </div>
                }
                else if (_step == AchStep.CancelConfirmation)
                {
                    <div class="ach-cancel-confirmation-footer">
                        <BillingButtonBar ShowBack="false"
                        ShowCancel="false"
                        ShowContinue="true"
                        OnContinue='() => Nav.NavigateTo("/billing-payments/payment-history")'
                        ContinueText="CONTINUE"
                        ButtonWidth="200" />
                    </div>
                }
                else if (_step == AchStep.PrintPreview)
                {
                    <BillingButtonBar ShowBack="true"
                                      ShowCancel="false"
                                      ShowContinue="true"
                                      BackText="DASHBOARD"
                                      ContinueText="PAYMENT HISTORY"
                                      OnBack='() => Nav.NavigateTo("/employer-dashboard")'
                                      OnContinue='() => Nav.NavigateTo("/billing-payments/payment-history")'
                                      ButtonWidth="200" />
                }
                else
                {
                    <BillingButtonBar ShowBack="true"
                    ShowCancel="true"
                    ShowContinue="true"
                    OnBack="HandleBack"
                    OnCancel="HandleCancel"
                    OnContinue="HandleContinue"
                    ContinueText="CONTINUE"
                    ButtonWidth="200" />
                }
            </nav>
        }
    </div>
</main>

@code {
    [Inject] private IContactInformationService ContactInformationService { get; set; } = default!;
    [Inject] private IDashboardOrchestrator DashboardOrchestrator { get; set; } = default!;
    [Inject] private IUserAccountService UserAccountService { get; set; } = default!;
    [Inject] private IBankAccountOrchestrator BankAccountOrchestrator { get; set; } = default!;

    [SupplyParameterFromQuery(Name = "amount")]
    public string? AmountParam { get; set; }

    [SupplyParameterFromQuery(Name = "source")]
    public string? Source { get; set; }

    private AchStep _step = AchStep.Entry;
    private string _stepAnnouncement = string.Empty;

    private ACHContactModel? _contactInfo;
    private SavedBankAccount? _bankAccount = default!;
    private List<SavedBankAccount> _bankAccounts = new();

    private decimal? _initialAmount;
    private decimal _confirmedAmount;
    private DateOnly _confirmedSettlementDate;

    private AchPaymentInformation? _paymentInfoRef;

    private bool _showValidationSummary;
    private List<string> _validationErrors = new();
    private EmployerAccount? _employerSK;

    // Confirmation step state
    private string _confirmationNumber = string.Empty;
    private DateTime _transactionDateTime;
    private bool _paymentInfoExpanded = true;
    //private bool _bankInfoExpanded = true;
    //private bool _contactInfoExpanded = true;

    // Verify & Authorize
    private bool _authorized;
    private string? _authorizationError;

    // Verify & Cancel collapsibles
    private bool _verifyCancelPaymentExpanded = true;

    // Cancel Confirmation collapsibles
    private bool _cancelConfPaymentExpanded = true;

    // Tracks whether VerifyAuthorize was reached from Edit (for Back navigation)
    private bool _cameFromEdit;
    private bool _isLoading = true;
    private readonly AchPaymentFormModel _paymentDraft = new();
    private bool _verifyAuthorizePaymentExpanded = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (decimal.TryParse(AmountParam, out var qsAmount) && qsAmount > 0)
                _initialAmount = qsAmount;

            _employerSK = await DashboardOrchestrator.GetSelectedEmployerAccountAsync();

            var contactTypeCodeSK = 4;
            var secureUserSK = UserAccountService.GetUserSKClaim();
            var employerSk = _employerSK?.Id ?? 0;

            var result = await ContactInformationService.GetEmployerWebContact(secureUserSK, employerSk, contactTypeCodeSK);
            if (result != null)
                _contactInfo = result;

            var result1 = await BankAccountOrchestrator.GetExistingAccountsAsync();
            if (result1 != null)
                _bankAccounts = result1.ToList();

            _bankAccount = _bankAccounts.FirstOrDefault();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void OnAmountChanged(decimal amount) => _confirmedAmount = amount;
    private void OnSettlementDateChanged(DateOnly date) => _confirmedSettlementDate = date;

    private void NavigateToStep(AchStep step, string announcement)
    {
        _step = step;
        _stepAnnouncement = announcement;
    }

    private void HandleBack()
    {
        _showValidationSummary = false;
        _validationErrors.Clear();
        _authorizationError = null;

        switch (_step)
        {
            case AchStep.Entry:
                Nav.NavigateTo("/billing-payments/payment-options?source=flow");
                break;

            case AchStep.VerifyAuthorize:
                _authorized = false;
                NavigateToStep(_cameFromEdit ? AchStep.Edit : AchStep.Entry,
                               _cameFromEdit ? "Returned to Edit Payment step" : "Returned to Entry step");
                _cameFromEdit = false;
                break;

            case AchStep.Edit:
                NavigateToStep(AchStep.Confirmation, "Returned to Payment Confirmation");
                break;

            case AchStep.VerifyCancel:
                NavigateToStep(AchStep.Confirmation, "Returned to Payment Confirmation");
                break;
        }
    }


    private void HandleCancel() => Nav.NavigateTo("/employer-dashboard");

    private async Task HandleContinue()
    {
        _showValidationSummary = false;
        _validationErrors.Clear();
        _authorizationError = null;

        switch (_step)
        {
            case AchStep.Entry:
                if (!ValidateEntry())
                {
                    await JS.InvokeVoidAsync("window.scrollTo", 0, 0);
                    return;
                }

                _confirmedAmount = _paymentInfoRef!.GetAmount();
                _confirmedSettlementDate = _paymentInfoRef.GetSettlementDate();
                _cameFromEdit = false;
                NavigateToStep(AchStep.VerifyAuthorize, "Proceeding to Verify and Authorize step");
                break;

            case AchStep.VerifyAuthorize:
                if (!ValidateAuthorization())
                {
                    await JS.InvokeVoidAsync("window.scrollTo", 0, 0);
                    return;
                }

                _confirmationNumber = GenerateConfirmationNumber();
                _transactionDateTime = DateTime.Now;
                _authorized = false;
                NavigateToStep(AchStep.Confirmation, "Payment authorized. Proceeding to Confirmation step");
                break;

            case AchStep.Edit:
                if (!ValidateEntry())
                {
                    await JS.InvokeVoidAsync("window.scrollTo", 0, 0);
                    return;
                }

                _confirmedAmount = _paymentInfoRef!.GetAmount();
                _confirmedSettlementDate = _paymentInfoRef.GetSettlementDate();
                _cameFromEdit = true;
                NavigateToStep(AchStep.VerifyAuthorize, "Proceeding to Verify and Authorize step");
                break;
        }
    }

    /// <summary>
    /// Navigates to the Verify &amp; Cancel step from the Confirmation screen.
    /// </summary>
    private void HandleCancelPayment() => NavigateToStep(AchStep.VerifyCancel, "Proceeding to verify and Cancel payment step");

    /// <summary>
    /// Called when the user confirms cancellation on the Verify &amp; Cancel step.
    /// </summary>
    private void HandleConfirmCancel()
    {
        // TODO: call payment cancellation service (UIEP-730).
        // On success, advance to CancelConfirmation; on failure, show error banner.
        _step = AchStep.CancelConfirmation;
        NavigateToStep(AchStep.CancelConfirmation, "Payment cancelled. Your are now on the Cancel Confirmation page");
    }

    /// <summary>Navigates to the print preview step.</summary>
    private void HandlePrint() => NavigateToStep(AchStep.PrintPreview, "Opening print preview");

    /// <summary>Triggers the browser print dialog from the PrintPreview step.</summary>
    private async Task ExecutePrint() => await JS.InvokeVoidAsync("printSection", "print-section");

    private void HandleEditPayment()
    {
        _showValidationSummary = false;
        _validationErrors.Clear();
        NavigateToStep(AchStep.Edit, "You are now on the Edit Pament step.");
    }

    private bool ValidateEntry()
    {
        _validationErrors.Clear();

        if (_contactInfo is null)
            _validationErrors.Add("Contact Information is required. Please add your contact details.");

        if (_bankAccount is null)
            _validationErrors.Add("Bank Information is required. Please add a bank account.");

        if (_paymentInfoRef is not null && !_paymentInfoRef.Validate())
        {
            if (_paymentInfoRef.AmountError is not null)
                _validationErrors.Add(_paymentInfoRef.AmountError);

            if (_paymentInfoRef.DateError is not null)
                _validationErrors.Add(_paymentInfoRef.DateError);
        }

        _showValidationSummary = _validationErrors.Count > 0;
        return !_showValidationSummary;
    }

    private bool ValidateAuthorization()
    {
        if (_authorized)
            return true;

        _authorizationError = "You must accept the user agreement or cancel the payment.";
        _validationErrors.Clear();
        _validationErrors.Add(_authorizationError);
        _showValidationSummary = true;
        return false;
    }

    /// <summary>
    /// Renders the shared collapsible Payment Information card used across
    /// Confirmation, Verify &amp; Cancel, and Cancel Confirmation steps.
    /// </summary>
    private RenderFragment RenderPaymentInfoCard(string cardId, bool expanded, Action<bool> setExpanded, bool showConfirmationDetails) =>
        @<div class="ach-info-card">
            <div class="ach-info-card-header">
                <h2 id="@($"{cardId}-heading")" class="ach-info-card-title-display fw-bold">Payment Information</h2>
                <button type="button"
                        class="ach-collapse-btn"
                        aria-expanded="@expanded.ToString().ToLower()"
                        aria-controls="@($"{cardId}-body")"
                        aria-label="@(expanded ? "Collapse Payment Information" : "Expand Payment Information")"
                        @onclick="() => setExpanded(!expanded)">
                    <span aria-hidden="true">@((MarkupString)(expanded ? "&#8963;" : "&#8964;"))</span>
                </button>
            </div>
            <hr class="ach-section-divider" aria-hidden="true" />
            <div id="@($"{cardId}-body")"
                 role="region"
                 aria-labelledby="@($"{cardId}-heading")"
                 hidden="@(!expanded)">
                @if (expanded)
                {
                    <div class="ach-bank-grid">
                        <div class="ach-info-field">
                            <span class="ach-info-label">Confirmation Number</span>
                            <strong class="ach-info-value">@_confirmationNumber</strong>
                        </div>
                        <div class="ach-info-field">
                            <span class="ach-info-label">Transaction Date/Time</span>
                            <strong class="ach-info-value">@_transactionDateTime.ToString("MM/dd/yyyy hh:mm tt") CST</strong>
                        </div>
                        <div class="ach-info-field">
                            <span class="ach-info-label">Description</span>
                            <strong class="ach-info-value">Payment</strong>
                        </div>
                        <div class="ach-info-field">
                            <span class="ach-info-label">Payment Amount</span>
                            <strong class="ach-info-value">@_confirmedAmount.ToString("C2")</strong>
                        </div>
                    </div>
                    <div class="ach-info-field ach-info-field--full">
                        <span class="ach-info-label">Settlement Date</span>
                        <strong class="ach-info-value">@_confirmedSettlementDate.ToString("MM/dd/yyyy")</strong>
                    </div>
                }
            </div>
        </div>;

    private static string GenerateConfirmationNumber()
    {
        // TODO: Replace with server-generated confirmation number from payment service.
        const string chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789";
        return new string(Enumerable.Range(0, 12).Select(_ => chars[Random.Shared.Next(chars.Length)]).ToArray());
    }

    private void OnPaymentAmountInput()
    {
        if (_showValidationSummary)
        {
            _showValidationSummary = false;
            _validationErrors.Clear();
            StateHasChanged();
        }
    }
}
