@page "/billing-payments/bank-account-payment-ach"
@using UI.EmployerPortal.Razor.SharedComponents
@using UI.EmployerPortal.Razor.SharedComponents.NotificationBanners
@using UI.EmployerPortal.Web.Features.BillingPayments.Components
@using UI.EmployerPortal.Web.Features.BillingPayments.Models
@using UI.EmployerPortal.Web.Features.Shared.Accounts.Models
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Bank Account Payment (ACH)</PageTitle>

<main id="main-content" aria-label="Bank Account Payment (ACH)">
    <div class="billing-payments-container">

        <!-- Validation Error Banner -->
        @if (_showValidationSummary && _validationErrors.Any())
        {
            <NotificationBanner NotificationType="NotificationType.Alert"
                                MessageStyle="MessageStyle.MultiLine"
                                Messages="_validationErrors"
                                DismissButton="false" />
            <br />
        }

        @if (_step == AchStep.Entry)
        {
            @* ── STEP: Entry ──────────────────────────────────────────── *@
            <h1 class="billing-section-title fw-bold">Bank Account Payment (ACH)</h1>
            <p class="section-description">
                Make sure that you have provided contact and bank information below and verify that it is correct.
            </p>
            <p class="section-description"><em>All fields are required unless noted</em></p>

            <section class="billing-section" aria-label="Contact Information">
                <AchContactInfoDisplay ContactInfo="_contactInfo" />
            </section>

            <section class="billing-section" aria-label="Bank Information">
                <AchBankInfoDisplay BankAccounts="_bankAccounts"
                                    BankAccount="_bankAccount"
                                    SelectedAccountChanged="account => _bankAccount = account" />
            </section>

            <section class="billing-section" aria-label="Payment Information">
                <AchPaymentInformation @ref="_paymentInfoRef"
                                       InitialAmount="_initialAmount"
                                       AmountChanged="OnAmountChanged"
                                       SettlementDateChanged="OnSettlementDateChanged" />
            </section>
        }
        else if (_step == AchStep.VerifyAuthorize)
        {
            @* ── STEP: Verify & Authorize ────────────────────────────── *@
            <h1 class="billing-section-title fw-bold">Verify &amp; Authorize Bank Account Payment (ACH)</h1>
            <p class="section-description">
                Please verify that the data below is correct and then select the check box that says you
                authorize us to deduct this payment from your bank account. Then select Continue to complete
                the payment process. A final payment confirmation page will follow.
            </p>

            <section class="billing-section" aria-label="Contact Information">
                <AchContactInfoDisplay ContactInfo="_contactInfo" ReadOnly="true" />
            </section>

            <section class="billing-section" aria-label="Bank Information">
                <AchBankInfoDisplay BankAccounts="_bankAccounts"
                                    BankAccount="_bankAccount"
                                    ReadOnly="true" />
            </section>

            <section class="billing-section" aria-label="Payment Information">
                <div class="ach-info-card">
                    <div class="ach-info-card-header">
                        <h2 class="ach-info-card-title fw-bold">Payment Information</h2>
                        <span class="ach-collapse-icon" aria-hidden="true">&#8963;</span>
                    </div>
                    <hr class="ach-section-divider" aria-hidden="true" />
                    <div class="ach-bank-grid">
                        <div class="ach-info-field">
                            <span class="ach-info-label">Description</span>
                            <strong class="ach-info-value">Payment</strong>
                        </div>
                        <div class="ach-info-field">
                            <span class="ach-info-label">Payment Amount</span>
                            <strong class="ach-info-value">@_confirmedAmount.ToString("C2")</strong>
                        </div>
                    </div>
                    <div class="ach-info-field ach-info-field--full">
                        <span class="ach-info-label">Settlement Date</span>
                        <strong class="ach-info-value">@_confirmedSettlementDate.ToString("MM/dd/yyyy")</strong>
                    </div>
                </div>
            </section>

            @* ── Authorization ── *@
            <div class="ach-authorization-section">
                <p class="ach-authorization-text">
                    I hereby authorize the State of Wisconsin Department of Workforce Development
                    Unemployment Insurance Division to initiate an ACH debit entry to the bank account
                    shown above on this page for the payment amount on the settlement date shown on this page.
                </p>
                <div class="ach-authorization-checkbox">
                    <input type="checkbox"
                           id="achAuthorizeCheckbox"
                           @bind="_authorized"
                           aria-required="true" />
                    <label for="achAuthorizeCheckbox">I Accept</label>
                </div>
                @if (_authorizationError is not null)
                {
                    <div class="ach-field-error" role="alert">@_authorizationError</div>
                }
            </div>
        }
        else if (_step == AchStep.Confirmation)
        {
            @* ── STEP: Confirmation ───────────────────────────────────── *@
            <h1 class="billing-section-title fw-bold">Bank Account Payment (ACH)</h1>

            <NotificationBanner NotificationType="NotificationType.Confirmation"
                                Message="Payment Request Submitted"
                                DismissButton="false" />

            <p class="section-description">
                Thank you for your Wisconsin Unemployment Insurance payment. The details of
                your payment are shown below which includes a payment confirmation number.
            </p>

            <div class="ach-confirmation-actions">
                <a href="#" class="ach-print-link" @onclick="HandlePrint" @onclick:preventDefault>
                    &#128438; Print page for your records
                </a>
                <button class="btn btn-danger ach-cancel-payment-btn" @onclick="HandleCancelPayment">
                    CANCEL PAYMENT
                </button>
            </div>

            <section class="billing-section" aria-label="Payment Information">
                @RenderPaymentInfoCard(_paymentInfoExpanded, expanded => _paymentInfoExpanded = expanded, showConfirmationDetails: true)
            </section>

            <section class="billing-section" aria-label="Bank Information">
                <AchBankInfoDisplay BankAccounts="_bankAccounts"
                                    BankAccount="_bankAccount"
                                    ReadOnly="true" />
            </section>

            <section class="billing-section" aria-label="Contact Information">
                <AchContactInfoDisplay ContactInfo="_contactInfo"
                                       ReadOnly="true" />
            </section>
        }
        else if (_step == AchStep.Edit)
        {
            @* ── STEP: Edit Payment ───────────────────────────────────── *@
            <h1 class="billing-section-title fw-bold">Edit Bank Account Payment (ACH)</h1>
            <p class="section-description">Please make the changes to your payment below.</p>

            <div class="ach-edit-cancel-row">
                <button class="btn btn-danger ach-cancel-payment-btn" @onclick="HandleCancelPayment">
                    CANCEL PAYMENT
                </button>
            </div>

            <section class="billing-section" aria-label="Contact Information">
                <AchContactInfoDisplay ContactInfo="_contactInfo"
                                       ReadOnly="true"
                                       ShowEditLink="true" />
            </section>

            <section class="billing-section" aria-label="Bank Information">
                <AchBankInfoDisplay BankAccounts="_bankAccounts"
                                    BankAccount="_bankAccount"
                                    ReadOnly="true"
                                    ShowEditLink="true" />
            </section>

            <section class="billing-section" aria-label="Payment Information">
                <div class="ach-info-card">
                    <div class="ach-info-card-header">
                        <h2 class="ach-info-card-title fw-bold">Payment Information</h2>
                    </div>
                    <hr class="ach-section-divider" aria-hidden="true" />
                    <div class="ach-info-field ach-confirmation-number-field">
                        <span class="ach-info-label">Confirmation Number</span>
                        <strong class="ach-info-value">@_confirmationNumber</strong>
                    </div>
                    <AchPaymentInformation @ref="_paymentInfoRef"
                                           InitialAmount="_confirmedAmount"
                                           InitialSettlementDate="_confirmedSettlementDate"
                                           AmountChanged="OnAmountChanged"
                                           SettlementDateChanged="OnSettlementDateChanged" />
                </div>
            </section>
        }
        else if (_step == AchStep.VerifyCancel)
        {
            @* ── STEP: Verify & Cancel ────────────────────────────────── *@
            <h1 class="billing-section-title fw-bold">Verify &amp; Cancel EFT Payment</h1>
            <p class="section-description">
                You have selected to cancel the following payment. If you are sure you want to
                cancel this payment select cancel payment, otherwise go back to previous page.
            </p>

            <section class="billing-section" aria-label="Payment Information">
                @RenderPaymentInfoCard(_verifyCancelPaymentExpanded, expanded => _verifyCancelPaymentExpanded = expanded, showConfirmationDetails: true)
            </section>

            <section class="billing-section" aria-label="Contact Information">
                <AchContactInfoDisplay ContactInfo="_contactInfo" ReadOnly="true" />
            </section>

            <section class="billing-section" aria-label="Bank Information">
                <AchBankInfoDisplay BankAccounts="_bankAccounts"
                                    BankAccount="_bankAccount"
                                    ReadOnly="true" />
            </section>
        }
        else if (_step == AchStep.CancelConfirmation)
        {
            @* ── STEP: Cancel Confirmation ───────────────────────────── *@
            <h1 class="billing-section-title fw-bold">Cancelled EFT Payment Confirmation</h1>
            <p class="section-description">
                Your Wisconsin Unemployment Insurance payment has been successfully cancelled.
                Your cancelled payment details are shown below. The confirmation number you
                were issued when you first made this payment still applies to the cancelled payment.
            </p>

            <section class="billing-section" aria-label="Payment Information">
                @RenderPaymentInfoCard(_cancelConfPaymentExpanded, expanded => _cancelConfPaymentExpanded = expanded, showConfirmationDetails: true)
            </section>

            <section class="billing-section" aria-label="Contact Information">
                <AchContactInfoDisplay ContactInfo="_contactInfo" ReadOnly="true" />
            </section>

            <section class="billing-section" aria-label="Bank Information">
                <AchBankInfoDisplay BankAccounts="_bankAccounts"
                                    BankAccount="_bankAccount"
                                    ReadOnly="true" />
            </section>
        }
        else if (_step == AchStep.PrintPreview)
        {
            @* ── STEP: Print Preview ──────────────────────────────────── *@
            <h1 class="billing-section-title fw-bold">EFT Payment Confirmation</h1>
            <p class="section-description">print out payment confirmation.</p>

            <div class="ach-print-actions">
                <button class="btn btn-primary ach-print-btn" @onclick="ExecutePrint">
                    &#128438; PRINT
                </button>
            </div>

            @* ── Print layout: no collapsible, plain card borders ── *@
            <section class="billing-section ach-print-section" aria-label="Payment Information">
                <div class="ach-info-card ach-info-card--print">
                    <h2 class="ach-info-card-title fw-bold">Payment Information</h2>
                    <hr class="ach-section-divider" aria-hidden="true" />
                    <div class="ach-bank-grid">
                        <div class="ach-info-field">
                            <span class="ach-info-label">Confirmation Number</span>
                            <strong class="ach-info-value">@_confirmationNumber</strong>
                        </div>
                        <div class="ach-info-field">
                            <span class="ach-info-label">Transaction Date/Time</span>
                            <strong class="ach-info-value">@_transactionDateTime.ToString("MM/dd/yyyy hh:mm tt") CST</strong>
                        </div>
                        <div class="ach-info-field">
                            <span class="ach-info-label">Description</span>
                            <strong class="ach-info-value">Payment</strong>
                        </div>
                        <div class="ach-info-field">
                            <span class="ach-info-label">Payment Amount</span>
                            <strong class="ach-info-value">@_confirmedAmount.ToString("C2")</strong>
                        </div>
                    </div>
                    <div class="ach-info-field ach-info-field--full">
                        <span class="ach-info-label">Settlement Date</span>
                        <strong class="ach-info-value">@_confirmedSettlementDate.ToString("MM/dd/yyyy")</strong>
                    </div>
                </div>
            </section>

            <section class="billing-section ach-print-section" aria-label="Bank Information">
                <AchBankInfoDisplay BankAccounts="_bankAccounts"
                                    BankAccount="_bankAccount"
                                    ReadOnly="true" />
            </section>

            <section class="billing-section ach-print-section" aria-label="Contact Information">
                <AchContactInfoDisplay ContactInfo="_contactInfo" ReadOnly="true" />
            </section>
        }

        <!-- Footer Navigation -->
        <nav class="billing-footer" aria-label="Page actions">
            @if (_step == AchStep.Confirmation)
            {
                <div class="ach-confirmation-footer">
                    <button class="btn btn-outline-secondary ach-footer-btn"
                            @onclick='() => Nav.NavigateTo("/billing-payments/payment-history")'>
                        PAYMENT HISTORY
                    </button>
                    <button class="btn btn-link ach-edit-payment-btn" @onclick="HandleEditPayment">
                        EDIT PAYMENT
                    </button>
                </div>
            }
            else if (_step == AchStep.VerifyCancel)
            {
                <div class="ach-verify-cancel-footer">
                    <BillingButtonBar ShowBack="true"
                                      ShowCancel="false"
                                      ShowContinue="true"
                                      OnBack="HandleBack"
                                      OnContinue="HandleConfirmCancel"
                                      ContinueText="CANCEL PAYMENT"
                                      ButtonWidth="200" />
                </div>
            }
            else if (_step == AchStep.CancelConfirmation)
            {
                <div class="ach-cancel-confirmation-footer">
                    <BillingButtonBar ShowBack="false"
                                      ShowCancel="false"
                                      ShowContinue="true"
                                      OnContinue='() => Nav.NavigateTo("/billing-payments/payment-history")'
                                      ContinueText="CONTINUE"
                                      ButtonWidth="200" />
                </div>
            }
            else if (_step == AchStep.PrintPreview)
            {
                @* No footer buttons on print preview — browser print dialog handles output *@
            }
            else
            {
                <BillingButtonBar ShowBack="true"
                                  ShowCancel="true"
                                  ShowContinue="true"
                                  OnBack="HandleBack"
                                  OnCancel="HandleCancel"
                                  OnContinue="HandleContinue"
                                  ContinueText="CONTINUE"
                                  ButtonWidth="200" />
            }
        </nav>

    </div>
</main>

@code {
    [SupplyParameterFromQuery(Name = "amount")]
    public string? AmountParam { get; set; }

    [SupplyParameterFromQuery(Name = "source")]
    public string? Source { get; set; }

    private AchStep _step = AchStep.Entry;

    private AchContactInfo? _contactInfo;
    private List<AchBankAccount> _bankAccounts = new();
    private AchBankAccount? _bankAccount;

    private decimal? _initialAmount;
    private decimal _confirmedAmount;
    private DateOnly _confirmedSettlementDate;

    private AchPaymentInformation? _paymentInfoRef;

    private bool _showValidationSummary;
    private List<string> _validationErrors = new();

    // Verify & Authorize
    private bool _authorized;
    private string? _authorizationError;

    // Confirmation
    private string _confirmationNumber = string.Empty;
    private DateTime _transactionDateTime;
    private bool _paymentInfoExpanded = true;

    // Verify & Cancel collapsibles
    private bool _verifyCancelPaymentExpanded = true;

    // Cancel Confirmation collapsibles
    private bool _cancelConfPaymentExpanded = true;

    // Tracks whether VerifyAuthorize was reached from Edit (for Back navigation)
    private bool _cameFromEdit;

    protected override void OnInitialized()
    {
        if (decimal.TryParse(AmountParam, out var qsAmount) && qsAmount > 0)
            _initialAmount = qsAmount;

        // TODO: Replace stub data with actual service calls from related stories.
        _contactInfo = new AchContactInfo
        {
            ContactName = "Janice Smith",
            PhoneNumber = "(302) 789-6894",
            EmailAddress = "jsmith@email.com"
        };

        _bankAccounts =
        [
            new AchBankAccount
            {
                AccountNickname = "Janice's Checking Account",
                AccountHolderName = "Janice Smith",
                BankName = "Hometown Bank",
                RoutingNumber = "015708055",
                MaskedAccountNumber = "********9177",
                AccountType = "Checking"
            },
            new AchBankAccount
            {
                AccountNickname = "Janice's Savings Account",
                AccountHolderName = "Janice Smith",
                BankName = "Hometown Bank",
                RoutingNumber = "015708055",
                MaskedAccountNumber = "********4321",
                AccountType = "Savings"
            }
        ];
        _bankAccount = _bankAccounts.FirstOrDefault();
    }

    private void OnAmountChanged(decimal amount) => _confirmedAmount = amount;
    private void OnSettlementDateChanged(DateOnly date) => _confirmedSettlementDate = date;

    private void HandleBack()
    {
        _showValidationSummary = false;
        _validationErrors.Clear();
        _authorizationError = null;

        switch (_step)
        {
            case AchStep.Entry:
                Nav.NavigateTo("/billing-payments/payment-options?source=flow");
                break;

            case AchStep.VerifyAuthorize:
                _authorized = false;
                _step = _cameFromEdit ? AchStep.Edit : AchStep.Entry;
                _cameFromEdit = false;
                break;

            case AchStep.Edit:
                _step = AchStep.Confirmation;
                break;

            case AchStep.VerifyCancel:
                _step = AchStep.Confirmation;
                break;
        }
    }

    private void HandleCancel() => Nav.NavigateTo("/employer-dashboard");

    private void HandleContinue()
    {
        _showValidationSummary = false;
        _validationErrors.Clear();
        _authorizationError = null;

        switch (_step)
        {
            case AchStep.Entry:
                if (!ValidateEntry())
                    return;

                _confirmedAmount = _paymentInfoRef!.GetAmount();
                _confirmedSettlementDate = _paymentInfoRef.GetSettlementDate();
                _cameFromEdit = false;
                _step = AchStep.VerifyAuthorize;
                break;

            case AchStep.VerifyAuthorize:
                if (!ValidateAuthorization())
                    return;

                // TODO: Replace with actual payment submission service call.
                _confirmationNumber = GenerateConfirmationNumber();
                _transactionDateTime = DateTime.Now;
                _authorized = false;
                _step = AchStep.Confirmation;
                break;

            case AchStep.Edit:
                if (!ValidateEntry())
                    return;

                _confirmedAmount = _paymentInfoRef!.GetAmount();
                _confirmedSettlementDate = _paymentInfoRef.GetSettlementDate();
                _cameFromEdit = true;
                _step = AchStep.VerifyAuthorize;
                break;
        }
    }

    /// <summary>
    /// Navigates to the Verify &amp; Cancel step from the Confirmation screen.
    /// </summary>
    private void HandleCancelPayment() => _step = AchStep.VerifyCancel;

    /// <summary>
    /// Called when the user confirms cancellation on the Verify &amp; Cancel step.
    /// </summary>
    private void HandleConfirmCancel()
    {
        // TODO: call payment cancellation service (UIEP-730).
        // On success, advance to CancelConfirmation; on failure, show error banner.
        _step = AchStep.CancelConfirmation;
    }

    /// <summary>Navigates to the print preview step.</summary>
    private void HandlePrint() => _step = AchStep.PrintPreview;

    /// <summary>Triggers the browser print dialog from the PrintPreview step.</summary>
    private async Task ExecutePrint() => await JS.InvokeVoidAsync("window.print");

    private void HandleEditPayment()
    {
        _showValidationSummary = false;
        _validationErrors.Clear();
        _step = AchStep.Edit;
    }

    private bool ValidateEntry()
    {
        _validationErrors.Clear();

        if (_contactInfo is null)
            _validationErrors.Add("Contact Information is required. Please add your contact details.");

        if (_bankAccount is null)
            _validationErrors.Add("Bank Information is required. Please add a bank account.");

        if (_paymentInfoRef is not null && !_paymentInfoRef.Validate())
        {
            if (_paymentInfoRef.AmountError is not null)
                _validationErrors.Add(_paymentInfoRef.AmountError);

            if (_paymentInfoRef.DateError is not null)
                _validationErrors.Add(_paymentInfoRef.DateError);
        }

        _showValidationSummary = _validationErrors.Count > 0;
        return !_showValidationSummary;
    }

    private bool ValidateAuthorization()
    {
        if (_authorized)
            return true;

        _authorizationError = "You must accept the authorization to proceed.";
        return false;
    }

    /// <summary>
    /// Renders the shared collapsible Payment Information card used across
    /// Confirmation, Verify &amp; Cancel, and Cancel Confirmation steps.
    /// </summary>
    private RenderFragment RenderPaymentInfoCard(bool expanded, Action<bool> setExpanded, bool showConfirmationDetails) =>
        @<div class="ach-info-card">
            <div class="ach-info-card-header"
                 role="button" tabindex="0"
                 aria-expanded="@expanded"
                 @onclick="() => setExpanded(!expanded)">
                <h2 class="ach-info-card-title fw-bold">Payment Information</h2>
                <span class="ach-collapse-icon" aria-hidden="true">@(expanded ? "&#8963;" : "&#8964;")</span>
            </div>
            @if (expanded)
            {
                <hr class="ach-section-divider" aria-hidden="true" />
                <div class="ach-bank-grid">
                    <div class="ach-info-field">
                        <span class="ach-info-label">Confirmation Number</span>
                        <strong class="ach-info-value">@_confirmationNumber</strong>
                    </div>
                    <div class="ach-info-field">
                        <span class="ach-info-label">Transaction Date/Time</span>
                        <strong class="ach-info-value">@_transactionDateTime.ToString("MM/dd/yyyy hh:mm tt") CST</strong>
                    </div>
                    <div class="ach-info-field">
                        <span class="ach-info-label">Description</span>
                        <strong class="ach-info-value">Payment</strong>
                    </div>
                    <div class="ach-info-field">
                        <span class="ach-info-label">Payment Amount</span>
                        <strong class="ach-info-value">@_confirmedAmount.ToString("C2")</strong>
                    </div>
                </div>
                <div class="ach-info-field ach-info-field--full">
                    <span class="ach-info-label">Settlement Date</span>
                    <strong class="ach-info-value">@_confirmedSettlementDate.ToString("MM/dd/yyyy")</strong>
                </div>
            }
        </div>;

    private static string GenerateConfirmationNumber()
    {
        // TODO: Replace with server-generated confirmation number from payment service.
        const string chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789";
        return new string(Enumerable.Range(0, 12).Select(_ => chars[Random.Shared.Next(chars.Length)]).ToArray());
    }
}
