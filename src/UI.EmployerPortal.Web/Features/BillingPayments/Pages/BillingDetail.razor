@page "/billing-payments/billing-detail"
@using UI.EmployerPortal.Razor.SharedComponents
@using UI.EmployerPortal.Razor.SharedComponents.Inputs
@using UI.EmployerPortal.Razor.SharedComponents.NotificationBanners
@using UI.EmployerPortal.Web.Features.BillingPayments.Models
@using UI.EmployerPortal.Web.Features.BillingPayments.Services
@using UI.EmployerPortal.Web.Features.Dashboard
@using UI.EmployerPortal.Web.Features.Shared.Accounts.Services
@inject IBillingDetailService BillingDetailService
@inject IDashboardOrchestrator DashboardOrchestrator
@inject IUserAccountService UserAccountService
@inject NavigationManager Nav

<PageTitle>Billing Details</PageTitle>

<main id="main-content" class="section-page" aria-label="Billing Details">

    @if (_showValidationSummary && _validationErrors.Any())
    {
        <NotificationBanner NotificationType="NotificationType.Alert"
                            MessageStyle="MessageStyle.MultiLine"
                            Messages="_validationErrors"
                            DismissButton="false" />
    }

    <div class="billing-detail-container">
        <h1 class="billing-detail-title fw-bold">Billing Details</h1>
        <p class="billing-detail-description">
            This page reflects all current outstanding liabilities and any existing credits.
        </p>

        @* ── Current Liability ── *@
        <section class="billing-detail-section" aria-labelledby="current-liability-heading">
            <h2 id="current-liability-heading" class="billing-detail-section-heading">Current Liability</h2>
            <hr class="billing-detail-divider" aria-hidden="true" />
            <p class="billing-detail-liability-amount">@_model.TotalOutstandingBalance.ToString("C")</p>
        </section>

        @* ── Billing Detail Table ── *@
        <div class="billing-detail-table-wrapper" role="region" aria-label="Billing detail table">
            <table class="billing-detail-table">
                <thead>
                    <tr>
                        @foreach (var col in BillColumns)
                        {
                            <th scope="col"
                                class="billing-detail-th"
                                aria-sort="@GetAriaSort(col.Key, _billSortColumn, _billSortAscending)">
                                <button type="button"
                                        class="billing-detail-sort-btn"
                                        @onclick="() => SortBills(col.Key)"
                                        @onkeydown="(e) => OnSortKeyDown(e, col.Key, isBillTable: true)">
                                    @col.Label
                                    <span class="billing-detail-sort-icon" aria-hidden="true">
                                        @GetSortIndicator(col.Key, _billSortColumn, _billSortAscending)
                                    </span>
                                </button>
                            </th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var bill in SortedBills)
                    {
                        <tr>
                            <td>@bill.Year</td>
                            <td>@bill.Quarter</td>
                            <td>@bill.BillTypeDescription</td>
                            <td>@(bill.DueDate?.ToString("MM/dd/yyyy") ?? string.Empty)</td>
                            <td>@((bill.Balance ?? 0m).ToString("C"))</td>
                            <td>@((bill.InterestDueAmount ?? 0m).ToString("C"))</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr class="billing-detail-total-row">
                        <td colspan="4" class="fw-bold">Total</td>
                        <td class="fw-bold">@(_model.Bills.Sum(b => b.Balance ?? 0m).ToString("C"))</td>
                        <td class="fw-bold">@(_model.Bills.Sum(b => b.InterestDueAmount ?? 0m).ToString("C"))</td>
                    </tr>
                </tfoot>
            </table>
        </div>

        @* ── Credits Section — only when credits exist ── *@
        @if (_model.Credits.Any())
        {
            <section class="billing-detail-section" aria-labelledby="credits-heading">
                <h2 id="credits-heading" class="billing-detail-section-heading">Credits</h2>
                <hr class="billing-detail-divider" aria-hidden="true" />
                <p class="billing-detail-credits-amount"> @_model.TotalCredits.ToString("C") </p>

                <div class="billing-detail-table-wrapper" role="region" aria-label="Credits table">
                    <table class="billing-detail-table">
                        <thead>
                            <tr>
                                @foreach (var col in CreditColumns)
                                {
                                    <th scope="col"
                                        class="billing-detail-th"
                                        aria-sort="@GetAriaSort(col.Key, _creditSortColumn, _creditSortAscending)">
                                        <button type="button"
                                                class="billing-detail-sort-btn"
                                                @onclick="() => SortCredits(col.Key)"
                                                @onkeydown="(e) => OnSortKeyDown(e, col.Key, isBillTable: false)">
                                            @col.Label
                                            <span class="billing-detail-sort-icon" aria-hidden="true">
                                                @GetSortIndicator(col.Key, _creditSortColumn, _creditSortAscending)
                                            </span>
                                        </button>
                                    </th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var credit in SortedCredits)
                            {
                                <tr>
                                    <td>@(credit.DueDate?.ToString("MM/dd/yyyy") ?? string.Empty)</td>
                                    <td>@credit.Year</td>
                                    <td>@credit.Quarter</td>
                                    <td>@((credit.Balance ?? 0m).ToString("C"))</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="billing-detail-total-row">
                                <td colspan="3" class="fw-bold">Total</td>
                                <td class="fw-bold">@(_model.Credits.Sum(c => c.Balance ?? 0m).ToString("C"))</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </section>
        }

        @* ── Payment Summary ── *@
        <section class="billing-detail-section" aria-labelledby="payment-summary-heading">
            <h2 id="payment-summary-heading" class="billing-detail-section-heading">Payment</h2>
            <hr class="billing-detail-divider" aria-hidden="true" />

            <div class="billing-detail-summary" aria-label="Payment summary values" role="region">
                <div class="billing-detail-summary-row">
                    <span class="billing-detail-summary-label">Tax Due</span>
                    <span class="billing-detail-summary-value">@_model.TaxDue.ToString("C")</span>
                </div>
                <div class="billing-detail-summary-row">
                    <span class="billing-detail-summary-label">Interest Due</span>
                    <span class="billing-detail-summary-value">@_model.InterestDue.ToString("C")</span>
                </div>
                <div class="billing-detail-summary-row">
                    <span class="billing-detail-summary-label">Penalty Due</span>
                    <span class="billing-detail-summary-value">@_model.PenaltyDue.ToString("C")</span>
                </div>
                <div class="billing-detail-summary-row">
                    <span class="billing-detail-summary-label">Collection Costs Due</span>
                    <span class="billing-detail-summary-value">@_model.CollectionCostsDue.ToString("C")</span>
                </div>
                <div class="billing-detail-summary-row">
                    <span class="billing-detail-summary-label">NSF Fees Due</span>
                    <span class="billing-detail-summary-value">@_model.NsfFeesDue.ToString("C")</span>
                </div>
                <div class="billing-detail-summary-row">
                    <span class="billing-detail-summary-label">Assessment Due</span>
                    <span class="billing-detail-summary-value">@_model.AssessmentDue.ToString("C")</span>
                </div>
                <div class="billing-detail-summary-row">
                    <span class="billing-detail-summary-label">Credit</span>
                    <span class="billing-detail-summary-value">@_model.TotalCredits.ToString("C")</span>
                </div>
                <div class="billing-detail-summary-row">
                    <span class="billing-detail-summary-label fw-bold">Total Outstanding Balance</span>
                    <span class="billing-detail-summary-value fw-bold">@_model.TotalOutstandingBalance.ToString("C")</span>
                </div>
                <div class="billing-detail-summary-row">
                    <span class="billing-detail-summary-label">Total EFT Payments</span>
                    <span class="billing-detail-summary-value">@_model.TotalEftPayments.ToString("C")</span>
                </div>

                @* Amount to Pay — editable *@
                <div class="billing-detail-summary-row billing-detail-amount-to-pay-row">
                    <label for="amount-to-pay" class="billing-detail-summary-label fw-bold">Amount to Pay</label>
                    <div class="billing-detail-amount-input">
                        <OutlinedTextField Label=""
                                           Id="amount-to-pay"
                                           Type="text"
                                           InputMode="decimal"
                                           Value="@_displayAmount"
                                           ValueChanged="OnAmountChanged"
                                           OnBlur="OnAmountBlur"
                                           Required="true"
                                           Placeholder="0.00"
                                           ForceError="@(_amountError is not null)"
                                           ForceErrorMessage="@_amountError" />
                    </div>
                </div>
            </div>
        </section>

        <nav class="billing-footer" aria-label="Page actions">
            <BillingButtonBar ShowBack="false"
                              ShowContinue="true"
                              ShowCancel="false"
                              ContinueText="SELECT PAYMENT OPTIONS" ButtonWidth="300"
                              OnContinue="HandleContinue" />
        </nav>
    </div>
</main>

@code {
    private BillingDetailViewModel _model = new();
    private bool _showValidationSummary;
    private readonly List<string> _validationErrors = new();

    private string _displayAmount = string.Empty;
    private string? _amountError;
    private decimal _amount;
    private const decimal MinAmount = 0.01m;
    private const decimal MaxAmount = 999_999_999.99m;

    private string _billSortColumn = string.Empty;
    private bool _billSortAscending = true;
    private string _creditSortColumn = string.Empty;
    private bool _creditSortAscending = true;

    private static readonly (string Key, string Label)[] BillColumns =
    [
        ("year",     "Year"),
        ("quarter",  "Quarter"),
        ("type",     "Type"),
        ("duedate",  "Date Due"),
        ("balance",  "Amount"),
        ("interest", "Interest"),
    ];

    private static readonly (string Key, string Label)[] CreditColumns =
    [
        ("duedate",  "Effective Date"),
        ("year",     "Year"),
        ("quarter",  "Quarter"),
        ("balance",  "Amount"),
    ];

    protected override async Task OnInitializedAsync()
    {
        var employer = await DashboardOrchestrator.GetSelectedEmployerAccountAsync();
        var secureUserSK = UserAccountService.GetUserSKClaim();

        var request = new UI.EmployerPortal.Generated.ServiceClients.BillDetailService.EmployerRequest
        {
            EmployerSK = employer?.Id ?? 0,
            SecureUserSK = secureUserSK
        };

        var result = await BillingDetailService.GetTaxableBillingDetail(request);
        if (result != null)
        {
            _model = result;
            _amount = _model.AmountToPay;
            _displayAmount = _model.AmountToPay.ToString("C");
        }
    }

    private IEnumerable<BillLineItem> SortedBills =>
        ApplySort(_model.Bills, _billSortColumn, _billSortAscending);

    private IEnumerable<BillLineItem> SortedCredits =>
        ApplySort(_model.Credits, _creditSortColumn, _creditSortAscending);

    private static IEnumerable<BillLineItem> ApplySort(List<BillLineItem> items, string col, bool ascending)
    {
        Func<BillLineItem, object?> key = col switch
        {
            "year" => x => (object?)x.Year,
            "quarter" => x => x.Quarter,
            "type" => x => x.BillTypeDescription,
            "duedate" => x => x.DueDate,
            "balance" => x => x.Balance,
            "interest" => x => x.InterestDueAmount,
            _ => x => x.Year
        };
        return ascending ? items.OrderBy(key) : items.OrderByDescending(key);
    }

    private void SortBills(string column)
    {
        if (_billSortColumn == column)
            _billSortAscending = !_billSortAscending;
        else
        {
            _billSortColumn = column;
            _billSortAscending = true;
        }
    }

    private void SortCredits(string column)
    {
        if (_creditSortColumn == column)
            _creditSortAscending = !_creditSortAscending;
        else
        {
            _creditSortColumn = column;
            _creditSortAscending = true;
        }
    }

    private void OnSortKeyDown(KeyboardEventArgs e, string column, bool isBillTable)
    {
        if (e.Key is "Enter" or " ")
        {
            if (isBillTable) SortBills(column);
            else SortCredits(column);
        }
    }

    private static string GetAriaSort(string col, string sortCol, bool ascending)
    {
        if (col != sortCol) return "none";
        return ascending ? "ascending" : "descending";
    }

    private static string GetSortIndicator(string col, string sortCol, bool ascending)
    {
        if (col != sortCol) return "⇅";
        return ascending ? "↑" : "↓";
    }

    private async Task OnAmountChanged(string raw)
    {
        _displayAmount = raw;
        var cleaned = raw.Replace("$", "").Replace(",", "").Trim();
        if (!string.IsNullOrWhiteSpace(cleaned)
            && decimal.TryParse(cleaned, System.Globalization.NumberStyles.Number,
                System.Globalization.CultureInfo.InvariantCulture, out var v)
            && v >= MinAmount && v <= MaxAmount)
        {
            _amountError = null;
        }
        await Task.CompletedTask;
    }

    private async Task OnAmountBlur()
    {
        var cleaned = _displayAmount.Replace("$", "").Replace(",", "").Trim();
        ValidateAmount(cleaned);
        if (_amountError is null)
            _displayAmount = _amount.ToString("C");
        await Task.CompletedTask;
    }

    private void ValidateAmount(string cleaned)
    {
        if (string.IsNullOrWhiteSpace(cleaned))
        {
            _amountError = "Payment Amount is required";
            _amount = 0;
            return;
        }

        if (!decimal.TryParse(cleaned, System.Globalization.NumberStyles.Number,
                System.Globalization.CultureInfo.InvariantCulture, out var value))
        {
            _amountError = "Payment Amount must be numeric and in a valid format";
            _amount = 0;
            return;
        }

        if (value <= 0)
        {
            _amountError = "Payment Amount must be greater than $0.00";
            _amount = 0;
            return;
        }

        if (value > MaxAmount)
        {
            _amountError = $"Payment Amount cannot exceed {MaxAmount:C}";
            _amount = 0;
            return;
        }

        _amount = value;
        _amountError = null;
    }

    private bool Validate()
    {
        _validationErrors.Clear();

        var cleaned = _displayAmount.Replace("$", "").Replace(",", "").Trim();
        ValidateAmount(cleaned);
        if (_amountError is not null)
            _validationErrors.Add(_amountError);

        _showValidationSummary = _validationErrors.Any();
        return !_showValidationSummary;
    }

    private void HandleContinue()
    {
        if (!Validate())
        {
            StateHasChanged();
            return;
        }

        Nav.NavigateTo(BuildPath($"/billing-payments/payment-options?amount={_amount}"));
    }

    private string BuildPath(string relativePath)
    {
        var baseUri = new Uri(Nav.BaseUri);
        var basePath = baseUri.AbsolutePath.TrimEnd('/');
        return new PathString(basePath + relativePath);
    }
}
