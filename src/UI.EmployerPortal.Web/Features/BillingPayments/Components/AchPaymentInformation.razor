@using UI.EmployerPortal.Web.Features.BillingPayments.Services
@using UI.EmployerPortal.Web.Features.BillingPayments.Models
@using UI.EmployerPortal.Razor.SharedComponents.Inputs
@using Microsoft.AspNetCore.Components.Forms
@inject IFederalReserveHolidayService HolidayService
@inject IJSRuntime JS
@inject NavigationManager Nav

<div class="ach-payment-info-section" role="group" aria-labelledby="payment-info-heading">
    <h2 id="payment-info-heading" class="ach-payment-info-title fw-bold">Payment Information</h2>
    <hr class="ach-section-divider" aria-hidden="true" />

    <EditForm EditContext="_editContext">
        <DataAnnotationsValidator />

        @* ── Payment Amount + Amount Due Details ── *@
        <div class="ach-payment-amount-row">
            <div class="ach-payment-amount-field">
                <OutlinedTextField Label="Payment Amount"
                                   Type="text"
                                   InputMode="decimal"
                                   Value="@_displayAmount"
                                   ValueChanged="OnAmountChanged"
                                   OnBlur="OnAmountBlur"
                                   Required="true"
                                   Placeholder="0.00"
                                   For="() => _formModel.Amount"
                                   ForceError="@(AmountError is not null)"
                                   ForceErrorMessage="@AmountError" />
            </div>
            <a href="billing-payments/billing"
               class="ach-amount-due-link"
               aria-label="View Amount Due Details">
                Amount Due Details
            </a>
        </div>
    </EditForm>

    @* ── Settlement Date ── *@
    <div class="ach-settlement-date-field">
        <OutlinedTextField Label="Settlement Date"
                           Id="@_dateInputId"
                           Value="@_formModel.SettlementDate"
                           ValueChanged="OnDateInputChanged"
                           Required="true"
                           Placeholder="MM/DD/YYYY"
                           For="() => _formModel.SettlementDate"
                           ForceError="@(DateError is not null)"
                           ForceErrorMessage="@DateError" />
    </div>

    @* ── Hint text ── *@
    <p id="settlementDateHint" class="ach-settlement-hint">
        The settlement date is the date the funds are withdrawn from your bank account.
        The next possible settlement date is the next business day and is updated each
        business day at 07:00 PM. You may select a settlement date up to 365 calendar
        days in the future. Weekends and Federal Reserve Holidays are not valid settlement
        days. The settlement date selected does not change your UI tax due date.
    </p>
</div>

@code {
    [Parameter] public decimal? InitialAmount { get; set; }
    [Parameter] public DateOnly? InitialSettlementDate { get; set; }
    [Parameter] public EventCallback<decimal> AmountChanged { get; set; }
    [Parameter] public EventCallback<DateOnly> SettlementDateChanged { get; set; }
    [Parameter] public EventCallback OnAmountInput { get; set; }
    [Parameter] public AchPaymentFormModel Draft { get; set; } = new();

    public string? AmountError { get; private set; }
    public string? DateError { get; private set; }

    private const decimal MinAmount = 0.01m;
    private const decimal MaxAmount = 999_999_999.99m;

    private AchPaymentFormModel _formModel => Draft;
    private EditContext _editContext = default!;

    private decimal _amount;
    private string _displayAmount = string.Empty;
    private DateOnly _settlementDate;
    private DateOnly _minDate;
    private DateOnly _maxDate;
    private readonly string _dateInputId = $"settlement-date-{Guid.NewGuid():N}";

    protected override async Task OnInitializedAsync()
    {
        _editContext = new EditContext(Draft);
        await HolidayService.LoadAsync();
        _editContext = new EditContext(_formModel);

        _minDate = HolidayService.FirstAvailableSettlementDate;
        _maxDate = DateOnly.FromDateTime(DateTime.Today).AddDays(365);

        if (Draft.ValidatedAmount is > 0)
        {
            _amount = Draft.ValidatedAmount.Value;
            _displayAmount = FormatAmount(_amount);
            Draft.Amount = _displayAmount;
        }
        else if (InitialAmount is > 0)
        {
            _amount = InitialAmount.Value;
            _displayAmount = FormatAmount(_amount);
            Draft.Amount = _displayAmount;
            Draft.ValidatedAmount = _amount;
        }

        var restoredDate = Draft.ValidatedSettlementDate
                        ?? (InitialSettlementDate >= _minDate
                        ? InitialSettlementDate : null);

        // Use provided initial date if valid, otherwise default to next valid business day
        _settlementDate = restoredDate.HasValue && restoredDate.Value >= _minDate
            ? restoredDate.Value
            : NextValidSettlementDate(DateOnly.FromDateTime(DateTime.Today));

        // if (InitialAmount is > 0)
        // {
        //     _amount = InitialAmount.Value;
        //     _displayAmount = FormatAmount(_amount);
        //     _formModel.Amount = _displayAmount;
        // }
        Draft.SettlementDate = _settlementDate.ToString("MM/dd/yyyy");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await HolidayService.LoadAsync();

            _minDate = HolidayService.FirstAvailableSettlementDate;
            if (_minDate == default)
            {
                _minDate = DateOnly.FromDateTime(DateTime.Today).AddDays(1);
            }
            _maxDate = DateOnly.FromDateTime(DateTime.Today).AddDays(365);

            var disabledDates = HolidayService
                .GetInvalidDatesInRange(_minDate, _maxDate)
                .Where(d => d.DayOfWeek is not DayOfWeek.Saturday and not DayOfWeek.Sunday) // holidays only; weekends handled by JS
                .Select(d => d.ToString("yyyy/MM/dd"))
                .ToArray();


            await JS.InvokeVoidAsync("initAchDatePicker",
                _dateInputId,
                _minDate.ToString("yyyy/MM/dd"),
                _maxDate.ToString("yyyy/MM/dd"),
                disabledDates,
                _settlementDate.ToString("yyyy/MM/dd"));
        }
    }

    /// <summary>Public API: called by parent page to validate before proceeding.</summary>
    public bool Validate()
    {
        var rawForValidation = string.IsNullOrWhiteSpace(_displayAmount)
                                ? string.Empty
                                : _displayAmount.Replace("$", "").Replace(",", "").Trim();
        ValidateAmount(rawForValidation);
        ValidateDate(_settlementDate);

        _formModel.Amount = string.IsNullOrWhiteSpace(_displayAmount)
                                ? null
                                : _displayAmount;
        _editContext.Validate();

        StateHasChanged();
        return AmountError is null && DateError is null;
        //return !_editContext.GetValidationMessages().Any() && DateError is null;
    }

    public decimal GetAmount() => _amount;
    public DateOnly GetSettlementDate() => _settlementDate;

    /// <summary>Callback from OutlinedTextField @onblur — reformat amount on blur.</summary>
    private async Task OnAmountBlur()
    {
        var cleaned = _displayAmount.Replace("$", "").Replace(",", "").Trim();
        ValidateAmount(cleaned);

        if (AmountError is null)
        {
            _displayAmount = FormatAmount(_amount);
            Draft.Amount = _displayAmount;
            Draft.ValidatedAmount = _amount;
            //_formModel.Amount = _displayAmount;
            await AmountChanged.InvokeAsync(_amount);
        }
        else
        {
            _amount = 0;
            Draft.ValidatedAmount = null;
            Draft.Amount = string.IsNullOrWhiteSpace(cleaned) ? null : _displayAmount;
            //_formModel.Amount = string.IsNullOrWhiteSpace(cleaned) ? null : _displayAmount;
        }
        _editContext.NotifyFieldChanged(_editContext.Field(nameof(AchPaymentFormModel.Amount)));
        StateHasChanged();
    }

    /// <summary>Callback from OutlinedTextField ValueChanged — validate on input.</summary>
    private async Task OnAmountChanged(string raw)
    {
        _displayAmount = raw;
        _formModel.Amount = string.IsNullOrWhiteSpace(raw) ? null : raw;

        var cleaned = _displayAmount.Replace("$", "").Replace(",", "").Trim();
        if (!string.IsNullOrWhiteSpace(cleaned)
            && decimal.TryParse(cleaned, System.Globalization.NumberStyles.Number,
            System.Globalization.CultureInfo.InvariantCulture, out var liveValue)
            && liveValue >= MinAmount
            && liveValue <= MaxAmount)
        {
            AmountError = null;
        }
        _editContext.NotifyFieldChanged(_editContext.Field(nameof(AchPaymentFormModel.Amount)));
        await OnAmountInput.InvokeAsync();
        //return Task.CompletedTask;
    }

    private async Task OnDateInputChanged(string raw)
    {
        var formats = new[] { "M/d/yyyy", "MM/dd/yyyy" };
        if (DateOnly.TryParseExact(raw, formats, null,
                        System.Globalization.DateTimeStyles.None, out var parsed))
        {
            if (parsed < _minDate)
            {
                Draft.SettlementDate = _settlementDate.ToString("MM/dd/yyyy");
                DateError = null;
                StateHasChanged();
                return;
            }
            Draft.SettlementDate = raw;
            Draft.ValidatedSettlementDate = parsed;
            _editContext.NotifyFieldChanged(_editContext.Field(nameof(AchPaymentFormModel.SettlementDate)));
            _settlementDate = parsed;
            ValidateDate(_settlementDate);
            if (DateError is null)
            {
                await SettlementDateChanged.InvokeAsync(_settlementDate);
            }
        }
        else
        {
            Draft.SettlementDate = string.IsNullOrWhiteSpace(raw) ? null : raw;
            Draft.ValidatedSettlementDate = null;
            _editContext.NotifyFieldChanged(_editContext.Field(nameof(AchPaymentFormModel.SettlementDate)));
            DateError = string.IsNullOrWhiteSpace(raw) ? null : "Please enter a valid settlement date (MM/DD/YYYY)";
        }
        StateHasChanged();
    }

 
    private void ValidateAmount(string raw)
    {
        var cleaned = raw.Replace("$", "").Replace(",", "").Trim();

        if (string.IsNullOrWhiteSpace(cleaned))
        {
            AmountError = "Payment Amount is required";
            _amount = 0;
            return;
        }

        if (!decimal.TryParse(cleaned, System.Globalization.NumberStyles.Number,
            System.Globalization.CultureInfo.InvariantCulture,
            out var value))
        {
            AmountError = "Payment Amount must include 2 decimal places. It must be numeric and in a valid format";
            _amount = 0;
            return;
        }

        if (value < MinAmount)
        {
            AmountError = value <= 0
                            ? $"Payment Amount must be greater than $0.00"
                            : $"Payment Amount must be at least {FormatAmount(MinAmount)}";
            _amount = 0;
            return;
        }

        if (value > MaxAmount)
        {
            AmountError = $"Payment Amount cannot exceed {FormatAmount(MaxAmount)}";
            _amount = 0;
            return;
        }

        _amount = value;
        AmountError = null;
    }

    private void ValidateDate(DateOnly date)
    {
        var today = DateOnly.FromDateTime(DateTime.Today);

        if (date < today)
        {
            DateError = "Settlement Date must not be a past date";
            return;
        }

        if (date == today)
        {
            DateError = "Settlement Date must be a future business day";
            return;
        }

        if (date > _maxDate)
        {
            DateError = "Settlement Date cannot be more than 365 days in the future";
            return;
        }

        if (date.DayOfWeek is DayOfWeek.Saturday or DayOfWeek.Sunday)
        {
            DateError = "Settlement Date cannot fall on a weekend";
            return;
        }

        if (HolidayService.IsFederalReserveHoliday(date))
        {
            DateError = "Settlement Date cannot fall on a Federal Reserve Holiday";
            return;
        }

        DateError = null;
    }

    private DateOnly NextValidSettlementDate(DateOnly from)
    {
        var candidate = from.AddDays(1);
        while (candidate.DayOfWeek is DayOfWeek.Saturday or DayOfWeek.Sunday
               || HolidayService.IsFederalReserveHoliday(candidate))
        {
            candidate = candidate.AddDays(1);
        }
        return candidate;
    }

    private static string FormatAmount(decimal value) => $"$ {value:N2}";
}
