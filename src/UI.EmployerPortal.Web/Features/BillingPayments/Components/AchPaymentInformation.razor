@using UI.EmployerPortal.Web.Features.BillingPayments.Services
@using UI.EmployerPortal.Razor.SharedComponents.Inputs
@inject IFederalReserveHolidayService HolidayService
@inject IJSRuntime JS

<div class="ach-payment-info-section">
    <h2 class="ach-payment-info-title fw-bold">Payment Information</h2>
    <hr class="ach-section-divider" aria-hidden="true" />

    @* ── Payment Amount + Amount Due Details ── *@
    <div class="ach-payment-amount-row">
        <div class="ach-payment-amount-field">
            <OutlinedTextField
                Label="Payment Amount"
                Type="text"
                InputMode="decimal"
                Value="@_displayAmount"
                ValueChanged="OnAmountChanged"
                OnBlur="OnAmountBlur"
                FormatText="Enter amount between $0.01 and $999,999,999.99"
                Required="true"
                Placeholder="$ 0.00" />
            @if (AmountError is not null)
            {
                <div class="ach-field-error" role="alert">@AmountError</div>
            }
        </div>
        <a href="#amount-due-details"
           class="ach-amount-due-link"
           aria-label="View Amount Due Details">
            Amount Due Details
        </a>
    </div>

    @* ── Settlement Date ── *@
    <div class="ach-settlement-date-field">
        <div class="master-text-field">
            <label for="@_dateInputId">Settlement Date</label>
            <input id="@_dateInputId"
                   class="master-input"
                   type="text"
                   value="@_settlementDate.ToString("yyyy-MM-dd")"
                   @onchange="OnDateChanged"
                   aria-label="Settlement Date"
                   aria-required="true"
                   placeholder="Select a date" />
            <div class="master-hint">Select a valid business day (no weekends or Federal holidays)</div>
        </div>
        @if (DateError is not null)
        {
            <div class="ach-field-error" role="alert">@DateError</div>
        }
    </div>

    @* ── Hint text ── *@
    <p id="settlementDateHint" class="ach-settlement-hint">
        The settlement date is the date the funds are withdrawn from your bank account.
        The next possible settlement date is the next business day and is updated each
        business day at 07:00 PM. You may select a settlement date up to 365 calendar
        days in the future. Weekends and Federal Reserve Holidays are not valid settlement
        days. The settlement date selected does not change your UI tax due date.
    </p>
</div>

@code {
    [Parameter] public decimal? InitialAmount { get; set; }
    [Parameter] public EventCallback<decimal> AmountChanged { get; set; }
    [Parameter] public EventCallback<DateOnly> SettlementDateChanged { get; set; }

    public string? AmountError { get; private set; }
    public string? DateError { get; private set; }

    private const decimal MinAmount = 0.01m;
    private const decimal MaxAmount = 999_999_999.99m;

    private decimal _amount;
    private string _displayAmount = string.Empty;
    private DateOnly _settlementDate;
    private DateOnly _minDate;
    private DateOnly _maxDate;
    private readonly string _dateInputId = $"settlement-date-{Guid.NewGuid():N}";

    protected override void OnInitialized()
    {
        _minDate = NextValidSettlementDate(DateOnly.FromDateTime(DateTime.Today));
        _maxDate = DateOnly.FromDateTime(DateTime.Today).AddDays(365);
        _settlementDate = _minDate;

        if (InitialAmount is > 0)
        {
            _amount = InitialAmount.Value;
            _displayAmount = FormatAmount(_amount);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var disabledDates = HolidayService
                .GetInvalidDatesInRange(_minDate, _maxDate)
                .Where(d => d.DayOfWeek is not DayOfWeek.Saturday and not DayOfWeek.Sunday) // holidays only; weekends handled by JS
                .Select(d => d.ToString("yyyy-MM-dd"))
                .ToArray();

            await JS.InvokeVoidAsync("initAchDatePicker",
                _dateInputId,
                _minDate.ToString("yyyy-MM-dd"),
                _maxDate.ToString("yyyy-MM-dd"),
                disabledDates);
        }
    }

    /// <summary>Public API: called by parent page to validate before proceeding.</summary>
    public bool Validate()
    {
        ValidateAmount(_displayAmount);
        ValidateDate(_settlementDate);
        return AmountError is null && DateError is null;
    }

    public decimal GetAmount() => _amount;
    public DateOnly GetSettlementDate() => _settlementDate;

    /// <summary>On blur: reformat the displayed amount if valid.</summary>
    private async Task OnAmountBlur()
    {
        var cleaned = _displayAmount.Replace("$", "").Replace(",", "").Trim();
        if (decimal.TryParse(cleaned, out var parsed) && parsed >= MinAmount && parsed <= MaxAmount)
        {
            _amount = parsed;
            _displayAmount = FormatAmount(_amount);
            AmountError = null;
            await AmountChanged.InvokeAsync(_amount);
        }
        else
        {
            // Trigger validation to surface/refresh the error message
            ValidateAmount(_displayAmount);
        }
        StateHasChanged();
    }

    /// <summary>On input change: update raw display value and validate — do NOT reformat here.</summary>
    private Task OnAmountChanged(string raw)
    {
        _displayAmount = raw;
        ValidateAmount(_displayAmount);
        return Task.CompletedTask;
    }

    /// <summary>On date change: validate and notify parent when valid.</summary>
    private async Task OnDateChanged(ChangeEventArgs e)
    {
        var dateStr = e.Value?.ToString() ?? string.Empty;
        if (DateOnly.TryParse(dateStr, out var parsed))
        {
            _settlementDate = parsed;
            ValidateDate(_settlementDate);
            if (DateError is null)
                await SettlementDateChanged.InvokeAsync(_settlementDate);
        }
        else
        {
            DateError = "Please enter a valid settlement date.";
        }
        StateHasChanged();
    }

    private void ValidateAmount(string raw)
    {
        var cleaned = raw.Replace("$", "").Replace(",", "").Trim();

        if (string.IsNullOrWhiteSpace(cleaned))
        {
            AmountError = "Payment Amount is required.";
            return;
        }

        if (!decimal.TryParse(cleaned, out var value))
        {
            AmountError = "Payment Amount must be a valid dollar amount.";
            return;
        }

        if (value < MinAmount)
        {
            AmountError = "Payment Amount must be greater than $0.00 (minimum is $0.01).";
            return;
        }

        if (value > MaxAmount)
        {
            AmountError = $"Payment Amount cannot exceed {FormatAmount(MaxAmount)}.";
            return;
        }

        // Only update internal state — do NOT reformat _displayAmount here (that happens on blur)
        _amount = value;
        AmountError = null;
    }

    private void ValidateDate(DateOnly date)
    {
        var today = DateOnly.FromDateTime(DateTime.Today);

        if (date < today)
        {
            DateError = "Settlement Date must not be a past date.";
            return;
        }

        if (date == today)
        {
            DateError = "Settlement Date must be a future business day.";
            return;
        }

        if (date > _maxDate)
        {
            DateError = "Settlement Date cannot be more than 365 days in the future.";
            return;
        }

        if (date.DayOfWeek is DayOfWeek.Saturday or DayOfWeek.Sunday)
        {
            DateError = "Settlement Date cannot fall on a weekend.";
            return;
        }

        if (HolidayService.IsFederalReserveHoliday(date))
        {
            DateError = "Settlement Date cannot fall on a Federal Reserve Holiday.";
            return;
        }

        DateError = null;
    }

    private DateOnly NextValidSettlementDate(DateOnly from)
    {
        var candidate = from.AddDays(1);
        while (candidate.DayOfWeek is DayOfWeek.Saturday or DayOfWeek.Sunday
               || HolidayService.IsFederalReserveHoliday(candidate))
        {
            candidate = candidate.AddDays(1);
        }
        return candidate;
    }

    private static string FormatAmount(decimal value) => $"$ {value:N2}";
}
