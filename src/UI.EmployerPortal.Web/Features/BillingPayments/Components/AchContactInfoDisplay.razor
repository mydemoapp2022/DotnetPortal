@using UI.EmployerPortal.Web.Features.BillingPayments.Models

<div class="ach-info-card">
    <div class="ach-info-card-header">
        <h2 class="ach-info-card-title fw-bold" id="contact-info-heading">Contact Information</h2>
        <div class="ach-info-card-header-actions">
            @if (_showEditLink && ContactInfo is not null)
            {
                <a href="/billing-payments/ach/contact-information/edit"
                   class="ach-edit-link"
                   aria-label="Edit Contact Information">
                    &#9998; Edit
                </a>
            }
            <button type="button"
                    class="ach-collapse-btn"
                    aria-expanded="@_expanded.ToString().ToLower()"
                    aria-controls="contact-info-body"
                    aria-label="@(_expanded ? "Collapse Contact Information" : "Expand Contact Information")"
                    @onclick="() => _expanded = !_expanded">
                <span aria-hidden="true">@((MarkupString)(_expanded ? "&#8963;" : "&#8964;"))</span>
            </button>
        </div>
    </div>

    <div id="contact-info-body"
         role="region"
         aria-labelledby="contact-info-heading"
         hidden="@(!_expanded)">
        <hr class="ach-section-divider" aria-hidden="true" />

        @if (ContactInfo is not null)
        {
            <dl class="ach-contact-grid">
                <div class="ach-info-field">
                    <dt class="ach-info-label">Contact Name</dt>
                    <dd class="ach-info-value"><strong>@ContactInfo.ContactName</strong></dd>
                </div>
                <div class="ach-info-field">
                    <dt class="ach-info-label">Phone Number</dt>
                    <dd class="ach-info-value">
                        <strong>
                            <a href="tel:@ContactInfo.PhoneNumber"
                               aria-label="Phone number @ContactInfo.PhoneNumber">
                                @ContactInfo.PhoneNumber
                            </a>
                        </strong>
                    </dd>
                </div>
            </dl>
            <dl class="ach-info-field ach-info-field--full">
                <div class="ach-info-field">
                    <dt class="ach-info-label">Email Address</dt>
                    <dd class="ach-info-value">
                        <strong>
                            <a href="mailto:@ContactInfo.EmailAddress"
                               aria-label="Email address @ContactInfo.EmailAddress">
                                @ContactInfo.EmailAddress
                            </a>
                        </strong>
                    </dd>
                </div>
            </dl>
        }
        else if (!ReadOnly)
        {
            <a href="/billing-payments/ach/contact-information/add"
               class="ach-add-link"
               aria-label="Add Contact Information">
                + Add Contact
            </a>
        }
    </div>
</div>

@code {
    [Parameter] public AchContactInfo? ContactInfo { get; set; }
    /// <summary>Hides all interactive elements (edit link, add link).</summary>
    [Parameter] public bool ReadOnly { get; set; }
    /// <summary>
    /// Explicitly controls the Edit link visibility.
    /// When not set, defaults to <c>!ReadOnly</c>.
    /// Use <c>ShowEditLink="true"</c> with <c>ReadOnly="true"</c> to show the edit link
    /// while still suppressing add/dropdown interactions (e.g. Edit Payment step).
    /// </summary>
    [Parameter] public bool? ShowEditLink { get; set; }

    private bool _showEditLink => ShowEditLink ?? !ReadOnly;
    private bool _expanded = true;
}
