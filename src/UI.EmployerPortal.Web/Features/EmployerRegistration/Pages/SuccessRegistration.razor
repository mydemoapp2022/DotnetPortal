@inject IJSRuntime JS
@page "/employer-registration/success-registration"

<button class="btn btn-primary" @onclick="DownloadPdf">Open PDF</button>

@code {
    public async Task DownloadPdf()
    {
        // var fileStream = await GetPdfStream();
        // if (fileStream != null)
        // {
        //     using var streamRef = new DotNetStreamReference(stream: fileStream);
        //     var fileName = Path.GetFileName(GetPdfFilePath());
        //     await JS.InvokeVoidAsync("downloadFileFromStream", fileName, streamRef);
        // }

        string pdfFilePath = GetPdfFilePath();
        var fileName = Path.GetFileName(GetPdfFilePath());
        await using var fileStream = File.OpenRead(pdfFilePath);
        using var streamRef = new DotNetStreamReference(stream: fileStream);
        await JS.InvokeVoidAsync("downloadFileFromStream", fileName, streamRef);
    }

    public async Task OpenPdfInNewTab()
    {
        var fileStream = await GetPdfStream();
        if (fileStream != null)
        {
            using var streamRef = new DotNetStreamReference(stream: fileStream);
            await JS.InvokeVoidAsync("openFileInNewTab", "InitialDetermination.pdf", streamRef);
        }
    }

    private async Task<FileStream?> GetPdfStream()
