        // var pdfFilePath = empRegServices.PDFFilePath;
        //string pdfFilePath = "/Download/InitialDetermination.pdf";
        string pdfFilePath = GetPdfFilePath();
        if (!string.IsNullOrEmpty(pdfFilePath) && File.Exists(pdfFilePath))
        {
            return File.OpenRead(pdfFilePath);
        }
        return null;
    }

