@using UI.EmployerPortal.Razor.SharedComponents.Inputs
@using UI.EmployerPortal.Web.Features.EmployerRegistration.Models
@using UI.EmployerPortal.Web.Features.EmployerRegistration.Components.Shared

<div class="limited-partnership-section">
    <StateSelect Id="registration-state"
                 Label="Registration State"
                 Value="@RegistrationState"
                 ValueChanged="StateChanged"
                 CssClass="@(GetFieldCssClass("RegistrationState"))" />

    <div class="general-partner-section">
        <h2 class="section-subtitle">General Partner Information</h2>

        <div class="member-card">
            <h3 class="member-title">General Partner</h3>

            <div class="member-fields">
                <ValidatedInput Id="first-name"
                                Label="First Name"
                                Value="@GeneralPartner.FirstName"
                                ValueChanged="@(v => GeneralPartner.FirstName = v)"
                                MaxLength="64"
                                Width="106"
                                HasError="@InvalidFields.Contains("GeneralPartner_FirstName")"
                                ErrorMessage="@GetErrorForField("GeneralPartner_FirstName")"
                                OnBlur="ValidateForm" />

                <ValidatedInput Id="middle-initial"
                                Label="Middle Initial"
                                Value="@GeneralPartner.MiddleInitial"
                                ValueChanged="@(v => GeneralPartner.MiddleInitial = v)"
                                MaxLength="1"
                                Width="114" />

                <ValidatedInput Id="last-name"
                                Label="Last Name"
                                Value="@GeneralPartner.LastName"
                                ValueChanged="@(v => GeneralPartner.LastName = v)"
                                MaxLength="64"
                                Width="103"
                                HasError="@InvalidFields.Contains("GeneralPartner_LastName")"
                                ErrorMessage="@GetErrorForField("GeneralPartner_LastName")"
                                OnBlur="ValidateForm" />

                <SSNInput Id="general-partner-ssn"
                          Label="SSN"
                          Value="@GeneralPartner.SSN"
                          ValueChanged="@((string value) => OnSSNChanged(value))"
                          IsFocused="@GeneralPartner.IsSSNFocused"
                          IsFocusedChanged="@((bool focused) => GeneralPartner.IsSSNFocused = focused)"
                          ShowSSN="@ShowSSN"
                          ShowSSNChanged="@((bool show) => ShowSSN = show)"
                          IsRequired="@(!ISOutsideUSA)"
                          CssClass="@(GetFieldCssClass("GeneralPartner_SSN"))" />
            </div>
        </div>
    </div>

    <!-- Limited Partnership Name -->
    <ValidatedInput Id="partnership-name"
                    Label="Limited Partnership Name"
                    Value="@LimitedPartnershipName"
                    ValueChanged="@(v => LimitedPartnershipName = v)"
                    HasError="@InvalidFields.Contains("LimitedPartnershipName")"
                    ErrorMessage="@GetErrorForField("LimitedPartnershipName")"
                    OnBlur="ValidateForm" />
</div>

@code {
    [Parameter]
    public OwnershipFormConfig Config { get; set; } = new();

    [Parameter]
    public EventCallback<LimitedPartnershipFormData> OnDataChanged { get; set; }

    [Parameter]
    public EventCallback<List<string>> OnValidationChanged { get; set; }

    [Parameter]
    public bool ISOutsideUSA { get; set; }

    [Parameter]
    public object? SavedData { get; set; }

    [Parameter]
    public Action<Func<List<string>>>? RegisterValidate { get; set; }

    private string RegistrationState { get; set; } = string.Empty;
    private string LimitedPartnershipName { get; set; } = string.Empty;
    private OwnerMember GeneralPartner { get; set; } = new() { Role = "General Partner" };
    private bool ShowSSN { get; set; }
    private List<string> ValidationErrors { get; set; } = [];
    private HashSet<string> InvalidFields { get; set; } = [];
    private bool _dataRestored;
    private bool _previousISOutsideUSA;

    protected override void OnInitialized()
    {
        _previousISOutsideUSA = ISOutsideUSA;
        GeneralPartner = new OwnerMember { Role = "General Partner" };
        RestoreFromSession();
        RegisterValidate?.Invoke(() => { ValidateForm(); return ValidationErrors; });
    }

    protected override void OnParametersSet()
    {
        if (_previousISOutsideUSA != ISOutsideUSA)
        {
            _previousISOutsideUSA = ISOutsideUSA;
        }
    }

    private void RestoreFromSession()
    {
        if (_dataRestored || SavedData == null)
            return;

        try
        {
            if (SavedData is OwnershipSessionData sessionData)
            {
                RegistrationState = sessionData.RegistrationState ?? string.Empty;
                LimitedPartnershipName = sessionData.LimitedPartnershipName ?? string.Empty;

                if (sessionData.GeneralPartner != null)
                    GeneralPartner = new OwnerMember
                    {
                        Role = "General Partner",
                        FirstName = sessionData.GeneralPartner.FirstName,
                        MiddleInitial = sessionData.GeneralPartner.MiddleInitial,
                        LastName = sessionData.GeneralPartner.LastName,
                        SSN = sessionData.GeneralPartner.SSN
                    };

                _dataRestored = true;
            }
        }
        catch
        {
            // Failed to restore, continue with defaults
        }
    }

    private void StateChanged(string value)
    {
        RegistrationState = value;
        ValidateForm();
    }

    private void OnSSNChanged(string value)
    {
        GeneralPartner.SSN = value;
        ValidateForm();
    }

    private void ValidateForm()
    {
        ValidationErrors.Clear();
        InvalidFields.Clear();

        if (string.IsNullOrWhiteSpace(RegistrationState))
        {
            ValidationErrors.Add("Registration State is required");
            InvalidFields.Add("RegistrationState");
        }

        if (string.IsNullOrWhiteSpace(LimitedPartnershipName))
        {
            ValidationErrors.Add("Limited Partnership Name is required");
            InvalidFields.Add("LimitedPartnershipName");
        }
        else if (LimitedPartnershipName.Length > 128)
        {
            ValidationErrors.Add("Limited Partnership Name must not exceed 128 characters");
            InvalidFields.Add("LimitedPartnershipName");
        }

        if (string.IsNullOrWhiteSpace(GeneralPartner.FirstName))
        {
            ValidationErrors.Add("General Partner First Name is required");
            InvalidFields.Add("GeneralPartner_FirstName");
        }
        else if (GeneralPartner.FirstName.Length > 64)
        {
            ValidationErrors.Add("General Partner First Name must not exceed 64 characters");
            InvalidFields.Add("GeneralPartner_FirstName");
        }

        if (string.IsNullOrWhiteSpace(GeneralPartner.LastName))
        {
            ValidationErrors.Add("General Partner Last Name is required");
            InvalidFields.Add("GeneralPartner_LastName");
        }
        else if (GeneralPartner.LastName.Length > 64)
        {
            ValidationErrors.Add("General Partner Last Name must not exceed 64 characters");
            InvalidFields.Add("GeneralPartner_LastName");
        }

        if (!ISOutsideUSA || !string.IsNullOrWhiteSpace(GeneralPartner.SSN))
        {
            var ssnResult = SSNInput.ValidateSSN(GeneralPartner.SSN, "General Partner");
            if (ssnResult != null && !ssnResult.IsValid)
            {
                ValidationErrors.Add(ssnResult.ErrorMessage);
                InvalidFields.Add("GeneralPartner_SSN");
            }
        }

        _ = OnValidationChanged.InvokeAsync(ValidationErrors);
        NotifyDataChanged();
        StateHasChanged();
    }

    private void NotifyDataChanged()
    {
        _ = OnDataChanged.InvokeAsync(new LimitedPartnershipFormData
        {
            RegistrationState = RegistrationState,
            LimitedPartnershipName = LimitedPartnershipName,
            GeneralPartner = GeneralPartner
        });
    }

    private string GetFieldCssClass(string fieldName) =>
        InvalidFields.Contains(fieldName) ? "input-validation-error" : string.Empty;

    private string? GetErrorForField(string fieldKey)
    {
        if (!InvalidFields.Contains(fieldKey))
            return null;

        var sep = fieldKey.LastIndexOf('_');
        if (sep < 0)
        {
            // No underscore — simple key like "LimitedPartnershipName" or "RegistrationState"
            var lbl = System.Text.RegularExpressions.Regex.Replace(
                fieldKey, "(?<=[a-z])(?=[A-Z])", " ");
            return ValidationErrors.FirstOrDefault(e =>
                e.Contains(lbl, StringComparison.OrdinalIgnoreCase));
        }

        // "GeneralPartner_FirstName" → prefix="General Partner", field="First Name"
        var prefixLabel = System.Text.RegularExpressions.Regex.Replace(
            fieldKey[..sep], "(?<=[a-z])(?=[A-Z])", " ");
        var fieldLabel = System.Text.RegularExpressions.Regex.Replace(
            fieldKey[(sep + 1)..], "(?<=[a-z])(?=[A-Z])", " ");

        return ValidationErrors.FirstOrDefault(e =>
            e.Contains(prefixLabel, StringComparison.OrdinalIgnoreCase) &&
            e.Contains(fieldLabel, StringComparison.OrdinalIgnoreCase))
            ?? ValidationErrors.FirstOrDefault(e =>
                e.Contains(fieldLabel, StringComparison.OrdinalIgnoreCase));
    }
}
