@using UI.EmployerPortal.Razor.SharedComponents.Inputs
@using UI.EmployerPortal.Razor.SharedComponents.Validation
@using UI.EmployerPortal.Web.Features.EmployerRegistration.Models
@using UI.EmployerPortal.Web.Features.EmployerRegistration.Components.Shared

<div class="llc-documentation-section">
    <p>
        You indicated that your limited liability company (LLC) has elected to be taxed as a
        corporation for federal tax purposes.
    </p>
    <p>
        Wisconsin Unemployment Insurance law treats a multimember LLC as a partnership and a single
        member LLC as a sole proprietorship unless the company files proof with the department that
        the Internal Revenue Service has agreed to treat the LLC as a corporation. Business owners
        of entities taxed as partnerships or sole proprietorships are excluded from Wisconsin
        Unemployment Insurance tax law and their earnings should not be reported to this department.
    </p>
    <p>
        You must submit a copy of the Notice of Acceptance issued to you by the IRS. We can also
        accept the following as proof that the IRS has agreed to treat the LLC as a Corporation:
    </p>
    <ul class="info-list">
        <li>
            IRS Documentation of accepted e-file of the 1120 or 1120S corporate tax return
            for any year along with a copy of the first page of the filed tax return.
        </li>
        <li>
            First page of 1120 or 1120S corporate tax returns from the two most recent filing years.
        </li>
    </ul>

    <!-- Has Documentation Question -->
    <div id="has-documentation-group"
         class="@(_showAllErrors && _invalidFields.Contains("HasRequiredDocumentation") ? "master-text-field--error" : "")">
        <p><strong>Do you have the required documentation available to upload?</strong></p>

        @if (_showAllErrors && _invalidFields.Contains("HasRequiredDocumentation"))
        {
            <ValidationError ErrorMessage="Please select an option." />
        }

        <RadioGroup TValue="bool?"
                    Value="Data.HasRequiredDocumentation"
                    ValueChanged="OnHasDocumentationChanged"
                    ValueExpression="() => Data.HasRequiredDocumentation"
                    Options="@YesNoRadioOptions" />
    </div>

    <!-- File Upload when Yes -->
    @if (Data.HasRequiredDocumentation == true)
    {
        <div class="file-upload-section">
            <h3 class="section-subtitle">File upload</h3>

            <div class="file-upload-area">
                <div class="file-upload-header">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M19.35 10.04C18.67 6.59 15.64 4 12 4C9.11 4 6.6 5.64 5.35 8.04C2.34 8.36 0 10.91 0 14C0 17.31 2.69 20 6 20H19C21.76 20 24 17.76 24 15C24 12.36 21.95 10.22 19.35 10.04ZM19 18H6C3.79 18 2 16.21 2 14C2 11.95 3.53 10.24 5.56 10.03L6.63 9.92L7.13 8.97C8.08 7.14 9.94 6 12 6C14.62 6 16.88 7.86 17.39 10.43L17.69 11.93L19.22 12.04C20.78 12.14 22 13.45 22 15C22 16.65 20.65 18 19 18ZM8 13H10.55V16H13.45V13H16L12 9L8 13Z"
                              fill="#1565C0" />
                    </svg>
                    <div>
                        <strong>Notice of Acceptance</strong>
                        <p class="file-upload-filetypes">Acceptable file types: PDF, JPG, HEIC or PNG.</p>
                    </div>
                </div>

                <div class="file-upload-dropzone @(_isDragOver ? "file-upload-dropzone--drag-over" : "")"
                     @ondragover:preventDefault
                     @ondragover="@(() => _isDragOver = true)"
                     @ondragleave="@(() => _isDragOver = false)"
                     @ondrop:preventDefault>
                    <InputFile OnChange="OnFileSelected"
                               accept=".pdf,.jpg,.jpeg,.heic,.png"
                               id="llc-doc-upload"
                               class="file-upload-input" />

                    @if (string.IsNullOrWhiteSpace(Data.UploadedFileName))
                    {
                        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M19.35 10.04C18.67 6.59 15.64 4 12 4C9.11 4 6.6 5.64 5.35 8.04C2.34 8.36 0 10.91 0 14C0 17.31 2.69 20 6 20H19C21.76 20 24 17.76 24 15C24 12.36 21.95 10.22 19.35 10.04ZM19 18H6C3.79 18 2 16.21 2 14C2 11.95 3.53 10.24 5.56 10.03L6.63 9.92L7.13 8.97C8.08 7.14 9.94 6 12 6C14.62 6 16.88 7.86 17.39 10.43L17.69 11.93L19.22 12.04C20.78 12.14 22 13.45 22 15C22 16.65 20.65 18 19 18ZM8 13H10.55V16H13.45V13H16L12 9L8 13Z"
                                  fill="#90CAF9" />
                        </svg>
                        <p>Drag and drop your file, or <label for="llc-doc-upload" class="file-upload-browse">browse</label></p>
                        <p class="file-upload-sizelimit">The file must be 20 MB or smaller.</p>
                    }
                    else
                    {
                        <p class="file-upload-filename">@Data.UploadedFileName</p>
                        <button type="button" class="file-upload-remove" @onclick="RemoveFile">Remove</button>
                    }
                </div>

                @if (_showAllErrors && _invalidFields.Contains("FileUpload"))
                {
                    <ValidationError ErrorMessage="@_fieldErrors.GetValueOrDefault("FileUpload")" />
                }
            </div>
        </div>
    }

    <!-- Reason & Acknowledgment when No -->
    @if (Data.HasRequiredDocumentation == false)
    {
        <div class="no-documentation-section">
            <div id="no-doc-reason-group"
                 class="@(_showAllErrors && _invalidFields.Contains("NoDocReason") ? "master-text-field--error" : "")">
                <p><strong>What is the reason the documentation cannot be submitted at this time?</strong></p>

                @if (_showAllErrors && _invalidFields.Contains("NoDocReason"))
                {
                    <ValidationError ErrorMessage="Please select a reason." />
                }

                <RadioGroup TValue="NoDocReason ?"
                            Value="Data.NoDocumentationReason"
                            ValueChanged="OnNoDocReasonChanged"
                            ValueExpression="() => Data.NoDocumentationReason"
                            Options="@NoDocReasonOptions" />
            </div>

            @if (Data.NoDocumentationReason == NoDocReason.HaventApplied)
            {
                <ValidatedDateInput Id="planned-submission-date"
                                    Label="When do you plan to submit your application to the IRS?"
                                    Value="@(Data.PlannedSubmissionDate?.ToDateTime(TimeOnly.MinValue))"
                                    ValueChanged="OnPlannedSubmissionDateChanged"
                                    Min="@DateTime.Today.AddDays(1)"
                                    HasError="@(_showAllErrors && _invalidFields.Contains("PlannedSubmissionDate"))"
                                    ErrorMessage="@_fieldErrors.GetValueOrDefault("PlannedSubmissionDate")"
                                    Visible="@_showAllErrors"
                                    Width="220" />
            }

            @if (Data.NoDocumentationReason == NoDocReason.AppliedNoDecision)
            {
                <ValidatedDateInput Id="application-submitted-date"
                                    Label="What date was the application submitted to the IRS?"
                                    Value="@(Data.ApplicationSubmittedDate?.ToDateTime(TimeOnly.MinValue))"
                                    ValueChanged="OnApplicationSubmittedDateChanged"
                                    Max="@DateTime.Today"
                                    HasError="@(_showAllErrors && _invalidFields.Contains("ApplicationSubmittedDate"))"
                                    ErrorMessage="@_fieldErrors.GetValueOrDefault("ApplicationSubmittedDate")"
                                    Visible="@_showAllErrors"
                                    Width="220" />
            }

            <!-- Acknowledgment checkbox -->
            <div id="acknowledge-group">
                <CheckboxInput Id="acknowledge-submit-doc"
                               Label="I acknowledge that I will submit the required documentation."
                               Value="@Data.AcknowledgeSubmitDocumentation"
                               ValueChanged="OnAcknowledgeChanged"
                               HasError="@(_showAllErrors && _invalidFields.Contains("Acknowledge"))"
                               ErrorMessage="You must acknowledge that you will submit the required documentation"
                               Visible="@_showAllErrors" />
            </div>

            <!-- Info paragraph -->
            <p class="llc-info-notice">
                Upon receipt of this information, we will treat your LLC as a corporation for
                Wisconsin UI tax purposes as of the effective date stated in your IRS notice.
                Each member of the LLC will be treated as a corporate officer for tax and benefit
                purposes. Any compensation received by members performing services for the LLC
                will be considered wages subject to UI tax.
            </p>
        </div>
    }
</div>

@code {
    private const long MaxFileSizeBytes = 20 * 1024 * 1024; // 20 MB
    private static readonly string[] AllowedExtensions = [".pdf", ".jpg", ".jpeg", ".heic", ".png"];

    [Parameter]
    public LlcDocumentationData Data { get; set; } = new();

    [Parameter]
    public EventCallback<LlcDocumentationData> OnDataChanged { get; set; }

    [Parameter]
    public Action<Func<List<ValidationItem>>>? RegisterValidate { get; set; }

    private static readonly IReadOnlyList<RadioOption<bool?>> YesNoRadioOptions =
    [
        new RadioOption<bool?> { Value = true, Label = "Yes" },
        new RadioOption<bool?> { Value = false, Label = "No" }
    ];

    private static readonly IReadOnlyList<RadioOption<NoDocReason?>> NoDocReasonOptions =
    [
        new RadioOption<NoDocReason?> { Value = NoDocReason.HaventApplied, Label = "We haven't applied yet." },
        new RadioOption<NoDocReason?> { Value = NoDocReason.AppliedNoDecision, Label = "We applied and have not received a decision from the IRS." }
    ];

    private HashSet<string> _invalidFields = [];
    private Dictionary<string, string> _fieldErrors = [];
    private List<ValidationItem> _validationItems = [];
    private bool _showAllErrors;
    private bool _isDragOver;

    protected override void OnInitialized()
    {
        RegisterValidate?.Invoke(() =>
        {
            _showAllErrors = true;
            return ValidateSection();
        });
    }

    private void OnHasDocumentationChanged(bool? value)
    {
        Data.HasRequiredDocumentation = value;

        if (value == true)
        {
            // Switching to Yes — clear "No" branch fields
            Data.NoDocumentationReason = null;
            Data.PlannedSubmissionDate = null;
            Data.ApplicationSubmittedDate = null;
            Data.AcknowledgeSubmitDocumentation = false;
        }
        else if (value == false)
        {
            // Switching to No — clear "Yes" branch fields
            Data.UploadedFileName = null;
            Data.UploadedFileContent = null;
            Data.UploadedFileContentType = null;
        }

        NotifyDataChanged();
    }

    // --- "Yes" branch handlers ---

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        _invalidFields.Remove("FileUpload");
        _fieldErrors.Remove("FileUpload");

        var file = e.File;
        var extension = Path.GetExtension(file.Name).ToLowerInvariant();

        if (!AllowedExtensions.Contains(extension))
        {
            _invalidFields.Add("FileUpload");
            _fieldErrors["FileUpload"] = "Invalid file type. Acceptable types: PDF, JPG, HEIC or PNG.";
            StateHasChanged();
            return;
        }

        if (file.Size > MaxFileSizeBytes)
        {
            _invalidFields.Add("FileUpload");
            _fieldErrors["FileUpload"] = "The file must be 20 MB or smaller.";
            StateHasChanged();
            return;
        }

        using var stream = file.OpenReadStream(MaxFileSizeBytes);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);

        Data.UploadedFileName = file.Name;
        Data.UploadedFileContent = ms.ToArray();
        Data.UploadedFileContentType = file.ContentType;

        NotifyDataChanged();
    }

    private void RemoveFile()
    {
        Data.UploadedFileName = null;
        Data.UploadedFileContent = null;
        Data.UploadedFileContentType = null;
        NotifyDataChanged();
    }

    // --- "No" branch handlers ---

    private void OnNoDocReasonChanged(NoDocReason? value)
    {
        Data.NoDocumentationReason = value;

        // Clear the conditional date for the deselected reason
        if (value != NoDocReason.HaventApplied)
            Data.PlannedSubmissionDate = null;

        if (value != NoDocReason.AppliedNoDecision)
            Data.ApplicationSubmittedDate = null;

        NotifyDataChanged();
    }

    private void OnPlannedSubmissionDateChanged(DateTime? value)
    {
        Data.PlannedSubmissionDate = value.HasValue ? DateOnly.FromDateTime(value.Value) : null;
        NotifyDataChanged();
    }

    private void OnApplicationSubmittedDateChanged(DateTime? value)
    {
        Data.ApplicationSubmittedDate = value.HasValue ? DateOnly.FromDateTime(value.Value) : null;
        NotifyDataChanged();
    }

    private void OnAcknowledgeChanged(bool value)
    {
        Data.AcknowledgeSubmitDocumentation = value;
        NotifyDataChanged();
    }

    /// <summary>
    /// Validates the section and returns validation items for the parent to aggregate.
    /// </summary>
    public List<ValidationItem> ValidateSection()
    {
        _invalidFields.Clear();
        _fieldErrors.Clear();
        _validationItems.Clear();

        // Must answer Yes or No
        if (Data.HasRequiredDocumentation is null)
        {
            _invalidFields.Add("HasRequiredDocumentation");
            _validationItems.Add(new ValidationItem(
                "Please select whether you have the required documentation.",
                "has-documentation-group"));
        }

        // "Yes" branch: file required
        if (Data.HasRequiredDocumentation == true && string.IsNullOrWhiteSpace(Data.UploadedFileName))
        {
            _invalidFields.Add("FileUpload");
            _fieldErrors["FileUpload"] = "Please upload the Notice of Acceptance document.";
            _validationItems.Add(new ValidationItem(
                "Please upload the Notice of Acceptance document.",
                "llc-doc-upload"));
        }

        // "No" branch validations
        if (Data.HasRequiredDocumentation == false)
        {
            // A reason must be selected
            if (Data.NoDocumentationReason is null)
            {
                _invalidFields.Add("NoDocReason");
                _validationItems.Add(new ValidationItem(
                    "Please select a reason the documentation cannot be submitted.",
                    "no-doc-reason-group"));
            }

            // "We haven't applied yet" — planned submission date required and must be future
            if (Data.NoDocumentationReason == NoDocReason.HaventApplied)
            {
                if (!Data.PlannedSubmissionDate.HasValue)
                {
                    _invalidFields.Add("PlannedSubmissionDate");
                    _fieldErrors["PlannedSubmissionDate"] = "Please enter the date you plan to submit your application.";
                    _validationItems.Add(new ValidationItem(
                        "Please enter the date you plan to submit your application to the IRS.",
                        "planned-submission-date"));
                }
                else if (Data.PlannedSubmissionDate.Value <= DateOnly.FromDateTime(DateTime.Today))
                {
                    _invalidFields.Add("PlannedSubmissionDate");
                    _fieldErrors["PlannedSubmissionDate"] = "Planned submission date must be a future date.";
                    _validationItems.Add(new ValidationItem(
                        "Planned submission date must be a future date.",
                        "planned-submission-date"));
                }
            }

            // "We applied and have not received a decision" — application date required and must be past
            if (Data.NoDocumentationReason == NoDocReason.AppliedNoDecision)
            {
                if (!Data.ApplicationSubmittedDate.HasValue)
                {
                    _invalidFields.Add("ApplicationSubmittedDate");
                    _fieldErrors["ApplicationSubmittedDate"] = "Please enter the date the application was submitted.";
                    _validationItems.Add(new ValidationItem(
                        "Please enter the date the application was submitted to the IRS.",
                        "application-submitted-date"));
                }
                else if (Data.ApplicationSubmittedDate.Value >= DateOnly.FromDateTime(DateTime.Today))
                {
                    _invalidFields.Add("ApplicationSubmittedDate");
                    _fieldErrors["ApplicationSubmittedDate"] = "Application submitted date must be a past date.";
                    _validationItems.Add(new ValidationItem(
                        "Application submitted date must be a past date.",
                        "application-submitted-date"));
                }
            }

            // Acknowledgment required
            if (!Data.AcknowledgeSubmitDocumentation)
            {
                _invalidFields.Add("Acknowledge");
                _validationItems.Add(new ValidationItem(
                    "You must acknowledge that you will submit the required documentation.",
                    "acknowledge-group"));
            }
        }

        StateHasChanged();
        return _validationItems;
    }

    private void NotifyDataChanged()
    {
        if (_showAllErrors)
            ValidateSection();

        _ = OnDataChanged.InvokeAsync(Data);
    }
}
