@using UI.EmployerPortal.Web.Features.EmployerRegistration.Models
@using UI.EmployerPortal.Web.Features.EmployerRegistration.Components.Shared
@using UI.EmployerPortal.Razor.SharedComponents.Inputs

<div class="sole-proprietorship-section">
    <div class="owner-info-section">
        <h2 class="section-subtitle">Owner Information</h2>

        <div class="member-card">
            <h3 class="member-title">Member 1</h3>

            <div class="member-fields">
                <ValidatedInput Id="first-name"
                                Label="First Name"
                                Value="@Owner.FirstName"
                                ValueChanged="@(v => Owner.FirstName = v)"
                                MaxLength="64"
                                Width="106"
                                HasError="@InvalidFields.Contains("FirstName")"
                                ErrorMessage="@GetErrorForField("FirstName")"
                                OnBlur="ValidateForm" />

                <ValidatedInput Id="middle-initial"
                                Label="Middle Initial"
                                Value="@Owner.MiddleInitial"
                                ValueChanged="@(v => Owner.MiddleInitial = v)"
                                MaxLength="1"
                                Width="114" />

                <ValidatedInput Id="last-name"
                                Label="Last Name"
                                Value="@Owner.LastName"
                                ValueChanged="@(v => Owner.LastName = v)"
                                MaxLength="64"
                                Width="103"
                                HasError="@InvalidFields.Contains("LastName")"
                                ErrorMessage="@GetErrorForField("LastName")"
                                OnBlur="ValidateForm" />

                <SSNInput Id="owner-ssn"
                          Label="SSN"
                          Value="@Owner.SSN"
                          ValueChanged="@((string value) => OnSSNChanged(value))"
                          IsFocused="@Owner.IsSSNFocused"
                          IsFocusedChanged="@((bool focused) => Owner.IsSSNFocused = focused)"
                          ShowSSN="@ShowSSN"
                          ShowSSNChanged="@((bool show) => ShowSSN = show)"
                          IsRequired="@(!ISOutsideUSA)"
                          CssClass="@(GetFieldCssClass("SSN"))" />

                <ValidatedInput Id="ownership-percentage"
                                Label="Ownership (%)"
                                InputType="number"
                                Value="@(Owner.OwnershipPercentage?.ToString("0.##"))"
                                ValueChanged="@(v => Owner.OwnershipPercentage = decimal.TryParse(v, out var n) ? n : null)"
                                Min="0"
                                Max="100"
                                Step="0.01"
                                Width="130"
                                HasError="@InvalidFields.Contains("OwnershipPercentage")"
                                ErrorMessage="@GetErrorForField("OwnershipPercentage")"
                                OnBlur="ValidateForm" />
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public OwnershipFormConfig Config { get; set; } = new();

    [Parameter]
    public EventCallback<OwnerMember> OnDataChanged { get; set; }

    [Parameter]
    public EventCallback<List<string>> OnValidationChanged { get; set; }

    [Parameter]
    public bool ISOutsideUSA { get; set; }

    [Parameter]
    public object? SavedData { get; set; }

    [Parameter]
    public Action<Func<List<string>>>? RegisterValidate { get; set; }

    private OwnerMember Owner { get; set; } = new();
    private bool ShowSSN { get; set; }
    private List<string> ValidationErrors { get; set; } = [];
    private HashSet<string> InvalidFields { get; set; } = [];
    private bool _dataRestored;
    private bool _previousISOutsideUSA;

    protected override void OnInitialized()
    {
        _previousISOutsideUSA = ISOutsideUSA;
        Owner = new OwnerMember();
        RestoreFromSession();
        RegisterValidate?.Invoke(() => { ValidateForm(); return ValidationErrors; });
    }

    protected override void OnParametersSet()
    {
        if (_previousISOutsideUSA != ISOutsideUSA)
        {
            _previousISOutsideUSA = ISOutsideUSA;
        }
    }

    private void RestoreFromSession()
    {
        if (_dataRestored || SavedData == null)
            return;

        try
        {
            if (SavedData is OwnershipSessionData sessionData && sessionData.Owner != null)
            {
                Owner = new OwnerMember
                {
                    Role = sessionData.Owner.Role,
                    FirstName = sessionData.Owner.FirstName,
                    MiddleInitial = sessionData.Owner.MiddleInitial,
                    LastName = sessionData.Owner.LastName,
                    SSN = sessionData.Owner.SSN,
                    OwnershipPercentage = sessionData.Owner.OwnershipPercentage
                };
                _dataRestored = true;
            }
        }
        catch
        {
            // Failed to restore, continue with defaults
        }
    }

    private void OnSSNChanged(string value)
    {
        Owner.SSN = value;
        ValidateForm();
    }

    private void ValidateForm()
    {
        ValidationErrors.Clear();
        InvalidFields.Clear();

        if (string.IsNullOrWhiteSpace(Owner.FirstName))
        {
            ValidationErrors.Add("First Name is required");
            InvalidFields.Add("FirstName");
        }
        else if (Owner.FirstName.Length > 64)
        {
            ValidationErrors.Add("First Name must not exceed 64 characters");
            InvalidFields.Add("FirstName");
        }

        if (string.IsNullOrWhiteSpace(Owner.LastName))
        {
            ValidationErrors.Add("Last Name is required");
            InvalidFields.Add("LastName");
        }
        else if (Owner.LastName.Length > 64)
        {
            ValidationErrors.Add("Last Name must not exceed 64 characters");
            InvalidFields.Add("LastName");
        }

        if (!ISOutsideUSA || !string.IsNullOrWhiteSpace(Owner.SSN))
        {
            var ssnResult = SSNInput.ValidateSSN(Owner.SSN, "SSN");
            if (ssnResult != null && !ssnResult.IsValid)
            {
                ValidationErrors.Add(ssnResult.ErrorMessage);
                InvalidFields.Add("SSN");
            }
        }

        if (Owner.OwnershipPercentage.HasValue)
        {
            if (Owner.OwnershipPercentage < 0 || Owner.OwnershipPercentage > 100)
            {
                ValidationErrors.Add("Ownership Percentage must be between 0 and 100.00");
                InvalidFields.Add("OwnershipPercentage");
            }
            else if (decimal.Round(Owner.OwnershipPercentage.Value, 2) != Owner.OwnershipPercentage.Value)
            {
                ValidationErrors.Add("Ownership Percentage must not exceed 2 decimal places");
                InvalidFields.Add("OwnershipPercentage");
            }
        }

        _ = OnValidationChanged.InvokeAsync(ValidationErrors);
        NotifyDataChanged();
        StateHasChanged();
    }

    private void NotifyDataChanged() => _ = OnDataChanged.InvokeAsync(Owner);

    private string GetFieldCssClass(string fieldName) =>
        InvalidFields.Contains(fieldName) ? "input-validation-error" : string.Empty;

    private string? GetErrorForField(string fieldKey)
    {
        if (!InvalidFields.Contains(fieldKey))
            return null;

        var sep = fieldKey.LastIndexOf('_');
        if (sep < 0)
        {
            var lbl = System.Text.RegularExpressions.Regex.Replace(fieldKey, "(?<=[a-z])(?=[A-Z])", " ");
            return ValidationErrors.FirstOrDefault(e => e.Contains(lbl, StringComparison.OrdinalIgnoreCase));
        }

        var prefixLabel = System.Text.RegularExpressions.Regex.Replace(fieldKey[..sep], "(?<=[a-z])(?=[A-Z])", " ");
        var fieldLabel = System.Text.RegularExpressions.Regex.Replace(fieldKey[(sep + 1)..], "(?<=[a-z])(?=[A-Z])", " ");

        return ValidationErrors.FirstOrDefault(e =>
            e.Contains(prefixLabel, StringComparison.OrdinalIgnoreCase) &&
            e.Contains(fieldLabel, StringComparison.OrdinalIgnoreCase))
            ?? ValidationErrors.FirstOrDefault(e => e.Contains(fieldLabel, StringComparison.OrdinalIgnoreCase));
    }
}
