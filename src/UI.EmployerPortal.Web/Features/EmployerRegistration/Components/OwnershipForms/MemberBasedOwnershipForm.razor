@using System.ComponentModel.DataAnnotations
@using UI.EmployerPortal.Razor.SharedComponents.Inputs
@using UI.EmployerPortal.Web.Features.EmployerRegistration.Models
@using UI.EmployerPortal.Web.Features.EmployerRegistration.Components.Shared
<div class="member-based-section">
    @if (Config.RequiresState)
    {
        <StateSelect Id="incorporation-state"
                     Label="@Config.StateLabel"
                     Value="@RegistrationState"
                     ValueChanged="StateChanged"
                     InvalidFields="InvalidFields"
                     ValidationErrors="ValidationErrors"
                     ErrorMessage="Registration State is required."
                     CssClass="@(_showAllErrors ? GetFieldCssClass("RegistrationState") : string.Empty)" />
    }

    <!-- Owner Information Section -->
    <div class="owner-info-section">
        <h2 class="section-subtitle">Owner Information</h2>

        @for (int i = 0; i < Members.Count; i++)
        {
            var index = i;
            var member = Members[index];

            <div class="member-card">
                <h3 class="member-title">@member.Role</h3>

                <div class="member-fields">
                    <!-- First Name -->
                    <ValidatedInput Id="@($"first-name-{index}")"
                                    Label="First Name"
                                    Value="@member.FirstName"
                                    ValueChanged="@(v => member.FirstName = v)"
                                    MaxLength="64"
                                    Width="106"
                                    HasError="@FieldErrors.ContainsKey($"Member{index}_FirstName")"
                                    ErrorMessage="First name is required"
                                    Visible="_showAllErrors"
                                    OnBlur="@(() => ValidateForm())" />

                    <!-- Middle Initial -->
                    <ValidatedInput Id="@($"middle-initial-{index}")"
                                    Label="Middle Initial"
                                    Value="@member.MiddleInitial"
                                    ValueChanged="@(v => member.MiddleInitial = v)"
                                    MaxLength="1"
                                    Width="114" />

                    <!-- Last Name -->
                    <ValidatedInput Id="@($"last-name-{index}")"
                                    Label="Last Name"
                                    Value="@member.LastName"
                                    ValueChanged="@(v => member.LastName = v)"
                                    MaxLength="64"
                                    Width="103"
                                    HasError="@FieldErrors.ContainsKey($"Member{index}_LastName")"
                                    ErrorMessage="Last name is required."
                                    Visible="_showAllErrors"
                                    OnBlur="@(() => ValidateForm())" />

                    <SSNInput Id="@($"ssn-{index}")"
                              Label="SSN"
                              Value="@member.SSN"
                              ValueChanged="@((string value) => OnSSNChanged(index, value))"
                              IsFocused="@member.IsSSNFocused"
                              IsFocusedChanged="@((bool focused) => OnSSNFocusChanged(index, focused))"
                              ShowSSN="false"
                              ShowSSNChanged="@((bool show) => ShowSSN = show)"
                              IsRequired="true"
                              Width="175"
                              HasError="@FieldErrors.ContainsKey($"Member{index}_SSN")"
                              ErrorMessage="@FieldErrors.GetValueOrDefault($"Member{index}_SSN")"
                              Visible="_showAllErrors"
                              OnBlur="@(() => ValidateForm())" />

                    <!-- Ownership Percentage -->
                    <ValidatedInput Id="@($"ownership-percentage-{index}")"
                                    Label="Ownership (%)"
                                    InputType="number"
                                    Value="@(member.OwnershipPercentage?.ToString("0.##"))"
                                    ValueChanged="@(v => member.OwnershipPercentage = decimal.TryParse(v, out var n) ? n : null)"
                                    Min="0"
                                    Max="100"
                                    Step="0.01"
                                    Width="130"
                                    MaxLength="3"
                                    HasError="@FieldErrors.ContainsKey($"Member{index}_OwnershipPercentage")"
                                    ErrorMessage="@FieldErrors.GetValueOrDefault($"Member{index}_OwnershipPercentage")"
                                    Visible="_showAllErrors"
                                    OnBlur="@(() => ValidateForm())" />
                </div>
            </div>
        }

        <br />

        <div id="more-than-five-group" class="@(_showAllErrors && InvalidFields.Contains("MoreThanFive") ? "master-text-field--error" : "")">
            <p class="">More than five?</p>

            @if (_showAllErrors && InvalidFields.Contains("MoreThanFive"))
            {
                <div class="master-error" aria-live="polite">
                    <svg width="12" height="16" viewBox="0 0 12 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <mask id="mask0_5694_133" maskUnits="userSpaceOnUse" x="0" y="2" width="12" height="12">
                            <rect y="2" width="12" height="12" fill="#D9D9D9" />
                        </mask>
                        <g mask="url(#mask0_5694_133)">
                            <path d="M6 10.5C6.14167 10.5 6.26042 10.4521 6.35625 10.3563C6.45208 10.2604 6.5 10.1417 6.5 10C6.5 9.85833 6.45208 9.73958 6.35625 9.64375C6.26042 9.54792 6.14167 9.5 6 9.5C5.85833 9.5 5.73958 9.54792 5.64375 9.64375C5.54792 9.73958 5.5 9.85833 5.5 10C5.5 10.1417 5.54792 10.2604 5.64375 10.3563C5.73958 10.4521 5.85833 10.5 6 10.5ZM5.5 8.5H6.5V5.5H5.5V8.5ZM6 13C5.30833 13 4.65833 12.8687 4.05 12.6062C3.44167 12.3438 2.9125 11.9875 2.4625 11.5375C2.0125 11.0875 1.65625 10.5583 1.39375 9.95C1.13125 9.34167 1 8.69167 1 8C1 7.30833 1.13125 6.65833 1.39375 6.05C1.65625 5.44167 2.0125 4.9125 2.4625 4.4625C2.9125 4.0125 3.44167 3.65625 4.05 3.39375C4.65833 3.13125 5.30833 3 6 3C6.69167 3 7.34167 3.13125 7.95 3.39375C8.55833 3.65625 9.0875 4.0125 9.5375 4.4625C9.9875 4.9125 10.3438 5.44167 10.6062 6.05C10.8687 6.65833 11 7.30833 11 8C11 8.69167 10.8687 9.34167 10.6062 9.95C10.3438 10.5583 9.9875 11.0875 9.5375 11.5375C9.0875 11.9875 8.55833 12.3438 7.95 12.6062C7.34167 12.8687 6.69167 13 6 13ZM6 12C7.11667 12 8.0625 11.6125 8.8375 10.8375C9.6125 10.0625 10 9.11667 10 8C10 6.88333 9.6125 5.9375 8.8375 5.1625C8.0625 4.3875 7.11667 4 6 4C4.88333 4 3.9375 4.3875 3.1625 5.1625C2.3875 5.9375 2 6.88333 2 8C2 9.11667 2.3875 10.0625 3.1625 10.8375C3.9375 11.6125 4.88333 12 6 12Z"
                                  fill="#C82838" />
                        </g>
                    </svg>
                    <span>Please select an option.</span>
                </div>
            }

            <RadioGroup TValue="bool?"
                        Value="MoreThanFive"
                        ValueChanged="OnMoreThanFiveChanged"
                        ValueExpression="() => MoreThanFive"
                        Options="@YesNoRadioOptions" />
            
        </div>
    </div>
</div>

@code {
    [Parameter]
    public OwnershipFormConfig Config { get; set; } = new();

    [Parameter]
    public EventCallback<MemberBasedFormData> OnDataChanged { get; set; }

    [Parameter]
    public EventCallback<List<ValidationItem>> OnValidationChanged { get; set; }

    [Parameter]
    public object? SavedData { get; set; }

    [Parameter]
    public OwnershipSessionData ContinueData { get; set; } = default!;

    [Parameter]
    public Action<Func<List<string>>>? RegisterValidate { get; set; }

    private static readonly IReadOnlyList<RadioOption<bool?>> YesNoRadioOptions = new[]
    {
        new RadioOption<bool?> { Value = true, Label = "Yes" },
        new RadioOption<bool?> { Value = false, Label = "No" }
    };

    private string RegistrationState { get; set; } = string.Empty;
    private bool ShowSSN { get; set; }
    private bool? MoreThanFive { get; set; } = false;
    private List<OwnerMember> Members { get; set; } = [];
    private List<string> ValidationErrors { get; set; } = [];
    private List<ValidationItem> _validationItems { get; set; } = [];
    private HashSet<string> InvalidFields { get; set; } = [];
    private Dictionary<string, string> FieldErrors { get; set; } = [];
    private bool _showAllErrors;
    private bool _dataRestored;

    protected override void OnInitialized()
    {
        InitializeMembers();
        RestoreFromContinueData();
        RegisterValidate?.Invoke(() => { _showAllErrors = true; ValidateForm(); return ValidationErrors; });
    }

    private void RestoreFromContinueData()
    {
        if (_dataRestored || ContinueData == null)
        {
            return;
        }

        try
        {
            RegistrationState = ContinueData.RegistrationState ?? string.Empty;
            MoreThanFive = ContinueData.MoreThanFive;

            if (ContinueData.Members is { Count: > 0 })
            {
                Members.Clear();
                foreach (var savedMember in ContinueData.Members)
                {
                    Members.Add(new OwnerMember
                    {
                        Role = savedMember.Role,
                        FirstName = savedMember.FirstName,
                        MiddleInitial = savedMember.MiddleInitial,
                        LastName = savedMember.LastName,
                        SSN = savedMember.SSN,
                        OwnershipPercentage = savedMember.OwnershipPercentage
                    });
                }
            }

            _dataRestored = true;
        }
        catch
        {
            // Failed to restore, continue with defaults
        }
    }

    private void InitializeMembers()
    {
        if (Members.Count > 0)
        {
            return;
        }

        Members.Clear();
        for (var i = 1; i <= Config.MaxEntries; i++)
        {
            Members.Add(new OwnerMember { Role = $"{Config.MemberLabel} {i}" });
        }
    }

    private void StateChanged(string value)
    {
        RegistrationState = value;
        ValidateForm();
    }

    private void OnSSNChanged(int index, string value)
    {
        if (index >= 0 && index < Members.Count)
        {
            Members[index].SSN = value;
            ValidateForm();
        }
    }

    private void OnSSNFocusChanged(int index, bool focused)
    {
        if (index >= 0 && index < Members.Count)
        {
            Members[index].IsSSNFocused = focused;
        }
    }

    private void OnMoreThanFiveChanged(bool? value)
    {
        MoreThanFive = value;
        ValidateForm();
    }

    private static string GetElementId(string fieldKey)
    {
        var match = System.Text.RegularExpressions.Regex.Match(
            fieldKey, @"^Member(\d+)_(\w+)$"
        );

        if (match.Success)
        {
            var idx = match.Groups[1].Value;
            return match.Groups[2].Value switch
            {
                "FirstName" => $"first-name-{idx}",
                "LastName" => $"last-name-{idx}",
                "SSN" => $"ssn-{idx}",
                "OwnershipPercentage" => $"ownership-percentage-{idx}",
                _ => string.Empty
            };
        }

        return fieldKey switch
        {
            "RegistrationState" => "registration-state",
            "MoreThanFive" => "more-than-five-group",
            _ => string.Empty
        };
    }

    private void AddFieldError(string fieldKey, string message)
    {
        var elementId = GetElementId(fieldKey);
        _validationItems.Add(new ValidationItem(message, elementId));
        ValidationErrors.Add(message);
        InvalidFields.Add(fieldKey);
        FieldErrors[fieldKey] = message;
    }

    private void ValidateForm()
    {
        ValidationErrors.Clear();
        _validationItems.Clear();
        InvalidFields.Clear();
        FieldErrors.Clear();

        if (Config.RequiresState && string.IsNullOrWhiteSpace(RegistrationState))
        {
            AddFieldError("RegistrationState", $"{Config.StateLabel} is required");
        }

        for (var i = 0; i < Members.Count; i++)
        {
            var member = Members[i];

            var hasAnyValue = !string.IsNullOrWhiteSpace(member.FirstName) ||
                             !string.IsNullOrWhiteSpace(member.MiddleInitial) ||
                             !string.IsNullOrWhiteSpace(member.LastName) ||
                             !string.IsNullOrWhiteSpace(member.SSN) ||
                             member.OwnershipPercentage.HasValue;

            if (i == 0 || hasAnyValue)
            {
                if (string.IsNullOrWhiteSpace(member.FirstName))
                {
                    AddFieldError($"Member{i}_FirstName", $"{member.Role} First Name is required");
                }
                else if (member.FirstName.Length > 64)
                {
                    AddFieldError($"Member{i}_FirstName", $"{member.Role} First Name must not exceed 64 characters");
                }

                if (string.IsNullOrWhiteSpace(member.LastName))
                {
                    AddFieldError($"Member{i}_LastName", $"{member.Role} Last Name is required");
                }
                else if (member.LastName.Length > 64)
                {
                    AddFieldError($"Member{i}_LastName", $"{member.Role} Last Name must not exceed 64 characters");
                }

                if (!string.IsNullOrWhiteSpace(member.SSN))
                {
                    var ssnResult = SSNInput.ValidateSSN(member.SSN, member.Role);
                    if (ssnResult != null && !ssnResult.IsValid)
                    {
                        AddFieldError($"Member{i}_SSN", ssnResult.ErrorMessage);
                    }
                }
                else
                {
                    AddFieldError($"Member{i}_SSN", $"{member.Role} SSN is required");
                }

                if (member.OwnershipPercentage.HasValue)
                {
                    if (member.OwnershipPercentage < 0 || member.OwnershipPercentage > 100)
                    {
                        AddFieldError($"Member{i}_OwnershipPercentage", $"{member.Role} Ownership Percentage must be between 0 and 100.00");
                    }
                    else if (decimal.Round(member.OwnershipPercentage.Value, 2) != member.OwnershipPercentage.Value)
                    {
                        AddFieldError($"Member{i}_OwnershipPercentage", $"{member.Role} Ownership Percentage must not exceed 2 decimal places");
                    }
                }
            }
        }

        var totalPercentage = Members
            .Where(m => m.OwnershipPercentage.HasValue)
            .Sum(m => m.OwnershipPercentage!.Value);

        if (totalPercentage > 0 && Math.Round(totalPercentage, 2) != 100)
        {
            var msg = "Total Ownership Percentage must equal 100.00";
            var firstIdx = Members.FindIndex(m => m.OwnershipPercentage.HasValue);
            var elementId = firstIdx >= 0 ? $"ownership-percentage-{firstIdx}" : string.Empty;
            _validationItems.Add(new ValidationItem(msg, elementId));
            ValidationErrors.Add(msg);
            for (var i = 0; i < Members.Count; i++)
            {
                if (Members[i].OwnershipPercentage.HasValue)
                {
                    InvalidFields.Add($"Member{i}_OwnershipPercentage");
                    FieldErrors.TryAdd($"Member{i}_OwnershipPercentage", msg);
                }
            }
        }

        var ssnList = Members.Select(m => (string?)m.SSN).ToList();
        var duplicateErrors = SSNInput.FindDuplicateSSNs(ssnList, i => Members[i].Role);

        if (duplicateErrors != null && duplicateErrors.Count > 0)
        {
            var ssnGroups = Members
                .Select((m, idx) => new { SSN = m.SSN, Index = idx })
                .Where(x => !string.IsNullOrWhiteSpace(x.SSN))
                .GroupBy(x => new string(x.SSN!.Where(char.IsDigit).ToArray()))
                .Where(g => g.Count() > 1);

            foreach (var group in ssnGroups)
            {
                var dupMsg = $"Duplicate SSN found for: {string.Join(", ", group.Select(x => Members[x.Index].Role))}";
                var firstItem = group.First();
                var elementId = $"ssn-{firstItem.Index}";
                _validationItems.Add(new ValidationItem(dupMsg, elementId));
                ValidationErrors.Add(dupMsg);
                foreach (var item in group)
                {
                    InvalidFields.Add($"Member{item.Index}_SSN");
                    FieldErrors.TryAdd($"Member{item.Index}_SSN", dupMsg);
                }
            }
        }

        if (MoreThanFive == null)
        {
            _validationItems.Add(new ValidationItem("More than five ? selection is required", "more-than-five-group"));
            ValidationErrors.Add("More than five? selection is required");
            InvalidFields.Add("MoreThanFive");
        }

        _ = OnValidationChanged.InvokeAsync(_validationItems);
        NotifyDataChanged();
        StateHasChanged();
    }

    private void NotifyDataChanged()
    {
        var formData = new MemberBasedFormData
        {
            RegistrationState = RegistrationState,
            Members = Members.Select(m => new OwnerMember
            {
                Role = m.Role,
                FirstName = m.FirstName,
                MiddleInitial = m.MiddleInitial,
                LastName = m.LastName,
                SSN = m.SSN,
                OwnershipPercentage = m.OwnershipPercentage
            }).ToList(),
            MoreThanFive = MoreThanFive
        };

        _ = OnDataChanged.InvokeAsync(formData);
    }

    private string GetFieldCssClass(string fieldName)
    {
        return InvalidFields.Contains(fieldName) ? "input-validation-error" : string.Empty;
    }
}
