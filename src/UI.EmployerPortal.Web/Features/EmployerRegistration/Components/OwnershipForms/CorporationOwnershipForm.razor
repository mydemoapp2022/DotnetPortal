@using UI.EmployerPortal.Web.Features.EmployerRegistration.Models
@using UI.EmployerPortal.Web.Features.EmployerRegistration.Components.Shared
@using UI.EmployerPortal.Razor.SharedComponents.Inputs

<div class="corporation-section">
    <!-- Incorporation State or Foreign Country -->
    <div class="form-row">
        <StateSelect Id="incorporation-state"
                     Label="@Config.StateLabel"
                     Value="@IncorporationState"
                     ValueChanged="OnIncorporationStateChanged"
                     Disabled="@(!string.IsNullOrWhiteSpace(ForeignCountry))"
                     CssClass="@(GetFieldCssClass("IncorporationState"))" />

        <div class="form-group-divider">
            <span>OR</span>
        </div>

        <ValidatedInput Id="foreign-country"
                        Label="Foreign Country"
                        Value="@ForeignCountry"
                        ValueChanged="@(v => { ForeignCountry = v; OnForeignCountryChanged(); })"
                        Disabled="@(!string.IsNullOrWhiteSpace(IncorporationState))"
                        HasError="@InvalidFields.Contains("ForeignCountry")"
                        ErrorMessage="@GetErrorForField("ForeignCountry")"
                        OnBlur="ValidateForm" />
    </div>

    <!-- Owner Information Section -->
    <div class="owner-info-section">
        <h2 class="section-subtitle">Owner Information</h2>

        @for (var i = 0; i < Officers.Count; i++)
        {
            var index = i;
            var officer = Officers[index];

            <div class="member-card">
                <h3 class="member-title">@officer.Role</h3>

                <div class="member-fields">
                    <ValidatedInput Id="@($"first-name-{officer.Role}")"
                                    Label="First Name"
                                    Value="@officer.FirstName"
                                    ValueChanged="@(v => officer.FirstName = v)"
                                    MaxLength="64"
                                    Width="106"
                                    HasError="@InvalidFields.Contains($"{officer.Role}_FirstName")"
                                    ErrorMessage="@GetErrorForField($"{officer.Role}_FirstName")"
                                    OnBlur="ValidateForm" />

                    <ValidatedInput Id="@($"middle-initial-{officer.Role}")"
                                    Label="Middle Initial"
                                    Value="@officer.MiddleInitial"
                                    ValueChanged="@(v => officer.MiddleInitial = v)"
                                    MaxLength="1"
                                    Width="114" />

                    <ValidatedInput Id="@($"last-name-{officer.Role}")"
                                    Label="Last Name"
                                    Value="@officer.LastName"
                                    ValueChanged="@(v => officer.LastName = v)"
                                    MaxLength="64"
                                    Width="103"
                                    HasError="@InvalidFields.Contains($"{officer.Role}_LastName")"
                                    ErrorMessage="@GetErrorForField($"{officer.Role}_LastName")"
                                    OnBlur="ValidateForm" />

                    <SSNInput Id="@($"ssn-{officer.Role}")"
                              Label="SSN"
                              Value="@officer.SSN"
                              ValueChanged="@((string value) => OnSSNChanged(index, value))"
                              IsFocused="@officer.IsSSNFocused"
                              IsFocusedChanged="@((bool focused) => OnSSNFocusChanged(index, focused))"
                              ShowSSN="@ShowSSN"
                              ShowSSNChanged="@((bool show) => ShowSSN = show)"
                              IsRequired="@(!ISOutsideUSA)"
                              CssClass="@(GetFieldCssClass($"{officer.Role}_SSN"))" />

                    <ValidatedInput Id="@($"ownership-percentage-{officer.Role}")"
                                    Label="Ownership (%)"
                                    InputType="number"
                                    Value="@(officer.OwnershipPercentage?.ToString("0.##"))"
                                    ValueChanged="@(v => officer.OwnershipPercentage = decimal.TryParse(v, out var n) ? n : null)"
                                    Min="0"
                                    Max="100"
                                    Step="0.01"
                                    Width="130"
                                    HasError="@InvalidFields.Contains($"{officer.Role}_OwnershipPercentage")"
                                    ErrorMessage="@GetErrorForField($"{officer.Role}_OwnershipPercentage")"
                                    OnBlur="ValidateForm" />
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public OwnershipFormConfig Config { get; set; } = new();

    [Parameter]
    public EventCallback<CorporationFormData> OnDataChanged { get; set; }

    [Parameter]
    public EventCallback<List<string>> OnValidationChanged { get; set; }

    [Parameter]
    public object? SavedData { get; set; }

    [Parameter]
    public bool ISOutsideUSA { get; set; }

    [Parameter]
    public Action<Func<List<string>>>? RegisterValidate { get; set; }

    private string IncorporationState { get; set; } = string.Empty;
    private string ForeignCountry { get; set; } = string.Empty;
    private bool ShowSSN { get; set; }
    private List<OwnerMember> Officers { get; set; } = [];
    private List<string> ValidationErrors { get; set; } = [];
    private HashSet<string> InvalidFields { get; set; } = [];
    private bool _dataRestored;
    private bool _previousISOutsideUSA;

    protected override void OnInitialized()
    {
        _previousISOutsideUSA = ISOutsideUSA;
        InitializeOfficers();
        RestoreFromSession();
        RegisterValidate?.Invoke(() => { ValidateForm(); return ValidationErrors; });
    }

    protected override void OnParametersSet()
    {
        if (_previousISOutsideUSA != ISOutsideUSA)
        {
            _previousISOutsideUSA = ISOutsideUSA;
        }
    }

    private void RestoreFromSession()
    {
        if (_dataRestored || SavedData == null)
            return;

        try
        {
            if (SavedData is OwnershipSessionData sessionData)
            {
                IncorporationState = sessionData.IncorporationState ?? string.Empty;
                ForeignCountry = sessionData.ForeignCountry ?? string.Empty;

                if (sessionData.Officers is { Count: > 0 })
                {
                    Officers.Clear();
                    foreach (var savedOfficer in sessionData.Officers)
                    {
                        Officers.Add(new OwnerMember
                        {
                            Role = savedOfficer.Role,
                            FirstName = savedOfficer.FirstName,
                            MiddleInitial = savedOfficer.MiddleInitial,
                            LastName = savedOfficer.LastName,
                            SSN = savedOfficer.SSN,
                            OwnershipPercentage = savedOfficer.OwnershipPercentage
                        });
                    }
                }

                _dataRestored = true;
            }
        }
        catch
        {
            // Failed to restore, continue with defaults
        }
    }

    private void InitializeOfficers()
    {
        if (Officers.Count > 0)
            return;

        Officers.Clear();
        foreach (var role in Config.PredefinedRoles)
        {
            Officers.Add(new OwnerMember { Role = role });
        }
    }

    private void OnIncorporationStateChanged(string value)
    {
        IncorporationState = value;
        if (!string.IsNullOrWhiteSpace(IncorporationState))
            ForeignCountry = string.Empty;
        ValidateForm();
    }

    private void OnForeignCountryChanged()
    {
        if (!string.IsNullOrWhiteSpace(ForeignCountry))
            IncorporationState = string.Empty;
        ValidateForm();
    }

    private void OnSSNChanged(int index, string value)
    {
        if (index >= 0 && index < Officers.Count)
        {
            Officers[index].SSN = value;
            ValidateForm();
        }
    }

    private void OnSSNFocusChanged(int index, bool focused)
    {
        if (index >= 0 && index < Officers.Count)
            Officers[index].IsSSNFocused = focused;
    }

    private void ValidateForm()
    {
        ValidationErrors.Clear();
        InvalidFields.Clear();

        if (string.IsNullOrWhiteSpace(IncorporationState) && string.IsNullOrWhiteSpace(ForeignCountry))
        {
            ValidationErrors.Add($"{Config.StateLabel} or Foreign Country is required");
            InvalidFields.Add("IncorporationState");
            InvalidFields.Add("ForeignCountry");
        }

        var hasAnyOfficerData = Officers.Any(o =>
            !string.IsNullOrWhiteSpace(o.FirstName) || !string.IsNullOrWhiteSpace(o.MiddleInitial) ||
            !string.IsNullOrWhiteSpace(o.LastName) || !string.IsNullOrWhiteSpace(o.SSN) ||
            o.OwnershipPercentage.HasValue);

        if (!hasAnyOfficerData)
        {
            ValidationErrors.Add("At least one officer is required");
        }
        else
        {
            for (var i = 0; i < Officers.Count; i++)
            {
                var officer = Officers[i];
                var hasAnyValue = !string.IsNullOrWhiteSpace(officer.FirstName) ||
                                  !string.IsNullOrWhiteSpace(officer.MiddleInitial) ||
                                  !string.IsNullOrWhiteSpace(officer.LastName) ||
                                  !string.IsNullOrWhiteSpace(officer.SSN) ||
                                  officer.OwnershipPercentage.HasValue;

                if (!hasAnyValue) continue;

                if (string.IsNullOrWhiteSpace(officer.FirstName))
                {
                    ValidationErrors.Add($"{officer.Role} First Name is required");
                    InvalidFields.Add($"{officer.Role}_FirstName");
                }
                else if (officer.FirstName.Length > 64)
                {
                    ValidationErrors.Add($"{officer.Role} First Name must not exceed 64 characters");
                    InvalidFields.Add($"{officer.Role}_FirstName");
                }

                if (string.IsNullOrWhiteSpace(officer.LastName))
                {
                    ValidationErrors.Add($"{officer.Role} Last Name is required");
                    InvalidFields.Add($"{officer.Role}_LastName");
                }
                else if (officer.LastName.Length > 64)
                {
                    ValidationErrors.Add($"{officer.Role} Last Name must not exceed 64 characters");
                    InvalidFields.Add($"{officer.Role}_LastName");
                }

                if (!ISOutsideUSA || !string.IsNullOrWhiteSpace(officer.SSN))
                {
                    var ssnResult = SSNInput.ValidateSSN(officer.SSN, officer.Role);
                    if (ssnResult != null && !ssnResult.IsValid)
                    {
                        ValidationErrors.Add(ssnResult.ErrorMessage);
                        InvalidFields.Add($"{officer.Role}_SSN");
                    }
                }

                if (officer.OwnershipPercentage.HasValue)
                {
                    if (officer.OwnershipPercentage < 0 || officer.OwnershipPercentage > 100)
                    {
                        ValidationErrors.Add($"{officer.Role} Ownership Percentage must be between 0 and 100.00");
                        InvalidFields.Add($"{officer.Role}_OwnershipPercentage");
                    }
                    else if (decimal.Round(officer.OwnershipPercentage.Value, 2) != officer.OwnershipPercentage.Value)
                    {
                        ValidationErrors.Add($"{officer.Role} Ownership Percentage must not exceed 2 decimal places");
                        InvalidFields.Add($"{officer.Role}_OwnershipPercentage");
                    }
                }
            }

            var totalPercentage = Officers
                .Where(o => o.OwnershipPercentage.HasValue)
                .Sum(o => o.OwnershipPercentage!.Value);

            if (totalPercentage > 0 && Math.Round(totalPercentage, 2) != 100)
            {
                ValidationErrors.Add("Total Ownership Percentage must equal 100.00");
                foreach (var o in Officers.Where(o => o.OwnershipPercentage.HasValue))
                    InvalidFields.Add($"{o.Role}_OwnershipPercentage");
            }

            var ssnList = Officers.Select(o => (string?)o.SSN).ToList();
            var duplicateErrors = SSNInput.FindDuplicateSSNs(ssnList, i => Officers[i].Role);

            if (duplicateErrors is { Count: > 0 })
            {
                ValidationErrors.AddRange(duplicateErrors);
                var ssnGroups = Officers
                    .Select((o, idx) => new { o.SSN, o.Role, Index = idx })
                    .Where(x => !string.IsNullOrWhiteSpace(x.SSN))
                    .GroupBy(x => new string(x.SSN!.Where(char.IsDigit).ToArray()))
                    .Where(g => g.Count() > 1);

                foreach (var group in ssnGroups)
                    foreach (var item in group)
                        InvalidFields.Add($"{item.Role}_SSN");
            }
        }

        _ = OnValidationChanged.InvokeAsync(ValidationErrors);
        NotifyDataChanged();
        StateHasChanged();
    }

    private void NotifyDataChanged()
    {
        _ = OnDataChanged.InvokeAsync(new CorporationFormData
        {
            IncorporationState = IncorporationState,
            ForeignCountry = ForeignCountry,
            Officers = Officers.Select(o => new OwnerMember
            {
                Role = o.Role,
                FirstName = o.FirstName,
                MiddleInitial = o.MiddleInitial,
                LastName = o.LastName,
                SSN = o.SSN,
                OwnershipPercentage = o.OwnershipPercentage
            }).ToList()
        });
    }

    private string GetFieldCssClass(string fieldName) =>
        InvalidFields.Contains(fieldName) ? "input-validation-error" : string.Empty;

    private string? GetErrorForField(string fieldKey)
    {
        if (!InvalidFields.Contains(fieldKey))
            return null;

        var sep = fieldKey.LastIndexOf('_');
        if (sep < 0)
        {
            var lbl = System.Text.RegularExpressions.Regex.Replace(fieldKey, "(?<=[a-z])(?=[A-Z])", " ");
            return ValidationErrors.FirstOrDefault(e => e.Contains(lbl, StringComparison.OrdinalIgnoreCase));
        }

        var prefixLabel = System.Text.RegularExpressions.Regex.Replace(fieldKey[..sep], "(?<=[a-z])(?=[A-Z])", " ");
        var fieldLabel = System.Text.RegularExpressions.Regex.Replace(fieldKey[(sep + 1)..], "(?<=[a-z])(?=[A-Z])", " ");

        return ValidationErrors.FirstOrDefault(e =>
            e.Contains(prefixLabel, StringComparison.OrdinalIgnoreCase) &&
            e.Contains(fieldLabel, StringComparison.OrdinalIgnoreCase))
            ?? ValidationErrors.FirstOrDefault(e => e.Contains(fieldLabel, StringComparison.OrdinalIgnoreCase));
    }
}
