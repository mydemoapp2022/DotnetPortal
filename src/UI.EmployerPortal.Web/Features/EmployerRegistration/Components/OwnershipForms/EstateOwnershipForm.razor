@using UI.EmployerPortal.Razor.SharedComponents.Inputs
@using UI.EmployerPortal.Web.Features.EmployerRegistration.Models
@using UI.EmployerPortal.Web.Features.EmployerRegistration.Components.Shared

<div class="estate-section">
    <!-- Decedent Section -->
    <div class="owner-info-section">
        <div class="member-card">
            <h3 class="member-title">Decedent</h3>

            <div class="member-fields">
                <ValidatedInput Id="decedent-first-name"
                                Label="First Name"
                                Value="@Decedent.FirstName"
                                ValueChanged="@(v => Decedent.FirstName = v)"
                                MaxLength="64"
                                Width="106"
                                HasError="@InvalidFields.Contains("Decedent_FirstName")"
                                ErrorMessage="@GetErrorForField("Decedent_FirstName")"
                                OnBlur="ValidateForm" />

                <ValidatedInput Id="decedent-middle-initial"
                                Label="Middle Initial"
                                Value="@Decedent.MiddleInitial"
                                ValueChanged="@(v => Decedent.MiddleInitial = v)"
                                MaxLength="1"
                                Width="114" />

                <ValidatedInput Id="decedent-last-name"
                                Label="Last Name"
                                Value="@Decedent.LastName"
                                ValueChanged="@(v => Decedent.LastName = v)"
                                MaxLength="64"
                                Width="103"
                                HasError="@InvalidFields.Contains("Decedent_LastName")"
                                ErrorMessage="@GetErrorForField("Decedent_LastName")"
                                OnBlur="ValidateForm" />

                <SSNInput Id="decedent-ssn"
                          Label="SSN"
                          Value="@Decedent.SSN"
                          ValueChanged="@((string value) => OnDecedentSSNChanged(value))"
                          IsFocused="@Decedent.IsSSNFocused"
                          IsFocusedChanged="@((bool focused) => Decedent.IsSSNFocused = focused)"
                          ShowSSN="@ShowSSN"
                          ShowSSNChanged="@((bool show) => ShowSSN = show)"
                          IsRequired="@(!ISOutsideUSA)"
                          CssClass="@(GetFieldCssClass("Decedent_SSN"))" />
            </div>
        </div>
    </div>

    <!-- Personal Representative Section -->
    <div class="owner-info-section">
        <div class="member-card">
            <h3 class="member-title">Personal Representative</h3>

            <div class="member-fields">
                <ValidatedInput Id="representative-first-name"
                                Label="First Name"
                                Value="@PersonalRepresentative.FirstName"
                                ValueChanged="@(v => PersonalRepresentative.FirstName = v)"
                                MaxLength="64"
                                Width="106"
                                HasError="@InvalidFields.Contains("PersonalRepresentative_FirstName")"
                                ErrorMessage="@GetErrorForField("PersonalRepresentative_FirstName")"
                                OnBlur="ValidateForm" />

                <ValidatedInput Id="representative-middle-initial"
                                Label="Middle Initial"
                                Value="@PersonalRepresentative.MiddleInitial"
                                ValueChanged="@(v => PersonalRepresentative.MiddleInitial = v)"
                                MaxLength="1"
                                Width="114" />

                <ValidatedInput Id="representative-last-name"
                                Label="Last Name"
                                Value="@PersonalRepresentative.LastName"
                                ValueChanged="@(v => PersonalRepresentative.LastName = v)"
                                MaxLength="64"
                                Width="103"
                                HasError="@InvalidFields.Contains("PersonalRepresentative_LastName")"
                                ErrorMessage="@GetErrorForField("PersonalRepresentative_LastName")"
                                OnBlur="ValidateForm" />

                <SSNInput Id="representative-ssn"
                          Label="SSN"
                          Value="@PersonalRepresentative.SSN"
                          ValueChanged="@((string value) => OnRepresentativeSSNChanged(value))"
                          IsFocused="@PersonalRepresentative.IsSSNFocused"
                          IsFocusedChanged="@((bool focused) => PersonalRepresentative.IsSSNFocused = focused)"
                          ShowSSN="@ShowSSN"
                          ShowSSNChanged="@((bool show) => ShowSSN = show)"
                          IsRequired="@(!ISOutsideUSA)"
                          CssClass="@(GetFieldCssClass("PersonalRepresentative_SSN"))" />
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public OwnershipFormConfig Config { get; set; } = new();

    [Parameter]
    public EventCallback<EstateFormData> OnDataChanged { get; set; }

    [Parameter]
    public EventCallback<List<string>> OnValidationChanged { get; set; }

    [Parameter]
    public bool ISOutsideUSA { get; set; }

    [Parameter]
    public object? SavedData { get; set; }

    [Parameter]
    public Action<Func<List<string>>>? RegisterValidate { get; set; }

    private OwnerMember Decedent { get; set; } = new() { Role = "Decedent" };
    private OwnerMember PersonalRepresentative { get; set; } = new() { Role = "Personal Representative" };
    private bool ShowSSN { get; set; }
    private List<string> ValidationErrors { get; set; } = [];
    private HashSet<string> InvalidFields { get; set; } = [];
    private bool _dataRestored;
    private bool _previousISOutsideUSA;

    protected override void OnInitialized()
    {
        _previousISOutsideUSA = ISOutsideUSA;
        Decedent = new OwnerMember { Role = "Decedent" };
        PersonalRepresentative = new OwnerMember { Role = "Personal Representative" };
        RestoreFromSession();
        RegisterValidate?.Invoke(() => { ValidateForm(); return ValidationErrors; });
    }

    protected override void OnParametersSet()
    {
        if (_previousISOutsideUSA != ISOutsideUSA)
        {
            _previousISOutsideUSA = ISOutsideUSA;
        }
    }

    private void RestoreFromSession()
    {
        if (_dataRestored || SavedData == null)
            return;

        try
        {
            if (SavedData is OwnershipSessionData sessionData)
            {
                if (sessionData.Decedent != null)
                    Decedent = new OwnerMember
                    {
                        Role = "Decedent",
                        FirstName = sessionData.Decedent.FirstName,
                        MiddleInitial = sessionData.Decedent.MiddleInitial,
                        LastName = sessionData.Decedent.LastName,
                        SSN = sessionData.Decedent.SSN
                    };

                if (sessionData.PersonalRepresentative != null)
                    PersonalRepresentative = new OwnerMember
                    {
                        Role = "Personal Representative",
                        FirstName = sessionData.PersonalRepresentative.FirstName,
                        MiddleInitial = sessionData.PersonalRepresentative.MiddleInitial,
                        LastName = sessionData.PersonalRepresentative.LastName,
                        SSN = sessionData.PersonalRepresentative.SSN
                    };

                _dataRestored = true;
            }
        }
        catch
        {
            // Failed to restore, continue with defaults
        }
    }

    private void OnDecedentSSNChanged(string value)
    {
        Decedent.SSN = value;
        ValidateForm();
    }

    private void OnRepresentativeSSNChanged(string value)
    {
        PersonalRepresentative.SSN = value;
        ValidateForm();
    }

    private void ValidateForm()
    {
        ValidationErrors.Clear();
        InvalidFields.Clear();

        // Decedent
        if (string.IsNullOrWhiteSpace(Decedent.FirstName))
        {
            ValidationErrors.Add("Decedent First Name is required");
            InvalidFields.Add("Decedent_FirstName");
        }
        else if (Decedent.FirstName.Length > 64)
        {
            ValidationErrors.Add("Decedent First Name must not exceed 64 characters");
            InvalidFields.Add("Decedent_FirstName");
        }

        if (string.IsNullOrWhiteSpace(Decedent.LastName))
        {
            ValidationErrors.Add("Decedent Last Name is required");
            InvalidFields.Add("Decedent_LastName");
        }
        else if (Decedent.LastName.Length > 64)
        {
            ValidationErrors.Add("Decedent Last Name must not exceed 64 characters");
            InvalidFields.Add("Decedent_LastName");
        }

        if (!ISOutsideUSA || !string.IsNullOrWhiteSpace(Decedent.SSN))
        {
            var ssnResult = SSNInput.ValidateSSN(Decedent.SSN, "Decedent");
            if (ssnResult != null && !ssnResult.IsValid)
            {
                ValidationErrors.Add(ssnResult.ErrorMessage ?? "Decedent SSN is invalid");
                InvalidFields.Add("Decedent_SSN");
            }
        }

        // Personal Representative
        if (string.IsNullOrWhiteSpace(PersonalRepresentative.FirstName))
        {
            ValidationErrors.Add("Personal Representative First Name is required");
            InvalidFields.Add("PersonalRepresentative_FirstName");
        }
        else if (PersonalRepresentative.FirstName.Length > 64)
        {
            ValidationErrors.Add("Personal Representative First Name must not exceed 64 characters");
            InvalidFields.Add("PersonalRepresentative_FirstName");
        }

        if (string.IsNullOrWhiteSpace(PersonalRepresentative.LastName))
        {
            ValidationErrors.Add("Personal Representative Last Name is required");
            InvalidFields.Add("PersonalRepresentative_LastName");
        }
        else if (PersonalRepresentative.LastName.Length > 64)
        {
            ValidationErrors.Add("Personal Representative Last Name must not exceed 64 characters");
            InvalidFields.Add("PersonalRepresentative_LastName");
        }

        if (!ISOutsideUSA || !string.IsNullOrWhiteSpace(PersonalRepresentative.SSN))
        {
            var ssnResult = SSNInput.ValidateSSN(PersonalRepresentative.SSN, "Personal Representative");
            if (ssnResult != null && !ssnResult.IsValid)
            {
                ValidationErrors.Add(ssnResult.ErrorMessage);
                InvalidFields.Add("PersonalRepresentative_SSN");
            }
        }

        var ssnList = new List<string?> { Decedent.SSN, PersonalRepresentative.SSN };
        var duplicateErrors = SSNInput.FindDuplicateSSNs(ssnList, i => i == 0 ? "Decedent" : "Personal Representative");
        if (duplicateErrors is { Count: > 0 })
        {
            ValidationErrors.AddRange(duplicateErrors);
            InvalidFields.Add("Decedent_SSN");
            InvalidFields.Add("PersonalRepresentative_SSN");
        }

        _ = OnValidationChanged.InvokeAsync(ValidationErrors);
        NotifyDataChanged();
        StateHasChanged();
    }

    private void NotifyDataChanged()
    {
        _ = OnDataChanged.InvokeAsync(new EstateFormData
        {
            Decedent = Decedent,
            PersonalRepresentative = PersonalRepresentative
        });
    }

    private string GetFieldCssClass(string fieldName) =>
        InvalidFields.Contains(fieldName) ? "input-validation-error" : string.Empty;

    private string? GetErrorForField(string fieldKey)
    {
        if (!InvalidFields.Contains(fieldKey))
            return null;

        var sep = fieldKey.LastIndexOf('_');
        if (sep < 0)
        {
            var lbl = System.Text.RegularExpressions.Regex.Replace(fieldKey, "(?<=[a-z])(?=[A-Z])", " ");
            return ValidationErrors.FirstOrDefault(e => e.Contains(lbl, StringComparison.OrdinalIgnoreCase));
        }

        var prefixLabel = System.Text.RegularExpressions.Regex.Replace(fieldKey[..sep], "(?<=[a-z])(?=[A-Z])", " ");
        var fieldLabel = System.Text.RegularExpressions.Regex.Replace(fieldKey[(sep + 1)..], "(?<=[a-z])(?=[A-Z])", " ");

        return ValidationErrors.FirstOrDefault(e =>
            e.Contains(prefixLabel, StringComparison.OrdinalIgnoreCase) &&
            e.Contains(fieldLabel, StringComparison.OrdinalIgnoreCase))
            ?? ValidationErrors.FirstOrDefault(e => e.Contains(fieldLabel, StringComparison.OrdinalIgnoreCase));
    }
}
