    //             return q.SortOrder;
    //         })
    //         .Select(q =>
    //         {
    //             var match = SurveyResponses.FirstOrDefault(r =>
    //             {
    //                 return r._surveyResponseItemSk == q.QuestionSetItemSK;
    //             });
    //             return match != null
    //                 ? Tuple.Create(q, match)
    //                 : null;
    //         })
    //         .OfType<Tuple<EmployerRegistrationQuestionDataProxy, SurveyResponse>>()
    //         .ToList();
    // }

    private List<Tuple<RegistrationAddressCode, AddressModel>> GetAddressesForSection(int sectionIndex)
    {
        return Addresses.Where(address =>
        {
            return addressCodesForSection[sectionIndex].Contains(address.Item1);
        }).ToList();
    }
}
