@if (Visible)
{
    @if (IsRightAlignedContent())
    {
        <div class="row @GetCssClass()" aria-label=@($"{Title} {GetFormattedMessage()}")>
            <div class="col-md-8 text-start">@GetNotificationIcon()<span class="nb-text"><strong class="mb-2 me-2">@Title:</strong>@GetFormattedMessage()</span></div>
            <div class="col-md-4">
                <div class="row justify-content-end">
                    <div class="col-auto">
                        @if (DueDate.HasValue)
                        {
                            @GetDueDateIcon()
                            @if (DueDateState == DueDateState.Achieved)
                            {
                                <span class="nb-text text-end">@GetDueDateText()</span>
                            }
                            else
                            {
                                <span class="nb-text text-end"><strong>@GetDueDateText()</strong></span>
                            }
                        }
                    </div>
                    <div class="col-auto nb-action">
                        @if (HasAction())
                        {
                            <a href="@ActionLink" class="nav-link me-2">Action</a>
                        }
                    </div>
                    <div class="col-auto">
                        @if (DismissButton)
                        {
                            <div @onclick="Hide">@GetDismissIcon()</div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <br />
    }
    else
    {
        <div class="row @GetCssClass()" aria-label=@($"{Title} {Message}")>
            <div class="col text-start">@GetNotificationIcon()<span class="nb-text"><strong class="mb-2 me-2">@Title:</strong>@GetFormattedMessage()</span></div>
        </div>
        <br />
    }
}
